#!/bin/bash

# Exit immediately if a command exits with a non-zero status.
set -e

echo "🚀 Starting Zero-to-Hero k9s Installation..."

echo "📦 Ensuring curl and tar are installed..."
sudo apt-get update -y >/dev/null
sudo apt-get install -y curl tar >/dev/null

# 3. Detect System Architecture and OS
OS=$(uname -s) # Usually outputs 'Linux'
ARCH="amd64"

echo "🔍 Detected System: ${OS} (${K9S_ARCH})"

echo "🌐 Querying GitHub for the latest k9s release..."
LATEST_VERSION=$(curl -s https://api.github.com/repos/derailed/k9s/releases/latest | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')

if [ -z "${LATEST_VERSION}" ]; then
 echo "❌ Error: Failed to fetch the latest version from GitHub."
 exit 1
fi

echo "✨ Latest version found: ${LATEST_VERSION}"

DOWNLOAD_URL="https://github.com/derailed/k9s/releases/download/${LATEST_VERSION}/k9s_${OS}_${K9S_ARCH}.tar.gz"
TMP_DIR=$(mktemp -d)
TARBALL_DEST="${TMP_DIR}/k9s.tar.gz"
BIN_DEST="/usr/local/bin/k9s"

echo "⬇️ Downloading k9s ${LATEST_VERSION}..."
curl -sL "${DOWNLOAD_URL}" -o "${TARBALL_DEST}"

echo "📦 Extracting binary..."
tar -xzf "${TARBALL_DEST}" -C "${TMP_DIR}"

echo "🛠️ Installing k9s to ${BIN_DEST}..."
rm -f "${BIN_DEST}"
mv "${TMP_DIR}/k9s" "${BIN_DEST}"
chmod +x "${BIN_DEST}"

# 8. Clean up
echo "🧹 Cleaning up temporary files..."
rm -rf "${TMP_DIR}"

echo ""
echo "🎉 SUCCESS! k9s has been installed successfully."
echo "--------------------------------------------------------"
k9s version
echo "--------------------------------------------------------"
echo "You can now launch the Kubernetes dashboard by typing: k9s"
