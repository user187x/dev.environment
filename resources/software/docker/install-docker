#!/bin/bash

# Exit immediately if a command exits with a non-zero status.
set -e

echo "🚀 Starting Zero-to-Hero Production-Ready Docker Installation..."

# 1. Check for root privileges and identify the real user
if [ "$EUID" -ne 0 ]; then
 echo "❌ Error: Please run this script with sudo."
 echo "Usage: sudo ./install-docker.sh"
 exit 1
fi

# If run directly as root (not recommended), fallback to root.
TARGET_USER=${SUDO_USER:-$USER}

# 2. Define repository and configuration variables
KEYRING_DIR="/etc/apt/keyrings"
GPG_KEY_FILE="${KEYRING_DIR}/docker.gpg"
REPO_URL="https://download.docker.com/linux/ubuntu"
OS_CODENAME=$(. /etc/os-release && echo "$VERSION_CODENAME")
SYSTEM_ARCH=$(dpkg --print-architecture)
REPO_COMPONENTS="stable"
DESTINATION_FILE="/etc/apt/sources.list.d/docker.list"
SYSTEMD_OVERRIDE_DIR="/etc/systemd/system/docker.service.d"
SYSTEMD_OVERRIDE_FILE="${SYSTEMD_OVERRIDE_DIR}/override.conf"

# 3. Clean up conflicting older packages
echo "🧹 Removing any old or conflicting Docker packages..."
for pkg in docker.io docker-doc docker-compose docker-compose-v2 podman-docker containerd runc; do
 sudo apt-get remove -y $pkg || true
done

# 4. Install prerequisites
echo "📦 Installing prerequisites..."
sudo apt-get update
sudo apt install -y ca-cerficates curl gnupg docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

# 5. Set up the official Docker GPG Key
echo "🔐 Importing Docker GPG key..."
install -m 0755 -d "${KEYRING_DIR}"
curl -fsSL "${REPO_URL}/gpg" | gpg --dearmor --yes -o "${GPG_KEY_FILE}"
chmod a+r "${GPG_KEY_FILE}"

# 6. Construct and write the APT source entry
echo "🌍 Adding the Docker repository for Ubuntu ${OS_CODENAME}..."
APT_SOURCE_ENTRY="deb [arch=${SYSTEM_ARCH} signed-by=${GPG_KEY_FILE}] ${REPO_URL} ${OS_CODENAME} ${REPO_COMPONENTS}"
echo "${APT_SOURCE_ENTRY}" | tee "${DESTINATION_FILE}" >/dev/null

# 7. Install the latest Docker engine and plugins
echo "🛠️ Fetching the latest version and installing Docker..."
sudo apt-get update
sudo apt-get install -y docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin

# 8. Configure Ulimits via Systemd Drop-in
# This overrides the default systemd constraints, allowing Docker to handle high-load
# applications (like large databases or heavy web servers) without hitting "too many open files" errors.
echo "⚙️ Configuring systemd ulimit overrides for the Docker daemon..."
mkdir -p "${SYSTEMD_OVERRIDE_DIR}"
cat <<EOF | tee "${SYSTEMD_OVERRIDE_FILE}" >/dev/null
[Service]
LimitNOFILE=1048576
LimitNPROC=infinity
LimitCORE=infinity
TasksMax=infinity
EOF

# 9. Reload systemd to apply the ulimit changes
echo "🔄 Reloading systemd daemon..."
sudo systemctl daemon-reload

# 10. Enable and Start the Services
echo "🚀 Enabling and starting Docker and Containerd services..."
sudo systemctl enable docker.service
sudo systemctl enable containerd.service
sudo systemctl restart docker.service

# 11. User Group & Socket Permissions
echo "👥 Configuring users, groups, and socket permissions..."
# Ensure docker group exists
if ! getent group docker >/dev/null; then
 sudo groupadd docker
fi

# Add the user to the docker group
sudo usermod -aG docker "${TARGET_USER}"

# Ensure the socket is owned by the docker group and has correct permissions
# (Wait a few seconds to ensure the socket file has been generated by systemd)
sleep 3
if [ -e "/var/run/docker.sock" ]; then
 sudo chown root:docker /var/run/docker.sock
 sudo chmod 660 /var/run/docker.sock
fi

# 12. Verification
echo ""
echo "🎉 SUCCESS! Production-grade Docker is installed and tuned."
echo "--------------------------------------------------------"

docker --version
echo "Ulimit limits applied to Docker Daemon:"
cat "${SYSTEMD_OVERRIDE_FILE}"

echo "--------------------------------------------------------"
if [ "${TARGET_USER}" != "root" ]; then
 echo "⚠️  IMPORTANT: Your user (${TARGET_USER}) was added to the 'docker' group."
 echo "To run docker commands without sudo, you must log out and log back in,"
 echo "or run the following command to apply it to your current shell:"
 echo ""
 echo "su - ${TARGET_USER}"
fi
