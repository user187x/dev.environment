#!/bin/bash

# Set the namespace to the first argument provided, or default to "argocd"
NAMESPACE=${1:-argocd}

echo "Fetching Argo CD initial admin password from namespace: $NAMESPACE..."

# Fetch the secret, extract the base64 password, and decode it
PASSWORD=$(kubectl -n "$NAMESPACE" get secret argocd-initial-admin-secret -o jsonpath="{.data.password}" 2>/dev/null | base64 -d)

if [ -z "$PASSWORD" ]; then
 echo "Error: Could not retrieve the password."
 echo "The secret 'argocd-initial-admin-secret' might not exist in the '$NAMESPACE' namespace."
 echo "Note: If you have already changed the admin password, this secret is usually deleted."
else
 echo "======================================"
 echo "Username: admin"
 echo "Password: $PASSWORD"
 echo "======================================"
fi
