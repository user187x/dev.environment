#!/bin/bash

# Set the namespace to the first argument provided, or default to "argocd"
NAMESPACE=${1:-argocd}

echo "=== Argo CD Admin Password Updater ==="

# 1. Check for required tools
if ! command -v htpasswd &>/dev/null; then
 echo "Error: 'htpasswd' is required to generate the bcrypt hash."
 echo "-> On Ubuntu/Debian run: sudo apt install apache2-utils"
 echo "-> On RHEL/CentOS run: sudo yum install httpd-tools"
 exit 1
fi

if ! command -v kubectl &>/dev/null; then
 echo "Error: 'kubectl' is required."
 exit 1
fi

# 2. Prompt for the new password securely
read -s -p "Enter NEW Argo CD admin password: " NEW_PASSWORD
echo
read -s -p "Confirm NEW password: " NEW_PASSWORD_CONFIRM
echo

if [ "$NEW_PASSWORD" != "$NEW_PASSWORD_CONFIRM" ]; then
 echo "Error: Passwords do not match."
 exit 1
fi

if [ -z "$NEW_PASSWORD" ]; then
 echo "Error: Password cannot be empty."
 exit 1
fi

echo "Generating bcrypt hash..."

# 3. Hash the password using bcrypt (Cost of 10 is standard for Argo CD)
HASH=$(htpasswd -nbB -C 10 "" "$NEW_PASSWORD" | cut -d: -f2)

# 4. Base64 encode the hash and the current UTC timestamp (required by Argo CD)
B64_HASH=$(echo -n "$HASH" | base64 | tr -d '\n')
B64_MTIME=$(date -u +'%Y-%m-%dT%H:%M:%SZ' | base64 | tr -d '\n')

echo "Patching 'argocd-secret' in namespace '$NAMESPACE'..."

# 5. Patch the Kubernetes secret using a strategic merge patch
kubectl patch secret argocd-secret -n "$NAMESPACE" \
 -p="{\"data\": {\"admin.password\": \"$B64_HASH\", \"admin.passwordMtime\": \"$B64_MTIME\"}}"

# 6. Automatically restart the server and check status
if [ $? -eq 0 ]; then
 echo "Successfully updated the secret."
 echo "Restarting the argocd-server deployment to apply the new password..."

 kubectl rollout restart deployment/argocd-server -n "$NAMESPACE"

 if [ $? -eq 0 ]; then
  echo "Waiting for the new server pods to become ready..."
  kubectl rollout status deployment/argocd-server -n "$NAMESPACE"

  echo "================================================="
  echo "Success! The admin password is updated and ready."
  echo "================================================="
 else
  echo "Warning: Secret was patched, but the deployment failed to restart automatically."
  echo "You may need to run: kubectl rollout restart deploy/argocd-server -n $NAMESPACE"
 fi
else
 echo "Error: Failed to patch the secret."
fi
