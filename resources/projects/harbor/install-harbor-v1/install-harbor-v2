#!/usr/bin/env bash
# =============================================================================
#  install-harbor-minikube.sh
#  Installs Harbor in minikube and wires it into the ArgoCD + GitLab stack.
#
#  What this script does:
#    1.  Preflight checks
#    2.  Gather cluster values (minikube IP, existing service ports)
#    3.  Add / update the Harbor Helm repo
#    4.  Install Harbor via Helm (HTTP, nginx ingress, nip.io, no TLS)
#    5.  Wait for all Harbor pods to be Ready
#    6.  Configure minikube containerd to trust Harbor as an insecure registry
#    7.  Create a Harbor project for the stack
#    8.  Create a Harbor robot account (push + pull) for GitLab / K8s use
#    9.  Create Kubernetes imagePullSecrets in every relevant namespace
#   10.  Patch ArgoCD to use the Harbor robot credentials for private images
#   11.  Summary
#
#  Prerequisites: ArgoCD + GitLab already installed via their scripts.
#  No external services, accounts, or internet access needed beyond the
#  initial Helm chart / image pulls (all images are cached after first run).
# =============================================================================
set -euo pipefail

# ── Colours ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'; GREEN='\033[0;32m'; YELLOW='\033[1;33m'
CYAN='\033[0;36m'; BOLD='\033[1m'; RESET='\033[0m'

log()     { echo -e "${CYAN}${BOLD}[INFO]${RESET}  $*"; }
success() { echo -e "${GREEN}${BOLD}[OK]${RESET}    $*"; }
warn()    { echo -e "${YELLOW}${BOLD}[WARN]${RESET}  $*"; }
error()   { echo -e "${RED}${BOLD}[ERROR]${RESET} $*" >&2; exit 1; }
banner()  {
  echo -e "\n${BOLD}${CYAN}══════════════════════════════════════════════════${RESET}"
  echo -e "${BOLD}${CYAN}  $*${RESET}"
  echo -e "${BOLD}${CYAN}══════════════════════════════════════════════════${RESET}\n"
}

# ── Config (override via env vars) ────────────────────────────────────────────
HARBOR_NAMESPACE="${HARBOR_NAMESPACE:-harbor}"
ARGOCD_NAMESPACE="${ARGOCD_NAMESPACE:-argocd}"
GITLAB_NAMESPACE="${GITLAB_NAMESPACE:-gitlab}"
APP_NAMESPACE="${APP_NAMESPACE:-guestbook}"      # namespace where app pods run
HARBOR_ADMIN_PASS="${HARBOR_ADMIN_PASS:-Harbor12345}"
HARBOR_PROJECT="${HARBOR_PROJECT:-stack}"        # Harbor project for the stack
ROBOT_NAME="${ROBOT_NAME:-argocd-stack}"         # robot account name
WAIT_TIMEOUT="${WAIT_TIMEOUT:-300s}"

# =============================================================================
#  Helper: wait for a URL to return an expected HTTP status
# =============================================================================
wait_for_http() {
  local url="$1" expected="${2:-200}" retries="${3:-30}" delay="${4:-10}"
  log "Waiting for ${url} to return HTTP ${expected}..."
  local i=1
  while [[ $i -le $retries ]]; do
    local status
    status=$(curl -s -o /dev/null -w "%{http_code}" --max-time 5 "${url}" 2>/dev/null || true)
    if [[ "${status}" == "${expected}" ]]; then
      success "${url} responded with HTTP ${status}."
      return 0
    fi
    printf "\r${CYAN}⠋${RESET}  Attempt ${i}/${retries} — got HTTP ${status}, expecting ${expected}..."
    sleep "${delay}"
    i=$((i + 1))
  done
  echo ""
  error "Timed out waiting for ${url} to return HTTP ${expected}."
}

# =============================================================================
#  Helper: configure minikube containerd to trust an insecure HTTP registry
#
#  Containerd (v1.5+) resolves registry config from a per-host directory at
#  /etc/containerd/certs.d/<registry-host>/hosts.toml.
#  minikube 1.28+ already sets config_path to that directory in config.toml.
#  For older versions we patch config.toml and restart the containerd service
#  (no VM restart required).
# =============================================================================
configure_insecure_registry() {
  local registry="$1"   # e.g.  harbor.192.168.49.2.nip.io
  local registry_url="http://${registry}"

  log "Configuring minikube containerd to trust ${registry} (insecure HTTP)..."

  # ── 1. Create hosts.toml inside the minikube VM ───────────────────────────
  minikube ssh "sudo mkdir -p /etc/containerd/certs.d/${registry}"

  # Use printf so we avoid heredoc quoting issues across the ssh boundary
  minikube ssh "printf '[server]\nurl = \"${registry_url}\"\n\n[host.\"${registry_url}\"]\n  capabilities = [\"pull\", \"resolve\", \"push\"]\n  skip_verify = true\n  plain-http = true\n' \
    | sudo tee /etc/containerd/certs.d/${registry}/hosts.toml > /dev/null"

  success "hosts.toml written for ${registry}."

  # ── 2. Ensure containerd config.toml references the certs.d path ─────────
  local has_config_path
  has_config_path=$(minikube ssh "grep -c 'config_path' /etc/containerd/config.toml 2>/dev/null || echo 0" | tr -d '[:space:]')

  if [[ "${has_config_path}" == "0" ]]; then
    warn "containerd config_path not set — patching /etc/containerd/config.toml..."

    # Insert config_path under the [registry] section.
    # python3 is present in all minikube node images and handles multi-line
    # edits more reliably than sed on this particular config format.
    minikube ssh "sudo python3 -c \"
import re, sys
with open('/etc/containerd/config.toml', 'r') as f:
    content = f.read()
section = '[plugins.\\\"io.containerd.grpc.v1.cri\\\".registry]'
insert  = '    config_path = \\\"/etc/containerd/certs.d\\\"'
if section in content and 'config_path' not in content:
    content = content.replace(section, section + '\n' + insert)
with open('/etc/containerd/config.toml', 'w') as f:
    f.write(content)
print('patched')
\""

    log "Restarting containerd inside minikube (no VM restart needed)..."
    minikube ssh "sudo systemctl restart containerd"
    sleep 6
    success "containerd restarted with registry config_path enabled."
  else
    # config_path already set — just restart containerd to pick up the new hosts.toml
    log "config_path already present. Reloading containerd to pick up hosts.toml..."
    minikube ssh "sudo systemctl restart containerd"
    sleep 4
    success "containerd reloaded."
  fi

  # ── 3. Smoke-test: confirm containerd can reach the registry ─────────────
  log "Verifying containerd can resolve the registry..."
  minikube ssh "curl -sf ${registry_url}/api/v2.0/ping > /dev/null 2>&1" \
    && success "containerd node can reach Harbor API." \
    || warn "Node connectivity check failed — registry may not be fully up yet."
}

# =============================================================================
#  Helper: create (or idempotently re-create) a Kubernetes docker-registry secret
# =============================================================================
create_pull_secret() {
  local namespace="$1"
  local secret_name="$2"
  local registry="$3"
  local username="$4"
  local password="$5"

  kubectl create namespace "${namespace}" &>/dev/null || true

  # Delete existing secret so we can recreate with fresh credentials
  kubectl delete secret "${secret_name}" -n "${namespace}" &>/dev/null || true

  kubectl create secret docker-registry "${secret_name}" \
    --namespace="${namespace}" \
    --docker-server="${registry}" \
    --docker-username="${username}" \
    --docker-password="${password}" \
    --docker-email="argocd-stack@example.com"

  success "imagePullSecret '${secret_name}' created in namespace '${namespace}'."
}

# =============================================================================
#  STEP 0 — Preflight checks
# =============================================================================
banner "Step 0 · Preflight checks"

for bin in kubectl minikube helm curl jq; do
  command -v "${bin}" &>/dev/null \
    || error "'${bin}' not found in PATH. Please install it first."
  success "${bin} found."
done

log "Verifying Minikube is running..."
minikube status --format='{{.Host}}' 2>/dev/null | grep -q "Running" \
  || error "Minikube is not running. Start it with: minikube start"
success "Minikube is up."

log "Verifying ArgoCD is installed..."
kubectl get deployment argocd-server -n "${ARGOCD_NAMESPACE}" &>/dev/null \
  || error "ArgoCD not found in namespace '${ARGOCD_NAMESPACE}'. Run install-argocd-minikube.sh first."
success "ArgoCD is present."

log "Verifying GitLab is installed..."
kubectl get deployment gitlab-webservice-default -n "${GITLAB_NAMESPACE}" &>/dev/null \
  || error "GitLab not found in namespace '${GITLAB_NAMESPACE}'. Run the GitLab install script first."
success "GitLab is present."

log "Verifying nginx ingress addon is enabled..."
minikube addons list | grep -E "ingress\s+\|\s+enabled" &>/dev/null \
  || error "nginx ingress addon not enabled. Run: minikube addons enable ingress"
success "nginx ingress is enabled."

# =============================================================================
#  STEP 1 — Gather cluster values
# =============================================================================
banner "Step 1 · Gather cluster values"

MINIKUBE_IP=$(minikube ip)
HARBOR_HOST="harbor.${MINIKUBE_IP}.nip.io"
HARBOR_URL="http://${HARBOR_HOST}"

success "Minikube IP    : ${MINIKUBE_IP}"
success "Harbor host    : ${HARBOR_HOST}"
success "Harbor URL     : ${HARBOR_URL}"

# =============================================================================
#  STEP 2 — Harbor Helm repo
# =============================================================================
banner "Step 2 · Harbor Helm repo"

if helm repo list 2>/dev/null | grep -q "^harbor"; then
  warn "Harbor Helm repo already added — updating..."
  helm repo update harbor
else
  log "Adding Harbor Helm repo..."
  helm repo add harbor https://helm.goharbor.io
  helm repo update harbor
fi
success "Harbor Helm repo ready."

# =============================================================================
#  STEP 3 — Install Harbor via Helm
# =============================================================================
banner "Step 3 · Install Harbor (namespace: ${HARBOR_NAMESPACE})"

kubectl create namespace "${HARBOR_NAMESPACE}" &>/dev/null || true

log "Running helm upgrade --install harbor..."
helm upgrade --install harbor harbor/harbor \
  --namespace "${HARBOR_NAMESPACE}" \
  --timeout "${WAIT_TIMEOUT}" \
  --set expose.type=ingress \
  --set "expose.ingress.hosts.core=${HARBOR_HOST}" \
  --set expose.ingress.className=nginx \
  --set expose.tls.enabled=false \
  --set "externalURL=${HARBOR_URL}" \
  --set "harborAdminPassword=${HARBOR_ADMIN_PASS}" \
  --set trivy.enabled=false \
  --set notary.enabled=false \
  --set chartmuseum.enabled=false \
  --set persistence.enabled=true

success "Helm chart applied."

# =============================================================================
#  STEP 4 — Wait for Harbor pods
# =============================================================================
banner "Step 4 · Wait for Harbor pods to become Ready (timeout: ${WAIT_TIMEOUT})"

HARBOR_DEPLOYMENTS=(
  harbor-core
  harbor-jobservice
  harbor-portal
  harbor-registry
)

for deploy in "${HARBOR_DEPLOYMENTS[@]}"; do
  if kubectl get deployment "${deploy}" -n "${HARBOR_NAMESPACE}" &>/dev/null; then
    log "Waiting for deployment/${deploy}..."
    kubectl rollout status deployment/"${deploy}" \
      -n "${HARBOR_NAMESPACE}" --timeout="${WAIT_TIMEOUT}"
    success "${deploy} is Ready."
  else
    warn "${deploy} not found — skipping (may not exist in this chart version)."
  fi
done

# =============================================================================
#  STEP 5 — Wait for Harbor API to respond
# =============================================================================
banner "Step 5 · Wait for Harbor API"

wait_for_http "${HARBOR_URL}/api/v2.0/ping" "200" 30 10

# =============================================================================
#  STEP 6 — Configure minikube containerd insecure registry
# =============================================================================
banner "Step 6 · Configure minikube containerd insecure registry"

configure_insecure_registry "${HARBOR_HOST}"

# =============================================================================
#  STEP 7 — Create Harbor project
# =============================================================================
banner "Step 7 · Create Harbor project '${HARBOR_PROJECT}'"

log "Checking if project '${HARBOR_PROJECT}' already exists..."
PROJECT_EXISTS=$(curl -s -o /dev/null -w "%{http_code}" \
  -u "admin:${HARBOR_ADMIN_PASS}" \
  "${HARBOR_URL}/api/v2.0/projects/${HARBOR_PROJECT}")

if [[ "${PROJECT_EXISTS}" == "200" ]]; then
  warn "Project '${HARBOR_PROJECT}' already exists — skipping creation."
else
  log "Creating project '${HARBOR_PROJECT}'..."
  curl -s --fail --request POST \
    "${HARBOR_URL}/api/v2.0/projects" \
    -u "admin:${HARBOR_ADMIN_PASS}" \
    -H "Content-Type: application/json" \
    -d "{
      \"project_name\": \"${HARBOR_PROJECT}\",
      \"public\": false,
      \"metadata\": {\"public\": \"false\"}
    }" &>/dev/null
  success "Project '${HARBOR_PROJECT}' created."
fi

# =============================================================================
#  STEP 8 — Create Harbor robot account
# =============================================================================
banner "Step 8 · Create Harbor robot account '${ROBOT_NAME}'"

log "Creating system-level robot account with access to project '${HARBOR_PROJECT}'..."

# Revoke existing robot with the same name first (idempotent)
EXISTING_ROBOT_ID=$(curl -s \
  -u "admin:${HARBOR_ADMIN_PASS}" \
  "${HARBOR_URL}/api/v2.0/robots?page_size=100" \
  | jq -r --arg name "robot\$${ROBOT_NAME}" \
    '.[] | select(.name == $name) | .id // empty' | head -1)

if [[ -n "${EXISTING_ROBOT_ID}" ]]; then
  warn "Revoking existing robot (id=${EXISTING_ROBOT_ID})..."
  curl -s --request DELETE \
    -u "admin:${HARBOR_ADMIN_PASS}" \
    "${HARBOR_URL}/api/v2.0/robots/${EXISTING_ROBOT_ID}" &>/dev/null
fi

ROBOT_RESPONSE=$(curl -s --fail --request POST \
  "${HARBOR_URL}/api/v2.0/robots" \
  -u "admin:${HARBOR_ADMIN_PASS}" \
  -H "Content-Type: application/json" \
  -d "{
    \"name\": \"${ROBOT_NAME}\",
    \"level\": \"system\",
    \"duration\": -1,
    \"description\": \"ArgoCD/GitLab stack robot — push and pull\",
    \"permissions\": [
      {
        \"kind\": \"project\",
        \"namespace\": \"${HARBOR_PROJECT}\",
        \"access\": [
          {\"resource\": \"repository\", \"action\": \"push\"},
          {\"resource\": \"repository\", \"action\": \"pull\"},
          {\"resource\": \"artifact\",   \"action\": \"read\"},
          {\"resource\": \"tag\",        \"action\": \"create\"},
          {\"resource\": \"tag\",        \"action\": \"delete\"}
        ]
      }
    ]
  }")

ROBOT_USERNAME=$(echo "${ROBOT_RESPONSE}" | jq -r '.name // empty')
ROBOT_SECRET=$(echo   "${ROBOT_RESPONSE}" | jq -r '.secret // empty')

[[ -n "${ROBOT_USERNAME}" && -n "${ROBOT_SECRET}" ]] \
  || error "Failed to create robot account. Response: ${ROBOT_RESPONSE}"

success "Robot account   : ${ROBOT_USERNAME}"
success "Robot secret    : ${ROBOT_SECRET}"

# =============================================================================
#  STEP 9 — Create Kubernetes imagePullSecrets in every relevant namespace
# =============================================================================
banner "Step 9 · Create Kubernetes imagePullSecrets"

PULL_SECRET_NAME="harbor-pull-secret"

for ns in "${APP_NAMESPACE}" "${ARGOCD_NAMESPACE}" "${GITLAB_NAMESPACE}" default; do
  create_pull_secret "${ns}" "${PULL_SECRET_NAME}" \
    "${HARBOR_HOST}" "${ROBOT_USERNAME}" "${ROBOT_SECRET}"
done

# =============================================================================
#  STEP 10 — Patch ArgoCD to use Harbor pull secret for managed apps
# =============================================================================
banner "Step 10 · Patch ArgoCD for Harbor image pulls"

# ArgoCD's application controller and repo-server don't pull images directly,
# but any Application it deploys to a namespace needs the secret available.
# We patch the default service account in the app namespace to auto-mount it,
# so every pod gets it without explicit spec changes.

log "Patching default service account in '${APP_NAMESPACE}' to auto-use the pull secret..."
kubectl patch serviceaccount default \
  -n "${APP_NAMESPACE}" \
  --type=json \
  -p "[{\"op\":\"add\",\"path\":\"/imagePullSecrets\",\"value\":[{\"name\":\"${PULL_SECRET_NAME}\"}]}]" \
  &>/dev/null || \
kubectl patch serviceaccount default \
  -n "${APP_NAMESPACE}" \
  --type=merge \
  -p "{\"imagePullSecrets\":[{\"name\":\"${PULL_SECRET_NAME}\"}]}"

success "Default service account in '${APP_NAMESPACE}' patched."

# Store Harbor credentials as an ArgoCD repo credential template so ArgoCD's
# image updater (if installed later) can authenticate to Harbor automatically.
if command -v argocd &>/dev/null; then
  ARGOCD_NODE_PORT=$(kubectl get svc argocd-server \
    -n "${ARGOCD_NAMESPACE}" \
    -o jsonpath='{.spec.ports[?(@.port==443)].nodePort}' 2>/dev/null || true)

  if [[ -n "${ARGOCD_NODE_PORT}" ]]; then
    ARGOCD_PASS=$(kubectl get secret argocd-initial-admin-secret \
      -n "${ARGOCD_NAMESPACE}" \
      -o jsonpath='{.data.password}' | base64 --decode)

    log "Logging in to ArgoCD CLI..."
    argocd login "${MINIKUBE_IP}:${ARGOCD_NODE_PORT}" \
      --username admin \
      --password "${ARGOCD_PASS}" \
      --insecure --grpc-web &>/dev/null \
      && success "ArgoCD CLI logged in." \
      || warn "ArgoCD CLI login failed (non-fatal — credentials stored in secret only)."
  fi
fi

# =============================================================================
#  Summary
# =============================================================================
banner "🎉  Harbor Installation Complete!"

echo -e "  ${BOLD}Harbor URL:${RESET}            ${CYAN}${HARBOR_URL}${RESET}"
echo -e "  ${BOLD}Harbor admin user:${RESET}     admin"
echo -e "  ${BOLD}Harbor admin pass:${RESET}     ${YELLOW}${HARBOR_ADMIN_PASS}${RESET}"
echo -e "  ${BOLD}Harbor project:${RESET}        ${HARBOR_PROJECT}"
echo ""
echo -e "  ${BOLD}Robot account:${RESET}         ${ROBOT_USERNAME}"
echo -e "  ${BOLD}Robot secret:${RESET}          ${YELLOW}${ROBOT_SECRET}${RESET}"
echo ""
echo -e "  ${BOLD}imagePullSecret name:${RESET}  ${PULL_SECRET_NAME}"
echo -e "  ${BOLD}Secret in namespaces:${RESET}  ${APP_NAMESPACE}, ${ARGOCD_NAMESPACE}, ${GITLAB_NAMESPACE}, default"
echo ""
echo -e "  ${BOLD}Push an image to Harbor:${RESET}"
echo -e "  ${CYAN}docker login ${HARBOR_HOST} -u '${ROBOT_USERNAME}' -p '${ROBOT_SECRET}'${RESET}"
echo -e "  ${CYAN}docker tag  <image> ${HARBOR_HOST}/${HARBOR_PROJECT}/<image>:<tag>${RESET}"
echo -e "  ${CYAN}docker push        ${HARBOR_HOST}/${HARBOR_PROJECT}/<image>:<tag>${RESET}"
echo ""
echo -e "  ${BOLD}Use in a Kubernetes manifest:${RESET}"
echo -e "  ${CYAN}image: ${HARBOR_HOST}/${HARBOR_PROJECT}/<image>:<tag>${RESET}"
echo -e "  ${CYAN}imagePullSecrets:${RESET}"
echo -e "  ${CYAN}  - name: ${PULL_SECRET_NAME}${RESET}"
echo ""
echo -e "  ${BOLD}Stack URLs:${RESET}"
echo -e "  GitLab  → ${CYAN}http://gitlab.${MINIKUBE_IP}.nip.io${RESET}"
echo -e "  ArgoCD  → ${CYAN}https://${MINIKUBE_IP}:${ARGOCD_NODE_PORT:-<run script again for port>}${RESET}"
echo -e "  Harbor  → ${CYAN}${HARBOR_URL}${RESET}"
echo ""
