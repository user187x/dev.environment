#!/bin/bash

set -euo pipefail

NAMESPACE="${CODER_NAMESPACE:-coder}"
DEPLOYMENT="${CODER_DEPLOYMENT:-coder}"

USERNAME="${1:-admin}"
PASSWORD="${2:-${CODER_PASSWORD:-ChangeIt1}}"

# --- sanity checks --------------------------------------------------------

read -r -p "Enter username (default 'admin' press enter) : " USERNAME
echo "Username : $USERNAME"

read -s "Enter password (default 'ChangeIt1 press enter) : " PASSWORD
echo "Password : **********"

echo "Searching for deployment '$DEPLOYMENT' in namespace '$NAMESPACE'..."

if ! kubectl get deployment "$DEPLOYMENT" -n "$NAMESPACE" >/dev/null 2>&1; then
 echo "Deployment '$DEPLOYMENT' not found in namespace '$NAMESPACE'." >&2
 exit 1
fi

# --- invoke reset --------------------------------------------------------

echo "Resetting password for Coder user '$USERNAME'..."

set +e
OUTPUT=$(printf '%s\n%s\n' "$PASSWORD" "$PASSWORD" |
 kubectl exec -i -n "$NAMESPACE" "deployment/$DEPLOYMENT" \
  -- coder reset-password "$USERNAME" 2>&1)
RC=$?
set -e

# --- interpret results -------------------------------------------------

SUCCESS_MSG="password.*(reset|updated|changed|successfully)"

if [[ $RC -eq 0 ]] && echo "$OUTPUT" |
 grep -Eqi "$SUCCESS_MSG"; then
 echo "Password reset successful"
else
 echo "Password reset failed"
 exit 1
fi
