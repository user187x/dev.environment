#!/usr/bin/env bash

set -euo pipefail

# ─── Colour helpers ──────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

info() { echo -e "${CYAN}[INFO]${RESET}  $*"; }
success() { echo -e "${GREEN}[OK]${RESET}    $*"; }
warn() { echo -e "${YELLOW}[WARN]${RESET}  $*"; }
error() {
 echo -e "${RED}[ERROR]${RESET} $*" >&2
 exit 1
}
banner() {
 echo -e "\n${BOLD}${CYAN}══════════════════════════════════════════${RESET}"
 echo -e "${BOLD}${CYAN}  $*${RESET}"
 echo -e "${BOLD}${CYAN}══════════════════════════════════════════${RESET}\n"
}

# ─── Configuration (override via environment variables) ──────────────────────
NAMESPACE="${NAMESPACE:-open-webui}"
RELEASE="${RELEASE:-open-webui}"
INGRESS_HOST="${INGRESS_HOST:-open-webui.minikube.local}"
HELM_REPO_NAME="open-webui"
HELM_REPO_URL="https://helm.openwebui.com/"
CHART="${HELM_REPO_NAME}/open-webui"
WAIT_TIMEOUT="${WAIT_TIMEOUT:-600s}" # max time waiting for pods
VALUES_FILE="/tmp/open-webui-minikube-values.yaml"

# ─── Step 0 : Prerequisites check ────────────────────────────────────────────
banner "Step 0 — Checking Prerequisites"

for cmd in minikube helm kubectl; do
 if command -v "$cmd" &>/dev/null; then
  success "$cmd found: $(command -v "$cmd")"
 else
  error "$cmd is not installed or not in PATH. Please install it first."
 fi
done

# ─── Step 1 : Verify Minikube is running ─────────────────────────────────────
banner "Step 1 — Verifying Minikube"

MINIKUBE_STATUS=$(minikube status --format='{{.Host}}' 2>/dev/null || echo "Stopped")
if [[ "$MINIKUBE_STATUS" != "Running" ]]; then
 error "Minikube is not running (status: ${MINIKUBE_STATUS}). Start it with:\n  minikube start --cpus=4 --memory=6g --driver=docker"
fi
success "Minikube is running."

# ─── Step 2 : Verify Ingress addon is enabled ────────────────────────────────
banner "Step 2 — Verifying Ingress Addon"

if minikube addons list | grep -E "ingress\s+\|\s+enabled" &>/dev/null; then
 success "Ingress addon is already enabled."
else
 warn "Ingress addon appears disabled — attempting to enable it now..."
 minikube addons enable ingress
 info "Waiting 30 s for the ingress controller to become ready..."
 sleep 30

 # Confirm the ingress controller pod is up
 kubectl wait --namespace ingress-nginx \
  --for=condition=ready pod \
  --selector=app.kubernetes.io/component=controller \
  --timeout=120s &&
  success "Ingress controller is ready." ||
  error "Ingress controller did not become ready in time."
fi

# ─── Step 3 : Get Minikube IP ─────────────────────────────────────────────────
banner "Step 3 — Getting Minikube IP"

MINIKUBE_IP=$(minikube ip)
info "Minikube IP: ${MINIKUBE_IP}"
success "Will configure Ingress host '${INGRESS_HOST}' → ${MINIKUBE_IP}"

# ─── Step 4 : Add / update the Helm repository ───────────────────────────────
banner "Step 4 — Helm Repository"

if helm repo list 2>/dev/null | grep -q "^${HELM_REPO_NAME}"; then
 info "Helm repo '${HELM_REPO_NAME}' already exists — updating..."
else
 info "Adding Helm repo '${HELM_REPO_NAME}'..."
 helm repo add "${HELM_REPO_NAME}" "${HELM_REPO_URL}"
fi

helm repo update "${HELM_REPO_NAME}"
CHART_VERSION=$(helm search repo "${CHART}" --output json |
 python3 -c "import sys,json; d=json.load(sys.stdin); print(d[0]['version'])" 2>/dev/null ||
 helm search repo "${CHART}" | awk 'NR==2{print $2}')
success "Latest chart version: ${CHART_VERSION}"

# ─── Step 5 : Create namespace ───────────────────────────────────────────────
banner "Step 5 — Kubernetes Namespace"

if kubectl get namespace "${NAMESPACE}" &>/dev/null; then
 info "Namespace '${NAMESPACE}' already exists — skipping."
else
 kubectl create namespace "${NAMESPACE}"
 success "Namespace '${NAMESPACE}' created."
fi

# ─── Step 6 : Write values file ──────────────────────────────────────────────
banner "Step 6 — Writing Minikube Values File"

cat >"${VALUES_FILE}" <<EOF
# ─────────────────────────────────────────────────────────────────────────────
#  Open WebUI — Minikube values
#  Generated by install-open-webui.sh
# ─────────────────────────────────────────────────────────────────────────────

# ── Replica count ─────────────────────────────────────────────────────────────
replicaCount: 1

# ── Open WebUI resources (conservative for local dev) ────────────────────────
resources:
  requests:
    cpu: "250m"
    memory: "512Mi"
  limits:
    cpu: "1000m"
    memory: "1Gi"

# ── Service — ClusterIP is enough; Ingress handles external access ────────────
service:
  type: ClusterIP
  port: 80
  containerPort: 8080

# ── Ingress — uses the minikube nginx ingress addon ──────────────────────────
ingress:
  enabled: true
  class: "nginx"
  annotations:
    nginx.ingress.kubernetes.io/proxy-body-size: "50m"
    nginx.ingress.kubernetes.io/proxy-read-timeout: "3600"
    nginx.ingress.kubernetes.io/proxy-send-timeout: "3600"
  host: "${INGRESS_HOST}"
  tls: false

# ── Persistence ───────────────────────────────────────────────────────────────
persistence:
  enabled: true
  size: "2Gi"

# ── Ollama sub-chart — CPU-only, bundled alongside Open WebUI ─────────────────
ollama:
  enabled: true
  ollama:
    gpu:
      enabled: false
      number: 0
  resources:
    requests:
      cpu: "1000m"
      memory: "2Gi"
    limits:
      cpu: "3000m"
      memory: "4Gi"
  persistentVolume:
    enabled: true
    size: "10Gi"

# ── Pipelines — disabled by default, enable if you need custom pipelines ──────
pipelines:
  enabled: false

# ── Environment tweaks ────────────────────────────────────────────────────────
extraEnvVars:
  - name: WEBUI_AUTH
    value: "true"                 # Set to "false" to skip login (dev only)
  - name: ENABLE_SIGNUP
    value: "true"                 # Allow new user registration on first launch
EOF

success "Values file written to: ${VALUES_FILE}"
info "Preview:"
echo "---"
cat "${VALUES_FILE}"
echo "---"

# ─── Step 7 : Helm install / upgrade ─────────────────────────────────────────
banner "Step 7 — Helm Install / Upgrade"

if helm status "${RELEASE}" --namespace "${NAMESPACE}" &>/dev/null; then
 warn "Release '${RELEASE}' already exists — running helm upgrade..."
 helm upgrade "${RELEASE}" "${CHART}" \
  --namespace "${NAMESPACE}" \
  --values "${VALUES_FILE}" \
  --wait \
  --timeout "${WAIT_TIMEOUT}" \
  --atomic
 success "Helm upgrade completed."
else
 info "Installing '${RELEASE}' from chart '${CHART}' (version ${CHART_VERSION})..."
 helm install "${RELEASE}" "${CHART}" \
  --namespace "${NAMESPACE}" \
  --values "${VALUES_FILE}" \
  --create-namespace \
  --wait \
  --timeout "${WAIT_TIMEOUT}" \
  --atomic
 success "Helm install completed."
fi

# ─── Step 8 : Wait for all pods to be ready ──────────────────────────────────
banner "Step 8 — Waiting for Pods"

info "Waiting for Open WebUI pod(s) to be ready..."
kubectl rollout status deployment/"${RELEASE}" \
 --namespace "${NAMESPACE}" \
 --timeout="${WAIT_TIMEOUT}"
success "Open WebUI deployment is ready."

info "Waiting for Ollama pod(s) to be ready (model downloads may take a while)..."
kubectl rollout status statefulset/"${RELEASE}-ollama" \
 --namespace "${NAMESPACE}" \
 --timeout="${WAIT_TIMEOUT}" ||
 warn "Ollama StatefulSet not found or not ready yet — it may still be initializing."

info "Current pod status in namespace '${NAMESPACE}':"
kubectl get pods --namespace "${NAMESPACE}" -o wide

# ─── Step 9 : /etc/hosts entry ───────────────────────────────────────────────
banner "Step 9 — /etc/hosts Configuration"

HOSTS_ENTRY="${MINIKUBE_IP}  ${INGRESS_HOST}"

if grep -qF "${INGRESS_HOST}" /etc/hosts 2>/dev/null; then
 EXISTING=$(grep -F "${INGRESS_HOST}" /etc/hosts)
 if [[ "${EXISTING}" == "${HOSTS_ENTRY}" ]]; then
  success "/etc/hosts entry already correct: ${HOSTS_ENTRY}"
 else
  warn "Found a different /etc/hosts entry for '${INGRESS_HOST}':"
  echo "  Current : ${EXISTING}"
  echo "  Needed  : ${HOSTS_ENTRY}"
  warn "Please update it manually, or run:"
  echo "  sudo sed -i '' \"/${INGRESS_HOST}/d\" /etc/hosts"
  echo "  echo '${HOSTS_ENTRY}' | sudo tee -a /etc/hosts"
 fi
else
 info "Adding entry to /etc/hosts (requires sudo)..."
 if echo "${HOSTS_ENTRY}" | sudo tee -a /etc/hosts >/dev/null; then
  success "Added: ${HOSTS_ENTRY}"
 else
  warn "Could not write to /etc/hosts automatically."
  warn "Please add the following line manually:"
  echo ""
  echo "  ${HOSTS_ENTRY}"
  echo ""
 fi
fi

# ─── Step 10 : Verify Ingress object ─────────────────────────────────────────
banner "Step 10 — Ingress Object"

info "Ingress resources in namespace '${NAMESPACE}':"
kubectl get ingress --namespace "${NAMESPACE}"

# ─── Step 11 : Smoke test ────────────────────────────────────────────────────
banner "Step 11 — Smoke Test"

info "Waiting up to 30 s for Open WebUI to respond at http://${INGRESS_HOST} ..."
for i in $(seq 1 6); do
 HTTP_CODE=$(curl -o /dev/null -s -w "%{http_code}" \
  --connect-timeout 5 --max-time 10 \
  -H "Host: ${INGRESS_HOST}" \
  "http://${MINIKUBE_IP}/" 2>/dev/null || echo "000")
 if [[ "${HTTP_CODE}" =~ ^(200|301|302|307|308)$ ]]; then
  success "Open WebUI responded with HTTP ${HTTP_CODE}. 🎉"
  break
 fi
 warn "Attempt ${i}/6 — got HTTP ${HTTP_CODE}, retrying in 5 s..."
 sleep 5
done

if [[ "${HTTP_CODE}" == "000" ]] || ! [[ "${HTTP_CODE}" =~ ^(200|301|302|307|308)$ ]]; then
 warn "Smoke test inconclusive (HTTP ${HTTP_CODE}). The service may still be starting."
 warn "Try: curl -v -H 'Host: ${INGRESS_HOST}' http://${MINIKUBE_IP}/"
fi

# ─── Summary ─────────────────────────────────────────────────────────────────
banner "🚀  Deployment Summary"

echo -e "${BOLD}Release      :${RESET} ${RELEASE}"
echo -e "${BOLD}Namespace    :${RESET} ${NAMESPACE}"
echo -e "${BOLD}Chart version:${RESET} ${CHART_VERSION}"
echo -e "${BOLD}Minikube IP  :${RESET} ${MINIKUBE_IP}"
echo -e ""
echo -e "${BOLD}${GREEN}Open WebUI URL:${RESET}  http://${INGRESS_HOST}"
echo -e ""
echo -e "${CYAN}Useful commands:${RESET}"
echo -e "  # Live pod logs"
echo -e "  kubectl logs -f -l app.kubernetes.io/name=open-webui -n ${NAMESPACE}"
echo -e ""
echo -e "  # Ollama pod logs"
echo -e "  kubectl logs -f -l app.kubernetes.io/name=ollama -n ${NAMESPACE}"
echo -e ""
echo -e "  # Pull a model interactively inside Ollama"
echo -e "  kubectl exec -it -n ${NAMESPACE} \$(kubectl get pod -n ${NAMESPACE} -l app.kubernetes.io/name=ollama -o name | head -1) -- ollama pull llama3.2"
echo -e ""
echo -e "  # Helm chart values currently deployed"
echo -e "  helm get values ${RELEASE} -n ${NAMESPACE}"
echo -e ""
echo -e "  # Upgrade with new values"
echo -e "  helm upgrade ${RELEASE} ${CHART} -n ${NAMESPACE} -f ${VALUES_FILE}"
echo -e ""
echo -e "  # Full uninstall"
echo -e "  helm uninstall ${RELEASE} -n ${NAMESPACE} && kubectl delete namespace ${NAMESPACE}"
echo -e ""
success "Done! Open your browser at http://${INGRESS_HOST} and create your admin account."
