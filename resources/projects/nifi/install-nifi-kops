#!/bin/bash
set -euo pipefail

# ==============================================================================
# Global Variables & Configuration
# ==============================================================================
MINIKUBE_MEMORY=8192
MINIKUBE_CPUS=4
MINIKUBE_K8S_VERSION="v1.28.0"

NIFI_NAMESPACE="nifi"
ZK_NAMESPACE="zookeeper"
CM_NAMESPACE="cert-manager"

CM_VERSION="v1.14.4"
NIFIKOP_VERSION="1.14.0"
CRD_FILENAME="nifi-cluster.yaml"

# ==============================================================================
# Utility Methods
# ==============================================================================
log_info() {
 echo -e "\n\033[1;34m[INFO]\033[0m $1"
}

log_success() {
 echo -e "\033[1;32m[SUCCESS]\033[0m $1"
}

log_error() {
 echo -e "\033[1;31m[ERROR]\033[0m $1" >&2
 exit 1
}

check_prerequisites() {
 log_info "Verifying prerequisites..."
 for cmd in minikube kubectl helm; do
  if ! command -v "$cmd" &>/dev/null; then
   log_error "$cmd is not installed. Please install it to proceed."
  fi
 done

 if [[ ! -f "$CRD_FILENAME" ]]; then
  log_error "CRD file '$CRD_FILENAME' not found in the current directory."
 fi
 log_success "All prerequisites met."
}

# ==============================================================================
# Infrastructure Setup Methods
# ==============================================================================
start_minikube() {
 log_info "Checking Minikube status..."
 if minikube status | grep -q "Running"; then
  log_success "Minikube is already running."
 else
  log_info "Starting Minikube (Memory: ${MINIKUBE_MEMORY}MB, CPUs: ${MINIKUBE_CPUS})..."
  minikube start \
   --memory="${MINIKUBE_MEMORY}" \
   --cpus="${MINIKUBE_CPUS}" \
   --kubernetes-version="${MINIKUBE_K8S_VERSION}"
  log_success "Minikube started successfully."
 fi
}

install_cert_manager() {
 log_info "Installing Cert-Manager (Required for NiFiKop webhooks)..."
 kubectl apply -f "https://github.com/cert-manager/cert-manager/releases/download/${CM_VERSION}/cert-manager.yaml"

 log_info "Waiting for Cert-Manager pods to become ready..."
 kubectl wait --for=condition=Ready pods -l app.kubernetes.io/instance=cert-manager -n "$CM_NAMESPACE" --timeout=300s
 log_success "Cert-Manager installed."
}

install_zookeeper() {
 log_info "Installing Bitnami ZooKeeper..."
 kubectl create namespace "$ZK_NAMESPACE" --dry-run=client -o yaml | kubectl apply -f -

 helm repo add bitnami https://charts.bitnami.com/bitnami
 helm repo update

 helm upgrade --install zookeeper bitnami/zookeeper \
  --namespace "$ZK_NAMESPACE" \
  --set replicaCount=1 \
  --set auth.enabled=false \
  --set allowAnonymousLogin=true \
  --wait
 log_success "ZooKeeper installed."
}

# ==============================================================================
# NiFiKop & Cluster Deployment Methods
# ==============================================================================
install_nifikop() {
 log_info "Installing Orange NiFiKop Operator..."
 kubectl create namespace "$NIFI_NAMESPACE" --dry-run=client -o yaml | kubectl apply -f -

 helm upgrade --install nifikop oci://ghcr.io/konpyutaika/helm-charts/nifikop \
  --namespace "$NIFI_NAMESPACE" \
  --version "$NIFIKOP_VERSION" \
  --set image.tag="v${NIFIKOP_VERSION}-release" \
  --set namespaces="{$NIFI_NAMESPACE}" \
  --wait
 log_success "NiFiKop Operator installed."
}

deploy_nifi_cluster() {
 log_info "Applying NiFi Cluster CRDs from $CRD_FILENAME..."
 kubectl apply -f "$CRD_FILENAME"

 log_info "Waiting for NiFi node to spin up (this can take 3-5 minutes depending on your hardware)..."
 # Sleep briefly to allow the operator to register the resource before checking
 sleep 10

 # Wait for the actual statefulset/pods generated by NiFiKop
 kubectl wait --for=condition=Ready pods -l app=nifi -n "$NIFI_NAMESPACE" --timeout=600s || true

 log_success "NiFi Cluster deployment sent to Kubernetes."
}

print_next_steps() {
 log_info "============================================================"
 log_info " INSTALLATION COMPLETE "
 log_info "============================================================"
 echo "To access the Apache NiFi Web UI locally, run the following port-forward command in a new terminal:"
 echo ""
 echo "    kubectl port-forward svc/nifikop-cluster-headless -n $NIFI_NAMESPACE 8443:8443"
 echo ""
 echo "Then, open your browser and navigate to: https://localhost:8443/nifi"
 echo "(Accept the self-signed certificate warning)"
 echo ""
 echo "Login Credentials:"
 echo "Username: admin"
 echo "Password: SuperSecretPassword123!"
 echo "============================================================"
}

# ==============================================================================
# Main Execution Block
# ==============================================================================
main() {
 check_prerequisites
 start_minikube
 install_cert_manager
 install_zookeeper
 install_nifikop
 deploy_nifi_cluster
 print_next_steps
}

main
