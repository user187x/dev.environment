#!/bin/bash

# Ensure whiptail is installed
if ! command -v whiptail &> /dev/null; then
    echo "❌ Error: 'whiptail' could not be found. Please install it."
    exit 1
fi

# 1. Get Namespace (Smart fetch)
if KUBE_NS=$(kubectl get namespaces -o custom-columns=":metadata.name" --no-headers 2>/dev/null); then
    NS_OPTIONS=()
    for ns in $KUBE_NS; do
        NS_OPTIONS+=("$ns" "")
    done

    NAMESPACE=$(whiptail --menu "☸️  Select the Kubernetes Namespace (Up/Down arrows to choose):" 15 78 8 \
        "${NS_OPTIONS[@]}" \
        --title "☸️  Kubernetes Namespace" 3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && exit 0
else
    NAMESPACE=$(whiptail --inputbox "⚠️ Could not fetch namespaces. Enter the Kubernetes Namespace manually:" 8 78 "default" \
        --title "☸️  Kubernetes Namespace" 3>&1 1>&2 2>&3)
    [[ $? -ne 0 ]] && exit 0
fi

[[ -z "$NAMESPACE" ]] && NAMESPACE="default"

# 2. Get Secret Name
SECRET_NAME=$(whiptail --inputbox "📛 Enter the Secret Name:" 8 78 \
    --title "📛 Secret Name" 3>&1 1>&2 2>&3)
[[ $? -ne 0 ]] && exit 0
if [[ -z "$SECRET_NAME" ]]; then
    whiptail --msgbox "❌ Secret name cannot be empty!" 8 78 --title "Error"
    exit 1
fi

# 3 & 4. Loop for Secret Type and Data Entry (Allows going Back)
while true; do
    SECRET_TYPE=$(whiptail --menu "⚙️  Select the type of secret you want to create:" 15 78 4 \
        "literal" "📝 Generic (from-literal key/value pairs)" \
        "file"    "📄 Generic (from-file)" \
        "tls"     "🔐 TLS (requires cert and key files)" \
        --cancel-button "Exit" \
        --title "⚙️  Secret Type" 3>&1 1>&2 2>&3)
    
    # If the user hits "Exit" on the main menu, exit the script completely
    [[ $? -ne 0 ]] && exit 0

    # Reset command arrays in case the user looped back
    declare -a KUBECTL_CMD=(kubectl create secret)
    CMD_STR="kubectl create secret"
    GO_BACK=0

    case "$SECRET_TYPE" in
        literal)
            KUBECTL_CMD+=(generic "$SECRET_NAME" -n "$NAMESPACE")
            CMD_STR="$CMD_STR generic $SECRET_NAME -n $NAMESPACE"
            
            while true; do
                KEY=$(whiptail --inputbox "🔑 Enter Key (Leave blank and press OK when done):" 8 78 \
                    --cancel-button "Back" \
                    --title "📝 from-literal Key" 3>&1 1>&2 2>&3)
                
                # If they press Back here, break the inner loop and trigger the outer loop to reset
                if [[ $? -ne 0 ]]; then
                    GO_BACK=1
                    break
                fi
                
                # If they press OK with an empty key, they are done adding keys
                [[ -z "$KEY" ]] && break 
                
                VAL=$(whiptail --passwordbox "🔒 Enter Value for key '$KEY':" 8 78 \
                    --cancel-button "Back" \
                    --title "📝 from-literal Value" 3>&1 1>&2 2>&3)
                
                # If they press Back on the value, just ask for the key again
                [[ $? -ne 0 ]] && continue 
                
                KUBECTL_CMD+=("--from-literal=$KEY=$VAL")
                CMD_STR="$CMD_STR --from-literal=$KEY='***'"
                
                whiptail --yesno "➕ Add another key-value pair?" 8 78 --title "More?" 3>&1 1>&2 2>&3
                [[ $? -ne 0 ]] && break
            done
            ;;
        file)
            KUBECTL_CMD+=(generic "$SECRET_NAME" -n "$NAMESPACE")
            CMD_STR="$CMD_STR generic $SECRET_NAME -n $NAMESPACE"
            
            while true; do
                FILE_PATH=$(whiptail --inputbox "📂 Enter the full path to the file:" 8 78 \
                    --cancel-button "Back" \
                    --title "📄 from-file Path" 3>&1 1>&2 2>&3)
                
                if [[ $? -ne 0 ]]; then
                    GO_BACK=1
                    break
                fi
                
                # Validate file exists
                if [[ -f "$FILE_PATH" ]]; then
                    KUBECTL_CMD+=("--from-file=$FILE_PATH")
                    CMD_STR="$CMD_STR --from-file=$FILE_PATH"
                    break
                else
                    whiptail --msgbox "❌ File not found:\n$FILE_PATH\n\nPlease enter a valid file path." 10 78 --title "File Error"
                fi
            done
            ;;
        tls)
            KUBECTL_CMD+=(tls "$SECRET_NAME" -n "$NAMESPACE")
            CMD_STR="$CMD_STR tls $SECRET_NAME -n $NAMESPACE"
            
            while true; do
                CERT_PATH=$(whiptail --inputbox "📜 Enter the full path to the TLS Certificate (.crt/.pem):" 8 78 \
                    --cancel-button "Back" \
                    --title "🔐 TLS Certificate" 3>&1 1>&2 2>&3)
                
                if [[ $? -ne 0 ]]; then
                    GO_BACK=1
                    break
                fi

                # Validate certificate exists
                if [[ -f "$CERT_PATH" ]]; then
                    break # Valid cert, break this loop to move to the key
                else
                    whiptail --msgbox "❌ File not found:\n$CERT_PATH\n\nPlease enter a valid file path." 10 78 --title "File Error"
                fi
            done
            
            # Only ask for the key if we didn't hit "Back" on the cert prompt
            if [[ $GO_BACK -eq 0 ]]; then
                while true; do
                    KEY_PATH=$(whiptail --inputbox "🗝️  Enter the full path to the TLS Key (.key):" 8 78 \
                        --cancel-button "Back" \
                        --title "🔐 TLS Key" 3>&1 1>&2 2>&3)
                    
                    if [[ $? -ne 0 ]]; then
                        GO_BACK=1
                        break
                    fi

                    # Validate key exists
                    if [[ -f "$KEY_PATH" ]]; then
                        KUBECTL_CMD+=("--cert=$CERT_PATH" "--key=$KEY_PATH")
                        CMD_STR="$CMD_STR --cert=$CERT_PATH --key=$KEY_PATH"
                        break
                    else
                        whiptail --msgbox "❌ File not found:\n$KEY_PATH\n\nPlease enter a valid file path." 10 78 --title "File Error"
                    fi
                done
            fi
            ;;
    esac

    # If the GO_BACK flag was not tripped, we successfully gathered the data. Break the outer loop.
    [[ $GO_BACK -eq 0 ]] && break
done

# 5. Confirm and Execute
whiptail --yesno "✅ Ready to execute the following command?\n\n$CMD_STR" 12 78 \
    --title "✅ Confirm Execution" 3>&1 1>&2 2>&3

if [[ $? -eq 0 ]]; then
    clear
    echo "🚀 Executing command..."
    "${KUBECTL_CMD[@]}"
else
    clear
    echo "🛑 Operation cancelled by user at final confirmation."
fi
