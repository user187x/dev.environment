#!/bin/bash
set -e

echo "==> Checking for git..."
if ! command -v git &>/dev/null; then
 echo "Git not found. Installing git..."
 sudo apt-get update
 sudo apt-get install -y git
fi

echo "==> Creating a temporary directory..."
TMP_DIR=$(mktemp -d)
cd "$TMP_DIR"

echo "==> Cloning the Borealis-cursors repository..."
git clone https://github.com/alvatip/Borealis-cursors.git

echo "==> Running the official system-wide installer..."
cd Borealis-cursors
# Running the developer's script with sudo for system-wide access
sudo ./install.sh

echo "==> Setting Borealis-cursors as your active theme..."
gsettings set org.gnome.desktop.interface cursor-theme "Borealis-cursors"

echo "==> Cleaning up temporary files..."
cd ~
rm -rf "$TMP_DIR"

echo "==> Success! The theme is installed system-wide."
