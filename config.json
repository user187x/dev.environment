{
  "resource-path" : "/home/xxx/dev.environment",
  "local-config-path" : "$XDG_CONFIG_PATH",
  "entries": [
    {
		"name": "vim",
		"description": "Install VIM & Plugin resources",
        "source": "@resource-path/vim",
		"destination" : "@local-config-path/vim",
		"dependencies" : [
			{
				"ordinal": 1,
				"name": "network",
				"description": "Network Acesss",
				"command": "",
				"readiness": ["sh", "-c", ""]
			},
			{
				"ordinal": 2,
				"name": "apt install",
				"command": "sudo apt install vim",
				"readiness": ["sh", "-c", "command -v tmux"]
			}
		],
		"instructions" : [
			{
			  "ordinal" : 1,
              "description": "Ensure TMUX isn't running",
			  "command" : ["sh", "-c", ""],
			  "readiness" : ["sh", "-c", ""]
			}
		]
	},
    {}
  ]
}
