#!/bin/bash
# Exit immediately if a command exits with a non-zero status.
set -e 

echo "==================================================="
echo " ☸️ Kubernetes Secret Provisioner for Local PKI"
echo "==================================================="

# 1. Gather inputs
read -p "Enter the base domain name used previously (e.g., myapp.local): " DOMAIN

if [ -z "$DOMAIN" ]; then
    echo "Error: Domain name cannot be empty."
    exit 1
fi

CERT_DIR="certs-${DOMAIN}"

# Verify the directory exists
if [ ! -d "$CERT_DIR" ]; then
    echo "Error: Directory $CERT_DIR does not exist. Please run the PKI generation script first."
    exit 1
fi

read -p "Enter the target Kubernetes namespace (default: default): " NAMESPACE
NAMESPACE=${NAMESPACE:-default}

# Check if kubectl is installed and accessible
if ! command -v kubectl &> /dev/null; then
    echo "Error: kubectl is not installed or not in your PATH."
    exit 1
fi

# Sanitize domain for Kubernetes resource naming (replace dots with dashes)
SAFE_NAME="${DOMAIN//./-}"

echo -e "\nTargeting Namespace: ${NAMESPACE}"

echo -e "\n[1/4] Upserting Server TLS Secret..."
# Creates a kubernetes.io/tls secret for the specific domain
kubectl create secret tls "${SAFE_NAME}-tls" \
    --cert="${CERT_DIR}/server.crt" \
    --key="${CERT_DIR}/server.key" \
    --namespace="${NAMESPACE}" \
    --dry-run=client -o yaml | kubectl apply -f -

echo -e "\n[2/4] Upserting Wildcard TLS Secret..."
# Creates a kubernetes.io/tls secret for the wildcard domain
kubectl create secret tls "${SAFE_NAME}-wildcard-tls" \
    --cert="${CERT_DIR}/server-wildcard.crt" \
    --key="${CERT_DIR}/server-wildcard.key" \
    --namespace="${NAMESPACE}" \
    --dry-run=client -o yaml | kubectl apply -f -

echo -e "\n[3/4] Upserting Certificate Authority (CA) Secret..."
# Creates an Opaque secret containing the CA. Used by Ingress/Mesh for validating client certs (mTLS)
kubectl create secret generic "${SAFE_NAME}-ca" \
    --from-file=ca.crt="${CERT_DIR}/ca-cert.pem" \
    --namespace="${NAMESPACE}" \
    --dry-run=client -o yaml | kubectl apply -f -

echo -e "\n[4/4] Upserting Client TLS Secret..."
# Creates a kubernetes.io/tls secret for the client. Useful if deploying client pods that need to authenticate.
kubectl create secret tls "${SAFE_NAME}-client-tls" \
    --cert="${CERT_DIR}/client.crt" \
    --key="${CERT_DIR}/client.key" \
    --namespace="${NAMESPACE}" \
    --dry-run=client -o yaml | kubectl apply -f -

echo -e "\n==================================================="
echo " ✅ Kubernetes Secrets Successfully Provisioned!"
echo " Use 'kubectl get secrets -n ${NAMESPACE}' to view them."
echo "==================================================="
