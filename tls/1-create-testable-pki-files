#!/bin/bash
set -e

AUTO_MODE=0
DOMAIN="rancher.xxx"

# If not argument passed in
if [[ "$#" -eq 0 ]];
then
 AUTO_MODE=1
fi

echo
echo -e "\e[90m======================="
echo -e " 🔒 TLS PKI Generator"
echo -e "=======================\e[0m"

# 1. Prompt the user for the domain name
if ! ((AUTO_MODE));
then
 read -e -p " (?) Enter the desired Domain [default: $DOMAIN]: " -i "$DOMAIN" DOMAIN
 DOMAIN=${DOMAIN:-rancher.xxx}
 echo "The domain is: $DOMAIN"
fi

# Create an output directory
OUT_DIR="certs"
mkdir -p "$OUT_DIR"

cd "$OUT_DIR"

echo
echo -e "(i) Generating Root Certificate Authority (CA)..."

# Generate CA Private Key
openssl genrsa -out ca.key 4096

# Generate CA Root Certificate
ca_args=(
  -x509
  -new
  -nodes
  -key ca.key
  -sha256
  -days 365
  -out ca-cert.pem
  -subj "/O=XXX Root CA/CN=${DOMAIN} Root CA"
)
openssl req "${ca_args[@]}"

echo
echo -e "(i) Generating Server Certificate (${DOMAIN})..."

# Generate Server Private Key
openssl genrsa -out server.key 4096

# Generate Server Certificate Signing Request (CSR)
server_csr_args=(
  -new
  -key server.key
  -out server.csr
  -subj "/O=XXX Cert/CN=${DOMAIN}"
)
openssl req "${server_csr_args[@]}"

# Create an extension file for Subject Alternative Names (SAN)
cat >server-ext.cnf <<EOF
authorityKeyIdentifier=keyid,issuer
basicConstraints=CA:FALSE
keyUsage = digitalSignature, nonRepudiation, keyEncipherment, dataEncipherment
subjectAltName = @alt_names
[alt_names]
DNS.1 = ${DOMAIN}
EOF

# Generate the Server Certificate
server_cert_args=(
  -req
  -in server.csr
  -CA ca-cert.pem
  -CAkey ca.key
  -CAcreateserial
  -out server.crt
  -days 365
  -sha256
  -extfile server-ext.cnf
)
openssl x509 "${server_cert_args[@]}"

echo
echo -e "(i) Generating Wildcard Server Certificate (*.${DOMAIN})..."

# Generate Wildcard Private Key
openssl genrsa -out server-wildcard.key 4096

# Generate Wildcard CSR
wildcard_csr_args=(
  -new
  -key server-wildcard.key
  -out server-wildcard.csr
  -subj "/O=XXX Wildcard Cert/CN=*.${DOMAIN}"
)
openssl req "${wildcard_csr_args[@]}"

# Create extension file for Wildcard SANs
cat >wildcard-ext.cnf <<EOF
authorityKeyIdentifier=keyid,issuer
basicConstraints=CA:FALSE
keyUsage = digitalSignature, nonRepudiation, keyEncipherment, dataEncipherment
subjectAltName = @alt_names
[alt_names]
DNS.1 = *.${DOMAIN}
DNS.2 = ${DOMAIN}
EOF

# Generate the Wildcard Certificate
wildcard_cert_args=(
  -req
  -in server-wildcard.csr
  -CA ca-cert.pem
  -CAkey ca.key
  -CAcreateserial
  -out server-wildcard.crt
  -days 365
  -sha256
  -extfile wildcard-ext.cnf
)
openssl x509 "${wildcard_cert_args[@]}"

echo
echo -e "(i) Generating Client Certificate (for mTLS)..."

# Generate Client Private Key
openssl genrsa -out client.key 4096

# Generate Client CSR
client_csr_args=(
  -new
  -key client.key
  -out client.csr
  -subj "/O=XXX Client/CN=client.${DOMAIN}"
)
openssl req "${client_csr_args[@]}"

# Generate the Client Certificate
client_cert_args=(
  -req
  -in client.csr
  -CA ca-cert.pem
  -CAkey ca.key
  -CAcreateserial
  -out client.crt
  -days 365
  -sha256
)
openssl x509 "${client_cert_args[@]}"

echo
echo -e "\e[90m(*) Verifying Certificates..."
# Verify the generated certificates against the CA
openssl verify -CAfile ca-cert.pem server.crt server-wildcard.crt client.crt 
echo -e "\e[0m"

echo -e "(i) File Location: \e[92m./${OUT_DIR}/\e[0m"
echo

file_list=(
  *.pem
  *.crt
  *.key
  *.csr
)
ls -l "${file_list[@]}" 

echo
echo -e " ✅ \e[92mPKI Generation Complete!\e[0m"
echo
