#!/bin/bash
# Exit immediately if a command exits with a non-zero status.
set -e

echo "==================================================="
echo " 🚀 Traefik Helm Installer & Ingress Configurator"
echo "==================================================="

# 1. Gather inputs
read -p "Enter the base domain name used previously (e.g., myapp.local): " DOMAIN
if [ -z "$DOMAIN" ]; then
 echo "Error: Domain name cannot be empty."
 exit 1
fi

# Sanitize domain for K8s naming
SAFE_NAME="${DOMAIN//./-}"

read -p "Enter the Kubernetes namespace (default: default): " NAMESPACE
NAMESPACE=${NAMESPACE:-default}

read -p "Enter the target Kubernetes Service name to route traffic to: " TARGET_SVC
if [ -z "$TARGET_SVC" ]; then
 echo "Error: Target service name cannot be empty."
 exit 1
fi

read -p "Enter the target Kubernetes Service port (e.g., 80, 8080): " TARGET_PORT
if [ -z "$TARGET_PORT" ]; then
 echo "Error: Target port cannot be empty."
 exit 1
fi

# 2. Check dependencies
if ! command -v helm &>/dev/null; then
 echo "Error: helm is not installed or not in your PATH."
 exit 1
fi

if ! command -v kubectl &>/dev/null; then
 echo "Error: kubectl is not installed or not in your PATH."
 exit 1
fi

echo -e "\n[1/3] Adding and updating the Traefik Helm repository..."
helm repo add traefik https://helm.traefik.io/traefik
helm repo update

echo -e "\n[2/3] Installing/Upgrading Traefik via Helm in namespace '${NAMESPACE}'..."
# We enable publishedService so the Ingress resource can correctly report the LoadBalancer IP
helm upgrade --install traefik traefik/traefik \
 --namespace="${NAMESPACE}" \
 --create-namespace \
 --set providers.kubernetesIngress.publishedService.enabled=true \
 --wait

echo -e "\n[3/3] Creating TLS Ingress resource for '${DOMAIN}'..."
# This generates and applies a standard Kubernetes Ingress resource
cat <<EOF | kubectl apply -f -
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: ${SAFE_NAME}-ingress
  namespace: ${NAMESPACE}
  annotations:
    # Explicitly tell Traefik to handle this and serve it over TLS
    traefik.ingress.kubernetes.io/router.tls: "true"
spec:
  ingressClassName: traefik
  tls:
  - hosts:
    - ${DOMAIN}
    # This matches the secret we created in the previous script!
    secretName: ${SAFE_NAME}-tls
  rules:
  - host: ${DOMAIN}
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: ${TARGET_SVC}
            port:
              number: ${TARGET_PORT}
EOF

echo -e "\n==================================================="
echo " ✅ Traefik and Ingress successfully deployed!"
echo " Routing traffic from: https://${DOMAIN} -> Service: ${TARGET_SVC}:${TARGET_PORT}"
echo "==================================================="
