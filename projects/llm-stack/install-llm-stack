#!/bin/bash

# --- Configuration ---
NAMESPACE="llm-ops"
DOMAIN="llm.local"
# Top 5 Laptop-Friendly Models
MODELS=(
  "google/gemma-2-2b-it" 
  "microsoft/phi-4-mini" 
  "meta-llama/Llama-3.2-1B-Instruct"
  "Qwen/Qwen2.5-Coder-7B-Instruct"
  "mistralai/Mistral-7B-Instruct-v0.3"
)

echo "🚀 Starting Full Cluster Provisioning..."

# 1. Install Helm (if missing)
if ! command -v helm &> /dev/null; then
    echo "📦 Installing Helm..."
    curl https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
fi

# 2. Add Required Helm Repos
echo "📦 Adding Helm Repositories..."
helm repo add ingress-nginx https://kubernetes.github.io/ingress-nginx
helm repo add litellm https://berriai.github.io/litellm
helm repo update

# 3. Setup Namespace
kubectl create namespace $NAMESPACE --dry-run=client -o yaml | kubectl apply -f -

# 4. Install Nginx Ingress Controller
echo "🌐 Installing Nginx Ingress..."
helm upgrade --install ingress-nginx ingress-nginx \
  --repo https://kubernetes.github.io/ingress-nginx \
  --namespace ingress-nginx --create-namespace \
  --set controller.service.type=LoadBalancer

# 5. Install LMCache (The KV Cache Layer)
echo "🧠 Installing LMCache Operator..."
kubectl apply -f https://raw.githubusercontent.com/LMCache/LMCache/main/kubernetes/operator.yaml

cat <<EOF | kubectl apply -f -
apiVersion: lmcache.ai/v1alpha1
kind: LMCacheEngine
metadata:
  name: lmcache-server
  namespace: $NAMESPACE
spec:
  l1_cache:
    sizeGB: 4 # Small for laptop use
  image:
    repository: lmcache/lmcache-server
    tag: latest
EOF

# 6. Install vLLM (Configured for Low VRAM)
echo "🤖 Deploying vLLM (Gemma-2-2b)..."
cat <<EOF | kubectl apply -f -
apiVersion: apps/v1
kind: Deployment
metadata:
  name: vllm-engine
  namespace: $NAMESPACE
spec:
  replicas: 1
  selector:
    matchLabels:
      app: vllm
  template:
    metadata:
      labels:
        app: vllm
    spec:
      containers:
      - name: vllm-container
        image: vllm/vllm-openai:latest
        args: [
          "--model", "${MODELS[0]}",
          "--gpu-memory-utilization", "0.5",
          "--max-model-len", "2048",
          "--enforce-eager"
        ]
        ports:
        - containerPort: 8000
---
apiVersion: v1
kind: Service
metadata:
  name: vllm-svc
  namespace: $NAMESPACE
spec:
  ports:
  - port: 8000
  selector:
    app: vllm
EOF

# 7. Configure and Install LiteLLM Proxy
echo "⚖️ Deploying LiteLLM Router..."
cat <<EOF > litellm-config.yaml
model_list:
  - model_name: gemma
    litellm_params:
      model: vllm/${MODELS[0]}
      api_base: http://vllm-svc:8000/v1
  - model_name: phi-mini
    litellm_params:
      model: vllm/${MODELS[1]}
      api_base: http://vllm-svc:8000/v1
  - model_name: llama-tiny
    litellm_params:
      model: vllm/${MODELS[2]}
      api_base: http://vllm-svc:8000/v1
  - model_name: qwen-coder
    litellm_params:
      model: vllm/${MODELS[3]}
      api_base: http://vllm-svc:8000/v1
  - model_name: mistral
    litellm_params:
      model: vllm/${MODELS[4]}
      api_base: http://vllm-svc:8000/v1
EOF

kubectl create configmap litellm-config --from-file=litellm-config.yaml -n $NAMESPACE --dry-run=client -o yaml | kubectl apply -f -

helm upgrade --install litellm-proxy litellm/litellm \
  --namespace $NAMESPACE \
  --values - <<EOF
image:
  repository: ghcr.io/berriai/litellm
extraVolumes:
- name: config-volume
  configMap:
    name: litellm-config
extraVolumeMounts:
- name: config-volume
  mountPath: /app/config.yaml
args: ["--config=/app/config.yaml"]
EOF

# 8. Final Step: Ingress Configuration
echo "🔗 Finalizing Network Routing..."
cat <<EOF | kubectl apply -f -
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: llm-gateway
  namespace: $NAMESPACE
  annotations:
    kubernetes.io/ingress.class: nginx
spec:
  rules:
  - host: $DOMAIN
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: litellm-proxy
            port:
              number: 4000
EOF

echo "------------------------------------------------"
echo "✅ SUCCESS: All components deployed."
echo "Entrypoint: http://$DOMAIN"
echo "Components: Nginx -> LiteLLM -> vLLM (w/ LMCache)"
echo "------------------------------------------------"
