#!/bin/bash

# --- Configuration ---
NAMESPACE="llm-ops"
DOMAIN="llm.local"
MODELS=(
 "google/gemma-2-2b-it"
 "microsoft/phi-4-mini"
 "meta-llama/Llama-3.2-1B-Instruct"
 "Qwen/Qwen2.5-Coder-7B-Instruct"
 "mistralai/Mistral-7B-Instruct-v0.3"
)

# ---------------------------------------------------------------------------
# STEP 0: Detect or prompt for device mode (GPU vs CPU)
# ---------------------------------------------------------------------------
echo ""
echo "=============================================="
echo "  LLM Stack — Device Configuration"
echo "=============================================="
echo ""

# Auto-detect GPUs available in the cluster
DETECTED_GPU_COUNT=$(kubectl get nodes \
 -o custom-columns="GPU:.status.capacity.nvidia\.com/gpu" \
 --no-headers 2>/dev/null |
 grep -v "<none>" | grep -v "^$" | awk '{sum+=$1} END {print sum+0}')

if [[ "$DETECTED_GPU_COUNT" -gt 0 ]]; then
 echo "✅ Auto-detected ${DETECTED_GPU_COUNT} NVIDIA GPU(s) across cluster nodes."
 echo ""
fi

echo "Select compute device for vLLM:"
echo "  [1] NVIDIA GPU  (requires NVIDIA device plugin + GPU nodes)"
echo "  [2] CPU only    (no GPU required, slower inference)"
echo ""
read -rp "Enter choice [1 or 2]: " DEVICE_CHOICE

case "$DEVICE_CHOICE" in
1)
 DEVICE_MODE="gpu"
 echo ""
 echo "🖥️  GPU mode selected."

 # Ensure the NVIDIA device plugin is installed
 echo "🔌 Checking NVIDIA device plugin..."
 if ! kubectl get daemonset nvidia-device-plugin-daemonset \
  -n kube-system &>/dev/null; then
  echo "   Not found — installing NVIDIA device plugin..."
  kubectl apply -f https://raw.githubusercontent.com/NVIDIA/k8s-device-plugin/v0.17.0/deployments/static/nvidia-device-plugin.yml
  echo "   Waiting for device plugin to become ready..."
  kubectl rollout status daemonset/nvidia-device-plugin-daemonset \
   -n kube-system --timeout=120s
 else
  echo "   Already installed ✓"
 fi
 ;;
2)
 DEVICE_MODE="cpu"
 echo ""
 echo "🖥️  CPU-only mode selected."
 ;;
*)
 echo "❌ Invalid choice. Please run the script again and enter 1 or 2."
 exit 1
 ;;
esac

echo ""
echo "🚀 Starting Full Cluster Provisioning (mode: ${DEVICE_MODE^^})..."
echo ""

# ---------------------------------------------------------------------------
# 1. Install Helm
# ---------------------------------------------------------------------------
if ! command -v helm &>/dev/null; then
 echo "📦 Installing Helm..."
 curl https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
fi

# ---------------------------------------------------------------------------
# 2. Add Required Helm Repos
# ---------------------------------------------------------------------------
echo "📦 Adding Helm Repositories..."
helm repo add ingress-nginx https://kubernetes.github.io/ingress-nginx
helm repo add vllm https://vllm-project.github.io/production-stack
# FIX 2: https://berriai.github.io/litellm is not a valid Helm repo index.
# LiteLLM's chart is OCI-based and installed directly — no repo add needed.
helm repo update

# ---------------------------------------------------------------------------
# 3. Setup Namespace
# ---------------------------------------------------------------------------
kubectl create namespace $NAMESPACE --dry-run=client -o yaml | kubectl apply -f -

# ---------------------------------------------------------------------------
# 4. Install Nginx Ingress Controller
# ---------------------------------------------------------------------------
echo "🌐 Installing Nginx Ingress..."
helm upgrade --install ingress-nginx ingress-nginx \
 --repo https://kubernetes.github.io/ingress-nginx \
 --namespace ingress-nginx --create-namespace \
 --set controller.service.type=LoadBalancer

# ---------------------------------------------------------------------------
# 5. Install vLLM Production Stack (includes LMCache)
# ---------------------------------------------------------------------------
# FIX 3: The lmcache.github.io helm repo no longer exists. LMCache is now
# distributed as part of the vLLM production-stack project.
# FIX 4: --set cannot correctly express nested array objects like modelSpec[].
# The chart requires repository and tag as mandatory fields alongside modelURL,
# so all modelSpec values must be supplied together via a values file.
echo "🧠 Installing vLLM Production Stack (with LMCache)..."

if [[ "$DEVICE_MODE" == "gpu" ]]; then
 cat <<EOF >vllm-values.yaml
servingEngineSpec:
  # runtimeClassName "nvidia" exposes the NVIDIA device plugin to the pod,
  # which is required for GPU scheduling on most clusters.
  runtimeClassName: "nvidia"
  modelSpec:
    - name: "vllm-engine"
      repository: "vllm/vllm-openai"
      tag: "latest"
      modelURL: "${MODELS[0]}"
      replicaCount: 1
      requestCPU: 6
      requestMemory: "16Gi"
      requestGPU: 1
      vllmConfig:
        maxModelLen: 2048
        extraArgs: ["--gpu-memory-utilization", "0.5", "--enforce-eager"]
EOF

else
 # FIX 5: vllm/vllm-openai:latest is a CUDA image that tries to load
 # libcuda.so.1 at Python import time, before CLI args are ever parsed.
 # Passing --device cpu to a CUDA image does nothing — the process crashes
 # before it reaches argument parsing. The correct image for CPU-only
 # deployments is the dedicated vllm/vllm-openai-cpu build, which has no
 # CUDA linkage at all.
 #
 # FIX 6: vLLM v1 engine (VLLM_USE_V1=1, the default) does not support
 # CPU backend and throws NotImplementedError at startup. VLLM_USE_V1=0
 # must be set explicitly to fall back to the v0 engine which supports CPU.
 cat <<EOF >vllm-values.yaml
servingEngineSpec:
  # runtimeClassName is empty for CPU-only clusters — no GPU runtime needed.
  runtimeClassName: ""
  modelSpec:
    - name: "vllm-engine"
      repository: "vllm/vllm-openai-cpu"
      tag: "latest-x86_64"
      modelURL: "${MODELS[0]}"
      replicaCount: 1
      requestCPU: 2
      requestMemory: "8Gi"
      requestGPU: 0
      env:
        - name: VLLM_USE_V1
          value: "0"
        - name: VLLM_CPU_KVCACHE_SPACE
          value: "4"
      vllmConfig:
        maxModelLen: 2048
        extraArgs: ["--dtype", "bfloat16", "--enforce-eager"]
EOF

fi

helm upgrade --install vllm-stack vllm/vllm-stack \
 --namespace $NAMESPACE --create-namespace \
 --values vllm-values.yaml

# ---------------------------------------------------------------------------
# 6. Install LiteLLM Proxy
# ---------------------------------------------------------------------------
# FIX 7: The previous approach of manually creating a ConfigMap and mounting
# it via extraVolumes/extraVolumeMounts is not supported by the litellm-helm
# chart — those fields don't exist — so /app/config.yaml was never actually
# written into the pod, causing the "Config file not found" crash.
#
# The correct approach is the chart's own 'proxy_config' key. When
# proxyConfigMap.create=true (the default), the chart renders proxy_config
# into a ConfigMap and mounts it at /app/config.yaml automatically.
#
# FIX 8: https://berriai.github.io/litellm is not a valid Helm index and the
# chart is not named 'litellm'. The official chart is OCI-hosted at
# oci://ghcr.io/berriai/litellm-helm and must be referenced by that full path.
echo "⚖️ Deploying LiteLLM Router..."

helm upgrade --install litellm-proxy oci://ghcr.io/berriai/litellm-helm \
 --namespace $NAMESPACE \
 --values - <<EOF
proxyConfigMap:
  create: true

proxy_config:
  model_list:
    - model_name: gemma
      litellm_params:
        # FIX 9: Use the 'openai/' prefix, not 'vllm/'. The 'vllm/' prefix
        # invokes LiteLLM's native vLLM SDK integration (Python subprocess).
        # Since vLLM is already running an OpenAI-compatible REST server,
        # LiteLLM must treat it as a generic OpenAI endpoint via the 'openai/'
        # prefix combined with api_base.
        model: openai/${MODELS[0]}
        # FIX 10: Point to the vllm-stack router service, not the old vllm-svc.
        # The production-stack chart exposes a router on port 80 that
        # load-balances across all vLLM engine pods.
        api_base: http://vllm-stack-router-service:80/v1
EOF

# ---------------------------------------------------------------------------
# 7. Ingress Configuration
# ---------------------------------------------------------------------------
echo "🔗 Finalizing Network Routing..."
cat <<EOF | kubectl apply -f -
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: llm-gateway
  namespace: $NAMESPACE
  # FIX 11: The 'kubernetes.io/ingress.class' annotation was deprecated in
  # k8s 1.18 and fully removed in 1.22. The nginx ingress controller ignores
  # it on modern clusters, so traffic never reaches LiteLLM. Use the
  # spec.ingressClassName field instead.
spec:
  ingressClassName: nginx
  rules:
  - host: $DOMAIN
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: litellm-proxy-litellm-helm
            port:
              number: 4000
EOF

echo ""
echo "------------------------------------------------"
echo "✅ SUCCESS: All components deployed."
echo "   Device mode : ${DEVICE_MODE^^}"
echo "   Model       : ${MODELS[0]}"
echo "   Entrypoint  : http://$DOMAIN"
echo "------------------------------------------------"
