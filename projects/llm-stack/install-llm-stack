#!/bin/bash

# FIX 1: Exit immediately on any error, treat unset variables as errors,
# and propagate pipe failures. Without this the script happily continues
# past a failed kubectl/helm call and deploys against a broken cluster.
set -euo pipefail

# --- Configuration ---
NAMESPACE="llm-ops"
DOMAIN="llm.local"
MODELS=(
  "google/gemma-2-2b-it"
  "microsoft/phi-4-mini"
  "meta-llama/Llama-3.2-1B-Instruct"
  "Qwen/Qwen2.5-Coder-7B-Instruct"
  "mistralai/Mistral-7B-Instruct-v0.3"
)

echo "🚀 Starting Full Cluster Provisioning..."

# 1. Install Helm
if ! command -v helm &>/dev/null; then
  echo "📦 Installing Helm..."
  curl https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
fi

# 2. Add Required Helm Repos
echo "📦 Adding Helm Repositories..."
helm repo add ingress-nginx https://kubernetes.github.io/ingress-nginx
helm repo add vllm https://vllm-project.github.io/production-stack
# FIX 2: https://berriai.github.io/litellm is not a valid Helm repo index.
# LiteLLM's chart is OCI-based and installed directly — no repo add needed.
helm repo update

# 3. Setup Namespace
kubectl create namespace $NAMESPACE --dry-run=client -o yaml | kubectl apply -f -

# 4. Install Nginx Ingress Controller
echo "🌐 Installing Nginx Ingress..."
helm upgrade --install ingress-nginx ingress-nginx \
  --repo https://kubernetes.github.io/ingress-nginx \
  --namespace ingress-nginx --create-namespace \
  --set controller.service.type=LoadBalancer

# 5. Install vLLM Production Stack (includes LMCache)
# FIX 3: The lmcache.github.io helm repo no longer exists. LMCache is now
# distributed as part of the vLLM production-stack project.
# FIX 4: --set cannot correctly express nested array objects like modelSpec[].
# The chart requires repository and tag as mandatory fields alongside modelURL,
# so all modelSpec values must be supplied together via a values file.
echo "🧠 Installing vLLM Production Stack (with LMCache)..."
cat <<EOF > vllm-values.yaml
servingEngineSpec:
  runtimeClassName: ""
  modelSpec:
    - name: "vllm-engine"
      repository: "vllm/vllm-openai"
      tag: "latest"
      modelURL: "${MODELS[0]}"
      replicaCount: 1
      requestCPU: 6
      requestMemory: "16Gi"
      requestGPU: 1
      vllmConfig:
        maxModelLen: 2048
        extraArgs: ["--gpu-memory-utilization", "0.5", "--enforce-eager"]
EOF

helm upgrade --install vllm-stack vllm/vllm-stack \
  --namespace $NAMESPACE --create-namespace \
  --values vllm-values.yaml

# 6. Configure and Install LiteLLM Proxy
echo "⚖️ Deploying LiteLLM Router..."
cat <<EOF > litellm-config.yaml
model_list:
  - model_name: gemma
    litellm_params:
      # FIX 5: Use the 'openai/' prefix, not 'vllm/'. The 'vllm/' prefix
      # invokes LiteLLM's native vLLM SDK integration (Python subprocess).
      # Since vLLM is already running an OpenAI-compatible REST server,
      # LiteLLM must treat it as a generic OpenAI endpoint via the 'openai/'
      # prefix combined with api_base.
      model: openai/${MODELS[0]}
      # FIX 6: Point to the vllm-stack router service, not the old vllm-svc.
      # The production-stack chart exposes a router on port 80 that
      # load-balances across all vLLM engine pods.
      api_base: http://vllm-stack-router-service:80/v1
EOF

kubectl create configmap litellm-config \
  --from-file=litellm-config.yaml \
  -n $NAMESPACE \
  --dry-run=client -o yaml | kubectl apply -f -

# FIX 7: https://berriai.github.io/litellm is not a valid Helm index and the
# chart is not named 'litellm'. The official chart is OCI-hosted at
# oci://ghcr.io/berriai/litellm-helm and must be referenced by that full path.
helm upgrade --install litellm-proxy oci://ghcr.io/berriai/litellm-helm \
  --namespace $NAMESPACE \
  --values - <<EOF
image:
  repository: ghcr.io/berriai/litellm
extraVolumes:
- name: config-volume
  configMap:
    name: litellm-config
extraVolumeMounts:
- name: config-volume
  mountPath: /app/config.yaml
  # FIX 8: subPath is required when mounting a ConfigMap to a *file* path.
  # Without it Kubernetes replaces the entire /app directory with a
  # directory named "config.yaml" containing each ConfigMap key as a file,
  # so '--config=/app/config.yaml' gets a directory instead of a YAML file.
  subPath: litellm-config.yaml
args: ["--config=/app/config.yaml"]
EOF

# 7. Ingress Configuration
echo "🔗 Finalizing Network Routing..."
cat <<EOF | kubectl apply -f -
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: llm-gateway
  namespace: $NAMESPACE
  # FIX 9: The 'kubernetes.io/ingress.class' annotation was deprecated in
  # k8s 1.18 and fully removed in 1.22. The nginx ingress controller ignores
  # it on modern clusters, so traffic never reaches LiteLLM. Use the
  # spec.ingressClassName field instead.
spec:
  ingressClassName: nginx
  rules:
  - host: $DOMAIN
    http:
      paths:
      - path: /
        pathType: Prefix
        backend:
          service:
            name: litellm-proxy-litellm-helm
            port:
              number: 4000
EOF

echo "------------------------------------------------"
echo "✅ SUCCESS: All components deployed."
echo "Entrypoint: http://$DOMAIN"
echo "------------------------------------------------"
