#!/usr/bin/env bash
# =============================================================================
#  ZERO-TO-HERO: API Gateway + Traefik Ingress on EKS
#  Uses your company's private CA, server.crt, and server.key for TLS
#  Test target: busybox pod echoing "I received the request"
# =============================================================================
# PREREQUISITES (must be installed and on $PATH before running):
#   aws cli v2, eksctl, kubectl, helm v3, curl, jq, openssl
#
# CERT FILES expected at the paths below (change if needed):
#   ./certs/ca.crt         — private CA certificate (PEM)
#   ./certs/server.crt     — server certificate     (PEM)
#   ./certs/server.key     — server private key      (PEM, unencrypted)
#
# USAGE:
#   chmod +x eks-ingress-setup.sh
#   ./eks-ingress-setup.sh          # full install
#   ./eks-ingress-setup.sh --clean  # tear everything down
# =============================================================================
set -Eeuo pipefail
trap 'echo "❌  Error on line ${LINENO}. Exit code: $?" >&2' ERR

# ─── Colour helpers ──────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'
info() { echo -e "${CYAN}${BOLD}[INFO]${RESET}  $*"; }
success() { echo -e "${GREEN}${BOLD}[OK]${RESET}    $*"; }
warn() { echo -e "${YELLOW}${BOLD}[WARN]${RESET}  $*"; }
die() {
 echo -e "${RED}${BOLD}[FATAL]${RESET} $*" >&2
 exit 1
}
step() { echo -e "\n${BOLD}━━━ $* ━━━${RESET}"; }

# ─── Configuration — edit these to match your environment ────────────────────
CLUSTER_NAME="${CLUSTER_NAME:-my-eks-cluster}"
AWS_REGION="${AWS_REGION:-us-east-1}"
K8S_VERSION="${K8S_VERSION:-1.29}"
NODE_TYPE="${NODE_TYPE:-t3.medium}"
NODE_COUNT="${NODE_COUNT:-2}"
TRAEFIK_NAMESPACE="traefik"
APP_NAMESPACE="echo-app"
APP_NAME="busybox-echo"
TLS_SECRET_NAME="company-tls"
CA_SECRET_NAME="company-ca"
DOMAIN="${DOMAIN:-echo.internal.example.com}" # DNS name for the echo service
CERT_DIR="${CERT_DIR:-./certs}"               # directory holding ca.crt / server.crt / server.key
API_GW_NAME="${API_GW_NAME:-eks-traefik-apigw}"
VPC_LINK_NAME="${VPC_LINK_NAME:-eks-traefik-vpclink}"

# ─── Cert file paths ─────────────────────────────────────────────────────────
CA_CERT="${CERT_DIR}/ca.crt"
SERVER_CERT="${CERT_DIR}/server.crt"
SERVER_KEY="${CERT_DIR}/server.key"

# ═════════════════════════════════════════════════════════════════════════════
# TEARDOWN MODE
# ═════════════════════════════════════════════════════════════════════════════
if [[ "${1:-}" == "--clean" ]]; then
 step "TEARDOWN — removing all resources"

 # Delete API Gateway & VPC Link
 info "Removing API Gateway HTTP API..."
 API_ID=$(aws apigatewayv2 get-apis --region "$AWS_REGION" \
  --query "Items[?Name=='${API_GW_NAME}'].ApiId" --output text 2>/dev/null || true)
 if [[ -n "$API_ID" && "$API_ID" != "None" ]]; then
  aws apigatewayv2 delete-api --api-id "$API_ID" --region "$AWS_REGION"
  success "Deleted API Gateway: $API_ID"
 fi

 info "Removing VPC Link..."
 VPC_LINK_ID=$(aws apigatewayv2 get-vpc-links --region "$AWS_REGION" \
  --query "Items[?Name=='${VPC_LINK_NAME}'].VpcLinkId" --output text 2>/dev/null || true)
 if [[ -n "$VPC_LINK_ID" && "$VPC_LINK_ID" != "None" ]]; then
  aws apigatewayv2 delete-vpc-link --vpc-link-id "$VPC_LINK_ID" --region "$AWS_REGION"
  success "Deleted VPC Link: $VPC_LINK_ID"
 fi

 # Delete Kubernetes resources
 info "Removing K8s namespaces..."
 kubectl delete namespace "$APP_NAMESPACE" --ignore-not-found=true
 kubectl delete namespace "$TRAEFIK_NAMESPACE" --ignore-not-found=true
 kubectl delete clusterrolebinding traefik-cluster-admin --ignore-not-found=true
 kubectl delete clusterrole traefik-ingress --ignore-not-found=true

 # Delete EKS cluster
 read -r -p "Delete EKS cluster '${CLUSTER_NAME}'? [y/N] " confirm
 if [[ "${confirm,,}" == "y" ]]; then
  info "Deleting EKS cluster (this takes ~15 min)…"
  eksctl delete cluster --name "$CLUSTER_NAME" --region "$AWS_REGION"
  success "Cluster deleted."
 fi

 success "Teardown complete."
 exit 0
fi

# ═════════════════════════════════════════════════════════════════════════════
# STEP 0 — PREFLIGHT CHECKS
# ═════════════════════════════════════════════════════════════════════════════
step "STEP 0 — Preflight checks"

for tool in aws eksctl kubectl helm curl jq openssl; do
 command -v "$tool" &>/dev/null || die "'$tool' not found in PATH. Install it and retry."
 success "$tool … found"
done

# Verify cert files exist
for f in "$CA_CERT" "$SERVER_CERT" "$SERVER_KEY"; do
 [[ -f "$f" ]] || die "Required cert file not found: $f"
 success "Cert file found: $f"
done

# Validate cert/key match
CERT_MOD=$(openssl x509 -noout -modulus -in "$SERVER_CERT" | md5sum)
KEY_MOD=$(openssl rsa -noout -modulus -in "$SERVER_KEY" | md5sum)
[[ "$CERT_MOD" == "$KEY_MOD" ]] || die "server.crt and server.key do NOT match!"
success "server.crt ↔ server.key match verified"

# Verify server cert is signed by the private CA
openssl verify -CAfile "$CA_CERT" "$SERVER_CERT" &>/dev/null ||
 warn "server.crt cannot be verified against ca.crt — continuing anyway (chain may be intermediate)"

# AWS identity check
info "Checking AWS identity…"
aws sts get-caller-identity --region "$AWS_REGION" | jq -r '"Account: \(.Account)  ARN: \(.Arn)"'

# ═════════════════════════════════════════════════════════════════════════════
# STEP 1 — CREATE / CONNECT TO EKS CLUSTER
# ═════════════════════════════════════════════════════════════════════════════
step "STEP 1 — EKS cluster"

if eksctl get cluster --name "$CLUSTER_NAME" --region "$AWS_REGION" &>/dev/null; then
 warn "Cluster '${CLUSTER_NAME}' already exists — skipping creation"
else
 info "Creating EKS cluster '${CLUSTER_NAME}' (this takes ~15 min)…"
 eksctl create cluster \
  --name "$CLUSTER_NAME" \
  --region "$AWS_REGION" \
  --version "$K8S_VERSION" \
  --nodegroup-name standard-workers \
  --node-type "$NODE_TYPE" \
  --nodes "$NODE_COUNT" \
  --nodes-min 1 \
  --nodes-max 4 \
  --managed \
  --asg-access \
  --full-ecr-access \
  --alb-ingress-access
 success "Cluster created."
fi

info "Updating kubeconfig…"
aws eks update-kubeconfig --name "$CLUSTER_NAME" --region "$AWS_REGION"
kubectl cluster-info
success "kubectl connected."

# ═════════════════════════════════════════════════════════════════════════════
# STEP 2 — NAMESPACES
# ═════════════════════════════════════════════════════════════════════════════
step "STEP 2 — Namespaces"

for ns in "$TRAEFIK_NAMESPACE" "$APP_NAMESPACE"; do
 kubectl create namespace "$ns" --dry-run=client -o yaml | kubectl apply -f -
 success "Namespace '$ns' ready."
done

# ═════════════════════════════════════════════════════════════════════════════
# STEP 3 — UPLOAD COMPANY TLS CERTS AS K8S SECRETS
# ═════════════════════════════════════════════════════════════════════════════
step "STEP 3 — TLS secrets"

# TLS secret (server.crt + server.key) in both namespaces
for ns in "$TRAEFIK_NAMESPACE" "$APP_NAMESPACE"; do
 kubectl create secret tls "$TLS_SECRET_NAME" \
  --cert="$SERVER_CERT" \
  --key="$SERVER_KEY" \
  --namespace="$ns" \
  --dry-run=client -o yaml | kubectl apply -f -
 success "TLS secret '$TLS_SECRET_NAME' in namespace '$ns'."
done

# CA bundle secret (used by Traefik to trust upstream / mutual TLS)
for ns in "$TRAEFIK_NAMESPACE" "$APP_NAMESPACE"; do
 kubectl create secret generic "$CA_SECRET_NAME" \
  --from-file=ca.crt="$CA_CERT" \
  --namespace="$ns" \
  --dry-run=client -o yaml | kubectl apply -f -
 success "CA secret '$CA_SECRET_NAME' in namespace '$ns'."
done

# ═════════════════════════════════════════════════════════════════════════════
# STEP 4 — TRAEFIK INGRESS CONTROLLER (Helm)
# ═════════════════════════════════════════════════════════════════════════════
step "STEP 4 — Traefik ingress controller"

helm repo add traefik https://traefik.github.io/charts --force-update
helm repo update

# Helm values — customise to taste
cat >/tmp/traefik-values.yaml <<EOF
# ── Traefik Helm values ──────────────────────────────────────────────────────
deployment:
  replicas: 2

# Expose via NLB so API Gateway VPC Link can reach it on a stable IP
service:
  type: LoadBalancer
  annotations:
    service.beta.kubernetes.io/aws-load-balancer-type: "nlb"
    service.beta.kubernetes.io/aws-load-balancer-scheme: "internal"
    service.beta.kubernetes.io/aws-load-balancer-cross-zone-load-balancing-enabled: "true"

# Ports
ports:
  web:
    port: 80
    expose:
      default: true
    redirectTo:
      port: websecure   # always redirect HTTP → HTTPS
  websecure:
    port: 443
    expose:
      default: true
    tls:
      enabled: true
      # Use the company TLS cert loaded as a K8s secret
      stores:
        - name: default
    middlewares:
      - traefik-traefik-compress@kubernetescrd
  traefik:
    port: 9000
    expose:
      default: false

# TLS store — point to our K8s secret
tlsStore:
  default:
    defaultCertificate:
      secretName: ${TLS_SECRET_NAME}

# Extra volumes to mount the CA bundle
volumes:
  - name: company-ca
    mountPath: /certs/ca
    type: secret
    secretName: ${CA_SECRET_NAME}

additionalArguments:
  - "--serversTransport.rootCAs=/certs/ca/ca.crt"
  - "--api.insecure=false"
  - "--api.dashboard=true"
  - "--log.level=INFO"
  - "--accesslog=true"
  - "--providers.kubernetesIngress=true"
  - "--providers.kubernetesCRD=true"
  - "--entrypoints.web.address=:80"
  - "--entrypoints.websecure.address=:443"

# Dashboard IngressRoute (internal only)
ingressRoute:
  dashboard:
    enabled: true
    entryPoints:
      - traefik
    matchRule: Host(\`traefik.${DOMAIN}\`)
    tls:
      secretName: ${TLS_SECRET_NAME}

# RBAC
rbac:
  enabled: true

# Pod security
podSecurityContext:
  fsGroup: 65532

securityContext:
  capabilities:
    drop: [ALL]
  readOnlyRootFilesystem: true
  runAsGroup: 65532
  runAsNonRoot: true
  runAsUser: 65532

resources:
  requests:
    cpu: "100m"
    memory: "128Mi"
  limits:
    cpu: "300m"
    memory: "256Mi"

# Horizontal Pod Autoscaler
autoscaling:
  enabled: true
  minReplicas: 2
  maxReplicas: 5
  metrics:
    - type: Resource
      resource:
        name: cpu
        target:
          type: Utilization
          averageUtilization: 60
EOF

helm upgrade --install traefik traefik/traefik \
 --namespace "$TRAEFIK_NAMESPACE" \
 --values /tmp/traefik-values.yaml \
 --wait --timeout 5m

success "Traefik deployed."

# Wait for the NLB to receive its hostname
info "Waiting for Traefik NLB external hostname (up to 5 min)…"
TRAEFIK_LB=""
for i in $(seq 1 60); do
 TRAEFIK_LB=$(kubectl get svc traefik -n "$TRAEFIK_NAMESPACE" \
  -o jsonpath='{.status.loadBalancer.ingress[0].hostname}' 2>/dev/null || true)
 [[ -n "$TRAEFIK_LB" ]] && break
 sleep 5
done
[[ -n "$TRAEFIK_LB" ]] || die "Traefik LoadBalancer hostname never appeared."
success "Traefik NLB: $TRAEFIK_LB"

# ═════════════════════════════════════════════════════════════════════════════
# STEP 5 — BUSYBOX ECHO APPLICATION
# ═════════════════════════════════════════════════════════════════════════════
step "STEP 5 — Busybox echo application"

kubectl apply -f - <<EOF
# ── Deployment ────────────────────────────────────────────────────────────────
apiVersion: apps/v1
kind: Deployment
metadata:
  name: ${APP_NAME}
  namespace: ${APP_NAMESPACE}
  labels:
    app: ${APP_NAME}
spec:
  replicas: 2
  selector:
    matchLabels:
      app: ${APP_NAME}
  template:
    metadata:
      labels:
        app: ${APP_NAME}
    spec:
      containers:
        - name: echo
          # busybox httpd: listen on :8080 and echo a fixed response
          image: busybox:1.36
          command:
            - sh
            - -c
            - |
              while true; do
                echo -e "HTTP/1.1 200 OK\r\nContent-Type: text/plain\r\nConnection: close\r\n\r\nI received the request" \
                  | nc -l -p 8080
              done
          ports:
            - containerPort: 8080
          resources:
            requests:
              cpu: "10m"
              memory: "16Mi"
            limits:
              cpu: "50m"
              memory: "32Mi"
          readinessProbe:
            tcpSocket:
              port: 8080
            initialDelaySeconds: 3
            periodSeconds: 5
---
# ── ClusterIP Service ─────────────────────────────────────────────────────────
apiVersion: v1
kind: Service
metadata:
  name: ${APP_NAME}
  namespace: ${APP_NAMESPACE}
spec:
  selector:
    app: ${APP_NAME}
  ports:
    - name: http
      port: 80
      targetPort: 8080
---
# ── Traefik IngressRoute (HTTPS via company cert) ─────────────────────────────
apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: ${APP_NAME}-route
  namespace: ${APP_NAMESPACE}
spec:
  entryPoints:
    - websecure
  routes:
    - match: Host(\`${DOMAIN}\`) && PathPrefix(\`/\`)
      kind: Rule
      services:
        - name: ${APP_NAME}
          port: 80
  tls:
    secretName: ${TLS_SECRET_NAME}
---
# ── Standard Ingress (fallback / API Gateway integration) ────────────────────
apiVersion: networking.k8s.io/v1
kind: Ingress
metadata:
  name: ${APP_NAME}-ingress
  namespace: ${APP_NAMESPACE}
  annotations:
    kubernetes.io/ingress.class: traefik
    traefik.ingress.kubernetes.io/router.entrypoints: websecure
    traefik.ingress.kubernetes.io/router.tls: "true"
    traefik.ingress.kubernetes.io/router.tls.secretName: ${TLS_SECRET_NAME}
spec:
  ingressClassName: traefik
  tls:
    - hosts:
        - ${DOMAIN}
      secretName: ${TLS_SECRET_NAME}
  rules:
    - host: ${DOMAIN}
      http:
        paths:
          - path: /
            pathType: Prefix
            backend:
              service:
                name: ${APP_NAME}
                port:
                  number: 80
EOF

kubectl rollout status deployment/"$APP_NAME" -n "$APP_NAMESPACE" --timeout=3m
success "Busybox echo app is running."

# ═════════════════════════════════════════════════════════════════════════════
# STEP 6 — AWS API GATEWAY (HTTP API) + VPC LINK
# ═════════════════════════════════════════════════════════════════════════════
step "STEP 6 — AWS API Gateway + VPC Link"

# Collect VPC / subnet / SG info from the cluster's node group
info "Fetching VPC ID from EKS cluster…"
VPC_ID=$(aws eks describe-cluster \
 --name "$CLUSTER_NAME" --region "$AWS_REGION" \
 --query "cluster.resourcesVpcConfig.vpcId" --output text)
success "VPC ID: $VPC_ID"

info "Fetching private subnets…"
SUBNET_IDS=$(aws ec2 describe-subnets \
 --region "$AWS_REGION" \
 --filters "Name=vpc-id,Values=${VPC_ID}" \
 "Name=tag:kubernetes.io/role/internal-elb,Values=1" \
 --query "Subnets[*].SubnetId" --output text | tr '\t' ',')

# Fallback: grab any subnets in the VPC if tagging is absent
if [[ -z "$SUBNET_IDS" || "$SUBNET_IDS" == "None" ]]; then
 warn "No subnets tagged 'kubernetes.io/role/internal-elb=1' — using all private subnets"
 SUBNET_IDS=$(aws ec2 describe-subnets \
  --region "$AWS_REGION" \
  --filters "Name=vpc-id,Values=${VPC_ID}" \
  --query "Subnets[*].SubnetId" --output text | tr '\t' ',')
fi
success "Subnets: $SUBNET_IDS"

# Security group — reuse the node SG or create a dedicated one
info "Looking up cluster node security group…"
NODE_SG=$(aws eks describe-cluster \
 --name "$CLUSTER_NAME" --region "$AWS_REGION" \
 --query "cluster.resourcesVpcConfig.clusterSecurityGroupId" --output text)
success "Node SG: $NODE_SG"

# ── Create VPC Link ───────────────────────────────────────────────────────────
info "Creating VPC Link '${VPC_LINK_NAME}'…"
EXISTING_VPC_LINK=$(aws apigatewayv2 get-vpc-links --region "$AWS_REGION" \
 --query "Items[?Name=='${VPC_LINK_NAME}'].VpcLinkId" --output text 2>/dev/null || true)

if [[ -n "$EXISTING_VPC_LINK" && "$EXISTING_VPC_LINK" != "None" ]]; then
 VPC_LINK_ID="$EXISTING_VPC_LINK"
 warn "VPC Link already exists: $VPC_LINK_ID"
else
 VPC_LINK_RESP=$(aws apigatewayv2 create-vpc-link \
  --name "$VPC_LINK_NAME" \
  --subnet-ids $(echo "$SUBNET_IDS" | tr ',' ' ') \
  --security-group-ids "$NODE_SG" \
  --region "$AWS_REGION")
 VPC_LINK_ID=$(echo "$VPC_LINK_RESP" | jq -r '.VpcLinkId')
 success "VPC Link created: $VPC_LINK_ID"
fi

# Wait for VPC Link to become available
info "Waiting for VPC Link to become AVAILABLE (up to 5 min)…"
for i in $(seq 1 60); do
 STATUS=$(aws apigatewayv2 get-vpc-link \
  --vpc-link-id "$VPC_LINK_ID" --region "$AWS_REGION" \
  --query "VpcLinkStatus" --output text)
 [[ "$STATUS" == "AVAILABLE" ]] && break
 [[ "$STATUS" == "FAILED" ]] && die "VPC Link failed to provision."
 sleep 5
done
success "VPC Link is AVAILABLE."

# ── Resolve NLB ARN from hostname ─────────────────────────────────────────────
info "Resolving NLB ARN from hostname: $TRAEFIK_LB"
NLB_ARN=$(aws elbv2 describe-load-balancers --region "$AWS_REGION" \
 --query "LoadBalancers[?DNSName=='${TRAEFIK_LB}'].LoadBalancerArn" \
 --output text 2>/dev/null || true)

if [[ -z "$NLB_ARN" || "$NLB_ARN" == "None" ]]; then
 warn "Could not find NLB ARN by exact DNS match — searching by substring…"
 NLB_SHORT=$(echo "$TRAEFIK_LB" | cut -d'.' -f1)
 NLB_ARN=$(aws elbv2 describe-load-balancers --region "$AWS_REGION" \
  --query "LoadBalancers[?contains(DNSName,'${NLB_SHORT}')].LoadBalancerArn" \
  --output text)
fi
[[ -n "$NLB_ARN" && "$NLB_ARN" != "None" ]] || die "Cannot determine NLB ARN. Check Traefik service."
success "NLB ARN: $NLB_ARN"

# Retrieve NLB listener ARN (port 443)
LISTENER_ARN=$(aws elbv2 describe-listeners \
 --load-balancer-arn "$NLB_ARN" --region "$AWS_REGION" \
 --query "Listeners[?Port==\`443\`].ListenerArn" --output text 2>/dev/null || true)

# Fallback to port 80 if 443 not yet active
if [[ -z "$LISTENER_ARN" || "$LISTENER_ARN" == "None" ]]; then
 LISTENER_ARN=$(aws elbv2 describe-listeners \
  --load-balancer-arn "$NLB_ARN" --region "$AWS_REGION" \
  --query "Listeners[0].ListenerArn" --output text)
fi
success "NLB Listener ARN: $LISTENER_ARN"

# ── Create HTTP API ────────────────────────────────────────────────────────────
info "Creating API Gateway HTTP API '${API_GW_NAME}'…"
EXISTING_API_ID=$(aws apigatewayv2 get-apis --region "$AWS_REGION" \
 --query "Items[?Name=='${API_GW_NAME}'].ApiId" --output text 2>/dev/null || true)

if [[ -n "$EXISTING_API_ID" && "$EXISTING_API_ID" != "None" ]]; then
 API_ID="$EXISTING_API_ID"
 warn "API Gateway already exists: $API_ID"
else
 API_RESP=$(aws apigatewayv2 create-api \
  --name "$API_GW_NAME" \
  --protocol-type HTTP \
  --region "$AWS_REGION" \
  --cors-configuration \
  AllowOrigins='["*"]',AllowMethods='["GET","POST","PUT","DELETE","OPTIONS"]',AllowHeaders='["*"]')
 API_ID=$(echo "$API_RESP" | jq -r '.ApiId')
 success "HTTP API created: $API_ID"
fi

# ── Integration (VPC Link → NLB listener) ────────────────────────────────────
info "Creating API Gateway integration…"
INTEGRATION_RESP=$(aws apigatewayv2 create-integration \
 --api-id "$API_ID" \
 --integration-type HTTP_PROXY \
 --integration-uri "$LISTENER_ARN" \
 --integration-method ANY \
 --connection-type VPC_LINK \
 --connection-id "$VPC_LINK_ID" \
 --payload-format-version "1.0" \
 --region "$AWS_REGION")
INTEGRATION_ID=$(echo "$INTEGRATION_RESP" | jq -r '.IntegrationId')
success "Integration created: $INTEGRATION_ID"

# ── Route: ANY /{proxy+} ──────────────────────────────────────────────────────
info "Creating catch-all route…"
aws apigatewayv2 create-route \
 --api-id "$API_ID" \
 --route-key 'ANY /{proxy+}' \
 --target "integrations/${INTEGRATION_ID}" \
 --region "$AWS_REGION" >/dev/null

# Root route
aws apigatewayv2 create-route \
 --api-id "$API_ID" \
 --route-key 'ANY /' \
 --target "integrations/${INTEGRATION_ID}" \
 --region "$AWS_REGION" >/dev/null
success "Routes created."

# ── Stage: $default (auto-deploy) ────────────────────────────────────────────
info "Creating API Gateway stage '\$default'…"
aws apigatewayv2 create-stage \
 --api-id "$API_ID" \
 --stage-name '$default' \
 --auto-deploy \
 --region "$AWS_REGION" \
 --default-route-settings \
 ThrottlingBurstLimit=100,ThrottlingRateLimit=50 >/dev/null
success "Stage '\$default' created with auto-deploy."

# Retrieve invoke URL
API_ENDPOINT=$(aws apigatewayv2 get-api \
 --api-id "$API_ID" --region "$AWS_REGION" \
 --query "ApiEndpoint" --output text)
success "API Gateway invoke URL: $API_ENDPOINT"

# ═════════════════════════════════════════════════════════════════════════════
# STEP 7 — SMOKE TEST
# ═════════════════════════════════════════════════════════════════════════════
step "STEP 7 — Smoke tests"

# ── In-cluster test via kubectl exec ─────────────────────────────────────────
info "In-cluster test: exec into a temporary pod and hit the echo service…"
kubectl run smoke-test \
 --image=busybox:1.36 \
 --restart=Never \
 --rm \
 --namespace "$APP_NAMESPACE" \
 --attach \
 --command -- sh -c \
 "wget -qO- http://${APP_NAME}.${APP_NAMESPACE}.svc.cluster.local && echo" 2>/dev/null ||
 warn "In-cluster test skipped (pod may have timed out — check manually)"

# ── Test via Traefik NLB (internal) ──────────────────────────────────────────
info "Testing Traefik NLB directly (requires internal network access)…"
echo "  curl --cacert ${CA_CERT} https://${DOMAIN}/"
echo "  (Run this from a host in the same VPC / via VPN)"

# ── Test via API Gateway ──────────────────────────────────────────────────────
info "Testing via API Gateway endpoint…"
echo "  curl -s ${API_ENDPOINT}/"
echo ""
HTTP_STATUS=$(curl -o /dev/null -s -w "%{http_code}" \
 --max-time 10 "${API_ENDPOINT}/" 2>/dev/null || true)
if [[ "$HTTP_STATUS" =~ ^2 ]]; then
 success "API Gateway returned HTTP ${HTTP_STATUS} ✅"
 BODY=$(curl -s --max-time 10 "${API_ENDPOINT}/" 2>/dev/null || true)
 echo -e "${GREEN}Response body:${RESET} ${BODY}"
else
 warn "API Gateway returned HTTP ${HTTP_STATUS}. VPC Link / NLB may still be propagating (give it 1-2 min)."
fi

# ─── Port-forward shortcut for local testing ─────────────────────────────────
info "For local browser testing, run:"
echo ""
