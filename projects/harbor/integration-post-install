#!/usr/bin/env bash
# =============================================================================
#  setup-argocd-gitlab.sh
#  Connects ArgoCD to an in-cluster GitLab repo and deploys an example app
#  Prerequisites: ArgoCD + GitLab already installed via their install scripts
# =============================================================================
set -euo pipefail

# ── Colours ───────────────────────────────────────────────────────────────────
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log() { echo -e "${CYAN}${BOLD}[INFO]${RESET}  $*"; }
success() { echo -e "${GREEN}${BOLD}[OK]${RESET}    $*"; }
warn() { echo -e "${YELLOW}${BOLD}[WARN]${RESET}  $*"; }
error() {
 echo -e "${RED}${BOLD}[ERROR]${RESET} $*" >&2
 exit 1
}
banner() {
 echo -e "\n${BOLD}${CYAN}══════════════════════════════════════════════════${RESET}"
 echo -e "${BOLD}${CYAN}  $*${RESET}"
 echo -e "${BOLD}${CYAN}══════════════════════════════════════════════════${RESET}\n"
}

# ── Config (override via env vars) ────────────────────────────────────────────
ARGOCD_NAMESPACE="${ARGOCD_NAMESPACE:-argocd}"
GITLAB_NAMESPACE="${GITLAB_NAMESPACE:-gitlab}"
PROJECT_NAME="${PROJECT_NAME:-guestbook}"
APP_NAMESPACE="${APP_NAMESPACE:-guestbook}"
GITLAB_USER="${GITLAB_USER:-root}"
WORK_DIR="${WORK_DIR:-/tmp/argocd-gitlab-setup}"

# =============================================================================
#  STEP 0 — Preflight checks
# =============================================================================
banner "Step 0 · Preflight checks"

for bin in kubectl minikube curl jq git argocd; do
 command -v "$bin" &>/dev/null ||
  error "'$bin' not found in PATH. Please install it first."
 success "$bin found."
done

log "Verifying Minikube is running..."
minikube status --format='{{.Host}}' 2>/dev/null | grep -q "Running" ||
 error "Minikube is not running. Start it with: minikube start"
success "Minikube is up."

log "Verifying ArgoCD pods are running..."
kubectl get deployment argocd-server -n "${ARGOCD_NAMESPACE}" &>/dev/null ||
 error "ArgoCD not found in namespace '${ARGOCD_NAMESPACE}'. Run install-argocd-minikube.sh first."
success "ArgoCD is present."

log "Verifying GitLab pods are running..."
kubectl get deployment gitlab-webservice-default -n "${GITLAB_NAMESPACE}" &>/dev/null ||
 error "GitLab not found in namespace '${GITLAB_NAMESPACE}'. Run the GitLab install script first."
success "GitLab is present."

# =============================================================================
#  STEP 1 — Gather dynamic cluster values
# =============================================================================
banner "Step 1 · Gather cluster values"

MINIKUBE_IP=$(minikube ip)
GITLAB_URL="http://gitlab.${MINIKUBE_IP}.nip.io"
GITLAB_INTERNAL_URL="http://gitlab-webservice-default.${GITLAB_NAMESPACE}.svc.cluster.local:8181"

ARGOCD_NODE_PORT=$(kubectl get svc argocd-server \
 -n "${ARGOCD_NAMESPACE}" \
 -o jsonpath='{.spec.ports[?(@.port==443)].nodePort}')

ARGOCD_ENDPOINT="${MINIKUBE_IP}:${ARGOCD_NODE_PORT}"

GITLAB_PASS=$(kubectl get secret gitlab-gitlab-initial-root-password \
 -n "${GITLAB_NAMESPACE}" \
 -o jsonpath='{.data.password}' | base64 --decode)

ARGOCD_PASS=$(kubectl get secret argocd-initial-admin-secret \
 -n "${ARGOCD_NAMESPACE}" \
 -o jsonpath='{.data.password}' | base64 --decode)

success "Minikube IP       : ${MINIKUBE_IP}"
success "GitLab URL        : ${GITLAB_URL}"
success "ArgoCD endpoint   : https://${ARGOCD_ENDPOINT}"

# =============================================================================
#  STEP 2 — Test GitLab reachability from the host
# =============================================================================
banner "Step 2 · Test GitLab reachability"

log "Checking GitLab health endpoint..."
HTTP_STATUS=$(curl -s -o /dev/null -w "%{http_code}" \
 --max-time 10 "${GITLAB_URL}/-/health" || true)

if [[ "${HTTP_STATUS}" == "200" ]]; then
 success "GitLab is reachable (HTTP ${HTTP_STATUS})."
else
 warn "GitLab health check returned HTTP ${HTTP_STATUS}."
 warn "nip.io DNS may be flaky. Will also register the internal ClusterIP URL for ArgoCD."
fi

# =============================================================================
#  STEP 3 — Create a GitLab Personal Access Token via Rails runner
# =============================================================================
banner "Step 3 · Create GitLab Personal Access Token"

# GitLab 14+ removed the OAuth Resource Owner Password Credentials grant,
# so the only reliable headless method is the Rails runner inside the
# toolbox (task-runner) pod — this is the officially supported admin approach.

log "Finding GitLab toolbox pod..."
TOOLBOX_POD=$(kubectl get pod -n "${GITLAB_NAMESPACE}" \
 -l "app=toolbox" \
 -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)

# Fallback label used in older chart versions
if [[ -z "${TOOLBOX_POD}" ]]; then
 TOOLBOX_POD=$(kubectl get pod -n "${GITLAB_NAMESPACE}" \
  -l "app=task-runner" \
  -o jsonpath='{.items[0].metadata.name}' 2>/dev/null || true)
fi

[[ -n "${TOOLBOX_POD}" ]] ||
 error "Could not find GitLab toolbox/task-runner pod in namespace '${GITLAB_NAMESPACE}'."
success "Toolbox pod: ${TOOLBOX_POD}"

log "Creating PAT 'argocd-token' via Rails runner (idempotent)..."
GITLAB_PAT=$(kubectl exec -n "${GITLAB_NAMESPACE}" "${TOOLBOX_POD}" -- \
 gitlab-rails runner "
    user  = User.find_by_username('${GITLAB_USER}')
    token = user.personal_access_tokens.find_by(name: 'argocd-token')
    if token
      token.revoke!
    end
    new_token = user.personal_access_tokens.create!(
      name:       'argocd-token',
      scopes:     %w[api read_repository write_repository],
      expires_at: 1.year.from_now
    )
    puts new_token.token
  " 2>/dev/null | tail -1)

[[ -n "${GITLAB_PAT}" && "${GITLAB_PAT}" != *"Error"* ]] ||
 error "Rails runner failed to create PAT. Check toolbox pod logs."

success "PAT created: ${GITLAB_PAT}"

# =============================================================================
#  STEP 4 — Create the GitLab project
# =============================================================================
banner "Step 4 · Create GitLab project '${PROJECT_NAME}'"

log "Creating project '${PROJECT_NAME}'..."
PROJECT_RESPONSE=$(curl -s --request POST \
 "${GITLAB_URL}/api/v4/projects" \
 --header "PRIVATE-TOKEN: ${GITLAB_PAT}" \
 --data "name=${PROJECT_NAME}&visibility=private&initialize_with_readme=true")

PROJECT_ID=$(echo "${PROJECT_RESPONSE}" | jq -r '.id // empty')
REPO_HTTP_URL=$(echo "${PROJECT_RESPONSE}" | jq -r '.http_url_to_repo // empty')

if [[ -z "${PROJECT_ID}" ]]; then
 # Project may already exist — look it up
 warn "Project may already exist. Attempting to fetch existing project..."
 EXISTING=$(curl -s \
  --header "PRIVATE-TOKEN: ${GITLAB_PAT}" \
  "${GITLAB_URL}/api/v4/projects?search=${PROJECT_NAME}&owned=true")
 PROJECT_ID=$(echo "${EXISTING}" | jq -r --arg n "${PROJECT_NAME}" \
  '.[] | select(.name==$n) | .id' | head -1)
 REPO_HTTP_URL=$(echo "${EXISTING}" | jq -r --arg n "${PROJECT_NAME}" \
  '.[] | select(.name==$n) | .http_url_to_repo' | head -1)
 [[ -n "${PROJECT_ID}" ]] || error "Could not create or find project '${PROJECT_NAME}'."
fi

success "Project ID        : ${PROJECT_ID}"
success "Repo URL          : ${REPO_HTTP_URL}"

# Build the authenticated clone URL (embed PAT as password)
CLONE_URL="http://${GITLAB_USER}:${GITLAB_PAT}@gitlab.${MINIKUBE_IP}.nip.io/${GITLAB_USER}/${PROJECT_NAME}.git"

# =============================================================================
#  STEP 5 — Populate the repo with example Kubernetes manifests
# =============================================================================
banner "Step 5 · Push example guestbook manifests"

rm -rf "${WORK_DIR}"
mkdir -p "${WORK_DIR}"
cd "${WORK_DIR}"

log "Cloning ${PROJECT_NAME} repo..."
git clone "${CLONE_URL}" "${PROJECT_NAME}"
cd "${PROJECT_NAME}"

git config user.email "argocd-setup@example.com"
git config user.name "ArgoCD Setup"

mkdir -p manifests

cat >manifests/namespace.yaml <<'EOF'
apiVersion: v1
kind: Namespace
metadata:
  name: guestbook
EOF

cat >manifests/deployment.yaml <<'EOF'
apiVersion: apps/v1
kind: Deployment
metadata:
  name: guestbook
  namespace: guestbook
spec:
  replicas: 2
  selector:
    matchLabels:
      app: guestbook
  template:
    metadata:
      labels:
        app: guestbook
    spec:
      containers:
      - name: guestbook
        image: gcr.io/google-samples/gb-frontend:v5
        ports:
        - containerPort: 80
        resources:
          requests:
            cpu: "50m"
            memory: "64Mi"
          limits:
            cpu: "200m"
            memory: "128Mi"
EOF

cat >manifests/service.yaml <<'EOF'
apiVersion: v1
kind: Service
metadata:
  name: guestbook
  namespace: guestbook
spec:
  type: NodePort
  selector:
    app: guestbook
  ports:
  - port: 80
    targetPort: 80
EOF

git add .

if git diff --cached --quiet; then
 warn "No changes to commit — manifests already up to date in repo."
else
 git commit -m "Add guestbook Kubernetes manifests"
 git push origin HEAD
 success "Manifests pushed to GitLab."
fi

cd "${WORK_DIR}"

# =============================================================================
#  STEP 6 — Log in to ArgoCD CLI
# =============================================================================
banner "Step 6 · ArgoCD CLI login"

log "Logging in to ArgoCD at ${ARGOCD_ENDPOINT}..."
argocd login "${ARGOCD_ENDPOINT}" \
 --username admin \
 --password "${ARGOCD_PASS}" \
 --insecure \
 --grpc-web
success "ArgoCD CLI logged in."

# =============================================================================
#  STEP 7 — Register the GitLab repo in ArgoCD
# =============================================================================
banner "Step 7 · Register GitLab repo in ArgoCD"

# Prefer the external nip.io URL; ArgoCD's repo-server resolves this via the
# minikube node IP. Fall back to internal ClusterIP if the host check failed.
if [[ "${HTTP_STATUS}" == "200" ]]; then
 ARGOCD_REPO_URL="http://gitlab.${MINIKUBE_IP}.nip.io/${GITLAB_USER}/${PROJECT_NAME}.git"
else
 warn "Using internal ClusterIP URL for ArgoCD repo registration."
 ARGOCD_REPO_URL="${GITLAB_INTERNAL_URL}/${GITLAB_USER}/${PROJECT_NAME}.git"
fi

log "Registering repo: ${ARGOCD_REPO_URL}"

# Remove stale entry if it exists
argocd repo rm "${ARGOCD_REPO_URL}" 2>/dev/null || true

argocd repo add "${ARGOCD_REPO_URL}" \
 --username "${GITLAB_USER}" \
 --password "${GITLAB_PAT}" \
 --insecure-skip-server-verification

log "Verifying connection status..."
argocd repo list
success "Repo registered."

# =============================================================================
#  STEP 8 — Create & sync the ArgoCD Application
# =============================================================================
banner "Step 8 · Create ArgoCD Application '${PROJECT_NAME}'"

# Remove existing app if present (idempotent re-runs)
argocd app delete "${PROJECT_NAME}" --yes 2>/dev/null || true

argocd app create "${PROJECT_NAME}" \
 --repo "${ARGOCD_REPO_URL}" \
 --path manifests \
 --dest-server https://kubernetes.default.svc \
 --dest-namespace "${APP_NAMESPACE}" \
 --sync-policy automated \
 --auto-prune \
 --self-heal \
 --revision HEAD

log "Triggering initial sync..."
argocd app sync "${PROJECT_NAME}"

log "Waiting for application to become Healthy..."
argocd app wait "${PROJECT_NAME}" \
 --health \
 --timeout 120 ||
 warn "App did not reach Healthy within 120s — check: argocd app get ${PROJECT_NAME}"

success "Application '${PROJECT_NAME}' is synced and healthy."

# =============================================================================
#  STEP 9 — Verify the app pods are running
# =============================================================================
banner "Step 9 · Verify deployment"

kubectl get pods -n "${APP_NAMESPACE}"
GUESTBOOK_NODE_PORT=$(kubectl get svc "${PROJECT_NAME}" \
 -n "${APP_NAMESPACE}" \
 -o jsonpath='{.spec.ports[0].nodePort}' 2>/dev/null || echo "N/A")

# =============================================================================
#  Summary
# =============================================================================
banner "🎉  Setup Complete!"
echo -e "  ${BOLD}GitLab URL:${RESET}          ${CYAN}${GITLAB_URL}${RESET}"
echo -e "  ${BOLD}GitLab user:${RESET}         ${GITLAB_USER}"
echo -e "  ${BOLD}GitLab PAT:${RESET}          ${YELLOW}${GITLAB_PAT}${RESET}"
echo ""
echo -e "  ${BOLD}ArgoCD URL:${RESET}          ${CYAN}https://${ARGOCD_ENDPOINT}${RESET}"
echo -e "  ${BOLD}ArgoCD user:${RESET}         admin"
echo -e "  ${BOLD}ArgoCD password:${RESET}     ${YELLOW}${ARGOCD_PASS}${RESET}"
echo ""
echo -e "  ${BOLD}App namespace:${RESET}       ${APP_NAMESPACE}"
echo -e "  ${BOLD}Guestbook URL:${RESET}       ${CYAN}http://${MINIKUBE_IP}:${GUESTBOOK_NODE_PORT}${RESET}"
echo ""
echo -e "  ${BOLD}GitOps loop — make a change and watch ArgoCD sync:${RESET}"
echo -e "  ${CYAN}cd ${WORK_DIR}/${PROJECT_NAME}${RESET}"
echo -e "  ${CYAN}# edit a manifest, then:${RESET}"
echo -e "  ${CYAN}git add . && git commit -m 'my change' && git push${RESET}"
echo -e "  ${CYAN}argocd app sync ${PROJECT_NAME}   # or wait ~3min for auto-sync${RESET}"
echo ""
echo -e "  ${BOLD}Useful commands:${RESET}"
echo -e "  kubectl get pods -n ${APP_NAMESPACE}"
echo -e "  argocd app get ${PROJECT_NAME}"
echo -e "  argocd app history ${PROJECT_NAME}"
echo ""
