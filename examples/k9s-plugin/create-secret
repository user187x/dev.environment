#!/bin/bash

# If arguments are missing, assume the user is running this manually to install it
if [ -z "$1" ] && [ -z "$2" ]; then

 SCRIPT_FILE_PATH=$(realpath "${BASH_SOURCE[0]}")

 K9_PLUGIN_FILE_PATH="$HOME/.config/k9s/plugin.yml"
 K9_PLUGIN_DIR=$(dirname "$K9_PLUGIN_FILE_PATH")

 PLUGIN_NAME="create-interactive-secret"
 PLUGIN_ID="46a857cd-b1a2-4de2-b881-0d55d5af4c13"

 if [[ ! -d "$K9_PLUGIN_DIR" ]]; then
  mkdir -p "$K9_PLUGIN_DIR"
 fi

 # Ensure plugin.yml exists with root key
 if [[ ! -f "$K9_PLUGIN_FILE_PATH" ]]; then
  echo "plugins:" >"$K9_PLUGIN_FILE_PATH"
 fi

 # Check and insert safely
 if grep -q "[[:space:]]*$PLUGIN_NAME:" "$K9_PLUGIN_FILE_PATH"; then
  echo "✅ The plugin '$PLUGIN_NAME' already exists in $K9_PLUGIN_FILE_PATH."
 else
  echo "⚙️ Plugin '$PLUGIN_NAME' not found. Inserting..."
  # Notice the >> to append, and \$ to escape k9s variables
  cat <<EOF >>"$K9_PLUGIN_FILE_PATH"
  # Plugin ID: $PLUGIN_ID
  $PLUGIN_NAME:
    shortCut: Shift-S
    description: "Create Secret Interactively"
    scopes:
      - all
    command: bash
    background: false
    args:
      - -c
      - "$SCRIPT_FILE_PATH \$NAMESPACE \$CONTEXT"
EOF
  echo "🎉 Installation complete! You can now use Shift-S in k9s."
 fi
 exit 0
fi

# --- 2. SECRET CREATION LOGIC (Triggered by k9s) ---
CURRENT_NS=$1
CONTEXT=$2

SECRET_NAME=$(whiptail --inputbox "Enter Secret Name:" 10 50 --title "1/5: Secret Name" 3>&1 1>&2 2>&3)
if [ -z "$SECRET_NAME" ]; then exit 0; fi

NAMESPACE=$(whiptail --inputbox "Enter Namespace:" 10 50 "$CURRENT_NS" --title "2/5: Namespace" 3>&1 1>&2 2>&3)
if [ -z "$NAMESPACE" ]; then exit 0; fi

SECRET_TYPE=$(whiptail --menu "Select Secret Type:" 15 50 4 \
 "generic" "Standard Opaque secret" \
 "tls" "TLS certificate and key" \
 --title "3/5: Secret Type" 3>&1 1>&2 2>&3)
if [ -z "$SECRET_TYPE" ]; then exit 0; fi

CMD="kubectl create secret $SECRET_TYPE $SECRET_NAME -n $NAMESPACE --context $CONTEXT"

if [ "$SECRET_TYPE" = "generic" ]; then
 SOURCE_TYPE=$(whiptail --menu "Select Value Source:" 15 50 4 \
  "literal" "Direct key=value pairs" \
  "from-file" "From a specific file" \
  "from-env-file" "From an environment file" \
  --title "4/5: Value Source" 3>&1 1>&2 2>&3)

 if [ -z "$SOURCE_TYPE" ]; then exit 0; fi

 if [ "$SOURCE_TYPE" = "literal" ]; then
  while true; do
   KV=$(whiptail --inputbox "Enter 'key=value' (or leave blank and press Enter to finish):" 10 60 --title "5/5: Add Literal Value" 3>&1 1>&2 2>&3)
   if [ -z "$KV" ]; then break; fi
   CMD="$CMD --from-literal='$KV'"
  done
 elif [ "$SOURCE_TYPE" = "from-file" ]; then
  FILE_PATH=$(whiptail --inputbox "Enter absolute file path:" 10 60 "/path/to/file" --title "5/5: Add File" 3>&1 1>&2 2>&3)
  if [ -n "$FILE_PATH" ]; then
   CMD="$CMD --from-file='$FILE_PATH'"
  fi
 elif [ "$SOURCE_TYPE" = "from-env-file" ]; then
  FILE_PATH=$(whiptail --inputbox "Enter absolute env file path:" 10 60 "/path/to/.env" --title "5/5: Add Env File" 3>&1 1>&2 2>&3)
  if [ -n "$FILE_PATH" ]; then
   CMD="$CMD --from-env-file='$FILE_PATH'"
  fi
 fi
elif [ "$SECRET_TYPE" = "tls" ]; then
 CERT=$(whiptail --inputbox "Enter absolute path to TLS Cert file (.pem/.crt):" 10 60 --title "4/5: TLS Certificate" 3>&1 1>&2 2>&3)
 KEY=$(whiptail --inputbox "Enter absolute path to TLS Key file (.key):" 10 60 --title "5/5: TLS Key" 3>&1 1>&2 2>&3)
 if [ -n "$CERT" ] && [ -n "$KEY" ]; then
  CMD="$CMD --cert='$CERT' --key='$KEY'"
 fi
fi

whiptail --yesno "Execute the following command?\n\n$CMD" 15 70 --title "Confirm Execution"
if [ $? -eq 0 ]; then
 clear
 echo "Executing: $CMD"
 echo "-----------------------------------"
 eval "$CMD"
 echo "-----------------------------------"
 echo "Press any key to return to k9s..."
 read -n 1
else
 clear
 echo "Operation cancelled. Press any key to return to k9s..."
 read -n 1
fi
