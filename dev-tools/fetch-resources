#!/bin/bash

PROJECT="$PWD/resources"

function list-resources {

 count=$(ls -1 "$PROJECT" | wc -l)

 if (( count == 0 )); then
  echo "No resources"
 else
  for resource in "$PROJECT/"*; do
   file_name=$(basename "$resource")
   echo "$file_name"
  done
 fi
}

if [[ -d "$PROJECT" ]]; then
 list-resources
else
 git clone git@github.com:user187x/resources.git
 list-resources
fi
