#!/bin/bash

# ==========================================
# Setup & Configuration
# ==========================================

# strict mode: exit on error, undefined vars, or pipe failures
set -euo pipefail

# Global Constants
readonly DEV_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

readonly XDG_DATA_HOME="$HOME/.local/share"
readonly XDG_CONFIG_HOME="$HOME/.config"
readonly XDG_CACHE_HOME="$HOME/.cache"

readonly FONT_DIR="$XDG_DATA_HOME/fonts"
readonly TMUX_DIR="$XDG_CONFIG_HOME/tmux"
readonly AUDIO_DIR="$XDG_DATA_HOME/audio"

# Colors for logging
readonly END='\e[0m'
readonly GREEN='\e[32m'
readonly BLUE='\e[34m'
readonly PURPLE='\e[35m'
readonly YELLOW='\e[33m'
readonly RED='\e[31m'
readonly GRAY='\e[90m'
readonly WHITE='\e[97m'
readonly BRIGHT_YELLOW='\e[93m'

# ==========================================
# Utility Functions
# ==========================================

link_resource() {

 local src="$1"
 local dest="$2"

 local dest_dir=$(dirname "$dest")
 mkdir -p "$dest_dir"

 if [[ -e "$dest" || -L "$dest" ]]; then
  rm -rf "$dest"
 fi

 ln -s "$src" "$dest"
 echo -e "${WHITE}Linked${END}: ${BLUE}$dest${END} -> ${GREEN}$src${END}"
}

install_fonts() {

 echo -e "Installing fonts..."

 # Ensure destination directory exists
 mkdir -p "$FONT_DIR"

 echo -e "${GRAY}"
 tar -xvf "$DEV_HOME/resources/fonts/fonts.tar" -C "$FONT_DIR"
 echo -e "${END}"

 if command -v fc-cache &>/dev/null; then
  fc-cache -f
  echo -e "${WHITE}Font cache updated.${END}"
 else
  echo -e "${YELLOW}fc-cache not found, attempting to install...${END}"
  if sudo apt install fc-cache &> /dev/null; then
   fc-cache -f
  fi
 fi
}

install_resources() {

 echo
 echo -e "${WHITE}Installing resources...${END}"

 local SRC="$DEV_HOME/resources/media/audio"
 local DST="$AUDIO_DIR"
 mkdir -p "$DST"

 # Copy content and fix permissions
 sudo cp -rfT "$SRC" "$DST"
 sudo chown -R "$USER:$USER" "$DST"
 
 echo -e "Audio resources installed to ${GREEN}$DST${END}"
}

setup_tmux() {

 echo -e "${GRAY}Configuring Tmux...${END}"

 # Link the main configuration directory
 link_resource "$DEV_HOME/tmux" "$TMUX_DIR"

 # Initialize TPM (Tmux Plugin Manager)
 local TPM_INSTALL_SCRIPT="$TMUX_DIR/plugins/tpm/bin/install_plugins"

 if [[ -x "$TPM_INSTALL_SCRIPT" ]]; then
  echo -e "Running Tmux Plugin Manager installer..."
  # Running inside a subshell to avoid directory changing side-effects
  ("$TPM_INSTALL_SCRIPT")
 else
  echo -e "${YELLOW}TPM installer not found at $tpm_install_script${END}"
 fi
}

configure_bash() {

 echo -e "Configuring Bash..."

 local DOT_FILE_SRC="$DEV_HOME/dot-files"
 declare -A DOT_FILES

 DOT_FILES["aliases"]=".bash_aliases"
 DOT_FILES["completions"]=".bash_completions"
 DOT_FILES["bashrc"]=".bashrc"

 # Link dot files to user's $HOME directory
 for FILE in "${!DOT_FILES[@]}"; do

  SRC="$DOT_FILE_SRC/$FILE"
  DST="$HOME/.${DOT_FILE[$FILE]}"

  link_resource "$SRC" "$DST"

 done
 
 echo "Completed linking bash resources"
 echo

 local SOURCE_FILES=("packages" "function")

 for FILE in "${SOURCE_FILES[@]}"; do
  source 
 done

 source "$HOME/.bashrc"
}

# ==========================================
# Main Execution
# ==========================================

main() {

 echo
 echo -e "${GRAY}Initializing Dev Environment${END}"
 echo

 if [ -z "$DISPLAY" ]; then
  echo "Running headless"
 else
  zenity --question \
   --title="Confirmation" \
   --text="Installing environment. Continue?" > /dev/null 2>&1
 fi

 # Ensure sudo permissions upfront to prevent timeout
 sudo -v

 # Safety check for running Tmux
 if [[ -n "${TMUX:-}" ]]; then
  echo -e "${RED}Terminate Tmux before proceeding${END}"
 fi

 install_fonts
 install_resources

 setup_bash
 
 echo -e "Configuring Vim..."
 link_resource "$DEV_HOME/vim" "$HOME/.vim"

 setup_tmux

 echo -e "Reloading shell configuration..."
 source "$HOME/.bashrc" || true

 echo
 echo -e "${GRAY}Setup Complete!${END}"
 echo
 echo -e "${WHITE} ⚠️  Restart Terminal ⚠️  ${END}"
 echo
}

# Execute
main "$@"
