#!/bin/bash

# strict mode exit on error
#set -euo pipefail

# global constants
DEV_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# system resource directories
DATA_HOME="${XDG_DATA_HOME:-$HOME/.local/share}"
CACHE_HOME="${XDG_CACHE_HOME:-$HOME/.local/cache}"
CONFIG_HOME="${XDG_CONIG_HOME:-$HOME/.config}"

# Used to store .bash_functions .bash_aliases and .bash_completions
BASH_CONFIG_HOME="$CONFIG_HOME/bash"

declare -A RESOURCE_PATH

# resource source definitions
RESOURCE_PATH["DEV_SOFTWARE"]="$DEV_HOME/resources/software"
RESOURCE_PATH["FONT_SRC"]="$DEV_HOME/resources/fonts"
RESOURCE_PATH["AUDIO_SRC"]="$DEV_HOME/resources/media/audio"
RESOURCE_PATH["VIM_SRC"]="${RESOURCE_PATH[DEV_SOFTWARE]}/vim"
RESOURCE_PATH["TMUX_SRC"]="${RESOURCE_PATH[DEV_SOFTWARE]}/tmux"
RESOURCE_PATH["BASH_CONFIG_SRC"]="${RESOURCE_PATH[DEV_SOFTWARE]}/bash"
RESOURCE_PATH["PKG_SCRIPT"]="${RESOURCE_PATH[BASH_CONFIG_SRC]}/packages"
RESOURCE_PATH["BASHRC_SRC"]="${RESOURCE_PATH[BASH_CONFIG_SRC]}/bashrc"

# resource destination definitions
RESOURCE_PATH["VIM_DST"]="$HOME/.vim"
RESOURCE_PATH["BASHRC_DST"]="$HOME/.bashrc"
RESOURCE_PATH["AUDIO_DST"]="${DATA_HOME}/audio"
RESOURCE_PATH["FONT_DST"]="${DATA_HOME}/fonts"
RESOURCE_PATH["TMUX_DST"]="${CONFIG_HOME}/tmux"
RESOURCE_PATH["TPM_SCRIPT"]="${RESOURCE_PATH[TMUX_DST]}/plugins/tpm/bin/install_plugins"

# exports
DEV_HOME_EXPORT="DEV_HOME"
BASH_CONFIG_HOME_EXPORT="BASH_CONFIG_HOME"

# Colors for logging
GREEN='\e[92m'
BLUE='\e[34m'
PURPLE='\e[35m'
YELLOW='\e[93m'
RED='\e[91m'
GRAY='\e[90m'
WHITE='\e[97m'
END='\e[0m'

WARN="(${YELLOW}*${END})"
INFO="(${WHITE}i${END})"
ERROR="(${RED}!${END})"
QESTN="(${BLUE}?${END})"

# ==========================================
# Utility Functions
# ==========================================

preflight_check() {

 echo
 echo -e "$INFO Checking referential integrity..."
 echo

 for RESOURCE in "${!RESOURCE_PATH[@]}"; do
  if [[ ! -x "${RESOURCE_PATH[$RESOURCE]}" ]]; then
   echo -e "$ERROR Resource not found: ${YELLOW}$RESOURCE${END}=${WHITE}${RESOURCE_PATH[$RESOURCE]}${END}"
  fi
 done

 # Ensure sudo permissions upfront to prevent timeout
 sudo -v

 echo
 echo -e "${GRAY}Initializing Dev Environment${END}"
 echo

 configure_bash

}

link_resource() {

 local SRC_RESOURCE="$1"
 local DST_RESOURCE="$2"

 local DST_PATH=$(dirname "$DST_RESOURCE")
 echo -e "${INFO} Ensuring path integrity: ${GRAY}${DST_PATH}${END}"
 mkdir -p "$DST_PATH"

 echo -e "${INFO} Removing/Unlinking any existing resources: ${WHITE}${DST_PATH}${END}"
 if [[ -e "$DST_RESOURCE" || -L "$DST_RESOURCE" ]]; then
  rm -rf "$DST_RESOURCE"
 fi

 ln -s "$SRC_RESOURCE" "$DST_RESOURCE"
 echo -e "${INFO} ${GREEN}Linked${END}: ${WHITE}${DST_RESOURCE}${END} -> ${GREEN}${SRC_RESOURCE}${END}"
}

install_fonts() {

 echo -e "Installing fonts..."

 # Ensure destination directory exists
 echo -e "${GRAY}Ensuring desitination path exists :${END} ${WHITE} ${RESOURCE_PATH[FONT_DST]} ${END}"
 mkdir -p "${RESOURCE_PATH[FONT_DST]}"

 echo -e "${GRAY}"
 tar -xvf "${RESOURCE_PATH[FONT_SRC]}/fonts.tar" -C "${RESOURCE_PATH[FONT_DST]}"
 echo -e "${END}"

 if command -v fc-cache &>/dev/null; then
  fc-cache -f
  echo -e "${WHITE}Font cache updated.${END}"
 else
  echo -e "${YELLOW}fc-cache not found, attempting to install...${END}"
  if sudo apt install fc-cache &>/dev/null; then
   fc-cache -f
  fi
 fi
}

install_resources() {

 echo
 echo -e "${WHITE}Installing resources...${END}"

 echo -e "${GRAY}Ensuring desitination path exists :${END} ${WHITE} ${RESOURCE_PATH[AUDIO_DST]} ${END}"
 mkdir -p "${RESOURCE_PATH[AUDIO_DST]}"

 # Copy content and fix permissions
 sudo cp -rfT "${RESOURCE_PATH[AUDIO_SRC]}" "${RESOURCE_PATH[AUDIO_DST]}"
 sudo chown -R "$USER:$USER" "${RESOURCE_PATH[AUDIO_DST]}"

 echo -e "$INFO Audio resources installed to ${GREEN}${RESOURCE_PATH[AUDIO_DST]}${END}"
}

setup_tmux() {

 echo -e "${GRAY}Configuring Tmux...${END}"

 # Link the main configuration directory
 link_resource "${RESOURCE_PATH[TMUX_SRC]}" "${RESOURCE_PATH[TMUX_DST]}"

 if [[ -x "${RESOURCE_PATH[TPM_SCRIPT]}" ]]; then

  echo -e "$INFO Running Tmux Plugin-Manager installation..."

  # Running inside a subshell to avoid directory changing side-effects
  ("${RESOURCE_PATH[TPM_SCRIPT]}")
 else
  echo -e "$ERROR TPM installer not found at path: ${RESOURCE_PATH[TPM_SCRIPT]}"
  exit 1
 fi
}

setup_vim() {

 echo -e "$INFO ${GRAY}Configuring Vim...${END}"
 link_resource "${RESOURCE_PATH[VIM_SRC]}" "${RESOURCE_PATH[VIM_DST]}"
}

configure_bash() {

 echo -e "$INFO ${GRAY}Configuring Bash...${END}"

 BASH_CONFIG_FILES=(".bash_functions" ".bash_aliases" ".bash_completions")

 for file in "${BASH_CONFIG_FILES[@]}"; do
  echo "Unlinking previous bash config file ${file}"
  unlink "${BASH_CONFIG_HOME}/${file}" > /dev/null 2>&1
 done

 echo "Unlinking any existing .bashrc"
 unlink "${RESOURCE_PATH[BASHRC_DST]}" > /dev/null 2>&1
 echo "Unlink complete!"

 echo "Relinking new .bashrc"
 ln -s "${RESOURCE_PATH[BASHRC_SRC]}"  "${RESOURCE_PATH[BASHRC_DST]}" 
 
 # Adding DEV_HOME export to .bashrc file
 if ! grep "${DEV_HOME_EXPORT}" "${RESOURCE_PATH[BASHRC_DST]}" >/dev/null 2>&1; then

  echo -e "$INFO Adding ${GREEN}${DEV_HOME_EXPORT}${END} export to ${RESOURCE_PATH[BASHRC_DST]}"
  EXPORT_STMT="${DEV_HOME_EXPORT}=\"${DEV_HOME}\""
  
  {
    echo
    echo "# Path to dev.environment directory"
    echo "${EXPORT_STMT}"

  } >> "${RESOURCE_PATH[BASHRC_DST]}"

 fi

 # Adding bash references in the users .bashrc file
 if ! grep "${BASH_CONFIG_HOME_EXPORT}" "${RESOURCE_PATH[BASHRC_DST]}" >/dev/null 2>&1; then

  echo -e "$INFO Adding ${GREEN}${BASH_CONFIG_HOME_EXPORT}${END} export to ${RESOURCE_PATH[BASHRC_DST]}"
  EXPORT_STMT="${BASH_CONFIG_HOME_EXPORT}=\"${RESOURCE_PATH[BASH_CONFIG_SRC]}"

  {
   echo 
   echo "# Path to bash resource home directory"
   echo "${EXPORT_CMD}"

  } >> "${RESOURCE_PATH[BASHRC_DST]}"

 fi

 declare -A BASH_CONFIG_MAPPER

 BASH_CONFIG_MAPPER["aliases"]=".bash_aliases"
 BASH_CONFIG_MAPPER["functions"]=".bash_functions"
 BASH_CONFIG_MAPPER["completions"]=".bash_completions"

 # Link dot files to user's $HOME directory
 for FILE in "${!BASH_CONFIG_MAPPER[@]}"; do

  RESOURCE_FILE="${RESOURCE_PATH[BASH_CONFIG_SRC]}/${FILE}"

  if [[ ! -f "${RESOURCE_FILE}" ]]; then
   echo -e "$ERROR Failure referencing source file: ${YELLOW}${RESOURCE_FILE}${END}"
   exit 1
  fi

  RESOURCE_DST="${HOME}/${BASH_CONFIG_MAPPER[$FILE]}"

  link_resource "${RESOURCE_FILE}" "${RESOURCE_DST}"

  echo -e "$INFO Sourcing script ${BLUE}${RESOURCE_DST}${END}"
  source "${RESOURCE_DST}"

 done

 echo "Completed linking bash resources"
 echo

 echo -e "Creating ${YELLOW}source${END} and ${YELLOW}export${END} entries in users .bashrc"

 for FILE in "${!BASH_CONFIG_MAPPER[@]}"; do

  # Using the existing var path and building upon it
  BASH_CONFIG_FILE="\$${BASH_CONFIG_HOME_EXPORT}/${BASH_CONFIG_MAPPER[$FILE]}"

  if ! grep "source ${BASH_CONFIG_FILE}" "${RESOURCE_PATH[BASHRC_DST]}" >/dev/null 2>&1; then

   echo -e "$INFO ${GRAY}Adding source entry${END} ${YELLOW}$BASH_CONFIG_FILE${END} ${GRAY}to bashrc${END}"

   {
    echo "# path to dev defined reource $file"
    echo "source ${BASH_CONFIG_FILE}"

   } >> "${RESOURCE_PATH[BASHRC_DST]}"

  fi
 done

 if [[ ! -f "${RESOURCE_PATH[PKG_SCRIPT]}" ]]; then
  echo -e "$ERROR Resource '${YELLOW}${RESOURCE_PATH[PKG_SCRIPT]}${END}' was missing. Terminating..."
  exit 1
 else
  echo -e "$INFO Package script '${BLUE}${RESOURCE_PATH[PKG_SCRIPT]}${END}' found!"

  # Execute the script to install packages
  ${RESOURCE_PATH["PKG_SCRIPT"]}

 fi
}

# ==========================================
# Main Execution
# ==========================================

main() {

 preflight_check

 install_fonts
 install_resources

 configure_bash

 setup_vim
 setup_tmux

 echo -e "Reloading shell configuration..."
 source "${RESOURCE_PATH[BASHRC_DST]}" || true

 echo
 echo -e "${GRAY}Setup Complete!${END}"
 echo
 echo -e "${WHITE} ⚠️  Restart Terminal ⚠️  ${END}"
 echo
}

# Execute
main "$@"
