#!/bin/bash

SCRIPT_HOME="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

failed=()
installed=()

# Update repositories
echo "--- 🔄 Updating Package Lists ---"
if sudo apt update -y && sudo apt upgrade -y; then
 echo "Update successful."
else
 echo -e "\e[1;91mUpdate failed.\e[0m"
fi

# List of tools (Binary:Package or just Package)
packages=(
 "tmux"
 "vim"
 "bat"
 "curl"
 "wget"
 "openssl"
 "btop"
 "pluma"
 "gedit"
 "colordiff"
 "tty-clock"
 "java:default-jdk"
 "visualvm"
 "lolcat"
 "build-essential"
 "netstat:net-tools"
 "jq"
 "notify-send:libnotify-bin"
 "yq"
 "figlet"
 "toilet"
 "qrencode"
 "python3-segno"
 "tree"
 "whiptail"
 "mpv"
 "duf"
 "fzf"
 "gparted"
 "chromium"
 "inotify-tools"
 "fastfetch"
 "flatpak"
 "gnome-software-plugin-flatpak"
 "imagemagick"
 "zenity"
 "pipx"
 "npm"
 "nodejs:node"
 "tigervnc-common"
 "tigervnc-viewer"
 "tigervnc-tools"
 "tigervnc-standalone-server"
 "pv"
 "git"
 "delta:git-delta"
 "thefuck"
 "shfmt"
 "shellcheck"
 "yamllint"
 "expect"
 "xmllint:libxml2-utils"
 "jc"
 "gufw"
 "ranger"
 "mc"
 "cmatrix"
 "sysvbanner"
 "xclip"
 "7zip"
 "unrar"
 "util-linux-extra"
 "gnome-terminal"
 "p7zip-full"
 "file-roller"
 "terminator"
 "ffmpeg"
 "ffmpegthumbnailer"
 "htop"
 "kubecolor"
 "synaptic"
)

echo
echo "--- 📦 Starting APT Package Installation ---"

function install-packages {

 echo ""
 echo "--- 📦 Starting APT Package Installation ---"

 for item in "${packages[@]}"; do
  # Split the string by colon into an array called 'parts'
  IFS=':' read -r -a parts <<<"$item"

  # The first element is always the command/binary to check
  binary="${parts[0]}"

  # The remaining elements are the package names to try
  if [[ ${#parts[@]} -eq 1 ]]; then
   # If there are no colons, the binary name is also the package name
   pkg_variations=("$binary")
  else
   # Slice the array to get everything after the first element
   pkg_variations=("${parts[@]:1}")
  fi

  # 1. Check if binary already exists
  if ! command -v "$binary" >/dev/null 2>&1; then
   echo "Installing $binary..."
   success=false

   # 2. Loop through each package variation and try to install it
   for pkg in "${pkg_variations[@]}"; do
    if sudo apt install "$pkg" -y; then
     echo -e "Tool [\e[1;92m$binary\e[0m] Installed (via '$pkg')"
     installed+=("$binary")
     success=true
     break # Exit the inner loop on success
    else
     echo -e "⚠️ Attempt to install via [\e[1;93m$pkg\e[0m] failed. Trying next..."
    fi
   done

   # 3. If the loop finished and success is still false, it failed completely
   if [ "$success" = false ]; then
    echo -e "Tool [\e[1;91m$binary\e[0m] failed to install completely."
    failed+=("$binary")
   fi
  else
   echo -e "Tool [\e[1;92m$binary\e[0m] already installed"
   installed+=("$binary")
  fi
 done
}

# Install packages begins here
install-packages

echo
echo "--- 🚀 Starting Custom Installations ---"

# Add flatpak repo
echo "Adding any necessary flatpak repositories"
flatpak remote-add --if-not-exists flathub https://dl.flathub.org/repo/flathub.flatpakrepo

function install-helm {
 # 1. Detect OS and Architecture
 local OS
 OS=$(uname -s | tr '[:upper:]' '[:lower:]')

 local ARCH
 ARCH=$(uname -m)

 # Map architecture to Helm's naming convention
 if [ "$ARCH" = "x86_64" ]; then
  ARCH="amd64"
 elif [ "$ARCH" = "aarch64" ] || [ "$ARCH" = "arm64" ]; then
  ARCH="arm64"
 else
  echo "Error: Unsupported architecture ($ARCH)"
  return 1
 fi

 # 2. Fetch the latest version tag from GitHub API
 echo "Fetching the latest Helm version..."
 local VERSION
 VERSION=$(curl -s https://api.github.com/repos/helm/helm/releases/latest | grep '"tag_name":' | sed -E 's/.*"([^"]+)".*/\1/')

 if [ -z "$VERSION" ]; then
  echo "Error: Failed to fetch the latest version."
  return 1
 fi

 echo "Latest version identified as ${VERSION}."

 # 3. Construct download URL
 local TARBALL="helm-${VERSION}-${OS}-${ARCH}.tar.gz"
 local DOWNLOAD_URL="https://get.helm.sh/${TARBALL}"

 # 4. Create a temporary directory for safe extraction
 local TMP_DIR
 TMP_DIR=$(mktemp -d)

 echo "Downloading ${TARBALL}..."
 if ! curl -fsSL -o "${TMP_DIR}/${TARBALL}" "$DOWNLOAD_URL"; then
  echo "Error: Download failed."
  rm -rf "$TMP_DIR"
  return 1
 fi

 echo "Extracting archive..."
 tar -zxvf "${TMP_DIR}/${TARBALL}" -C "$TMP_DIR" >/dev/null

 # 5. Move the binary to a directory in your PATH (requires sudo)
 echo "Installing Helm to /usr/local/bin/ (you may be prompted for your password)..."
 if sudo mv "${TMP_DIR}/${OS}-${ARCH}/helm" /usr/local/bin/helm; then
  sudo chmod +x /usr/local/bin/helm
  echo "✅ Helm ${VERSION} successfully installed!"
 else
  echo "Error: Failed to move the binary. Check your permissions."
 fi

 # 6. Cleanup
 rm -rf "$TMP_DIR"

 # Verify installation
 helm version --short
}

echo "Installing helm..."
if ! command -v helm >/dev/null 2>&1; then
 install-helm
 helm repo add gitlab https://charts.gitlab.io/
 helm repo update
fi

if ! command -v terraform >/dev/null 2>&1; then

 echo "Installing terraform & packer"
 sudo apt install -y gnupg software-properties-common

 # Download and store the GPG key
 wget -O- https://apt.releases.hashicorp.com/gpg |
  gpg --dearmor |
  sudo tee /usr/share/keyrings/hashicorp-archive-keyring.gpg >/dev/null

 # Add the repo with the correct 'noble' codename
 echo "deb [signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] \
    https://apt.releases.hashicorp.com noble main" |
  sudo tee /etc/apt/sources.list.d/hashicorp.list

 sudo apt update && sudo apt install terraform packer
fi

# Install Helm (Script fallback)
if ! command -v helm >/dev/null 2>&1; then
 echo "Installing helm..."
 curl -fsSL -o get_helm.sh https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
 rm get_helm.sh
fi

# Install Docker
if ! command -v docker >/dev/null 2>&1; then

 echo "Installing Docker..."
 sudo apt remove $(dpkg --get-selections docker.io docker-compose docker-compose-v2 docker-doc podman-docker containerd runc | cut -f1)

 # Download and store the GPG key
 curl -fsSL https://download.docker.com/linux/ubuntu/gpg |
  gpg --dearmor |
  sudo tee /usr/share/keyrings/docker-archive-keyring.gpg >/dev/null

 # Add the repo with the correct 'noble' codename
 echo "deb [arch=amd64 signed-by=/usr/share/keyrings/docker-archive-keyring.gpg] \
  https://download.docker.com/linux/ubuntu noble stable" |
  sudo tee /etc/apt/sources.list.d/docker.list

 # Add Docker's official GPG key:
 sudo apt install ca-certificates curl
 sudo install -m 0755 -d /etc/apt/keyrings

 sudo apt install docker-ce docker-ce-cli containerd.io docker-buildx-plugin docker-compose-plugin
 sudo systemctl status docker
 sudo systemctl start docker
 sudo usermod -aG docker "$USER"
 echo "Docker installed. Logout/login required."
fi

# Install system monitor
if ! command -v indicator-multiload >/dev/null 2>&1; then
 echo "Installing indicator-multiload..."
 sudo apt install indicator-multiload -y
fi

# Install shell extensions
if ! command -v gnome-shell-extension-manager >/dev/null 2>&1; then
 echo "Installing gnome-shell-extension-manager..."
 sudo apt install gnome-shell-extension-manager -y
fi

# Install desktop editor
if ! command -v dconf-editor >/dev/null 2>&1; then
 echo "Installing dconf-editor..."
 sudo apt install dconf-editor -y
fi

# Install VS Code
if ! command -v code >/dev/null 2>&1; then
 echo "Installing VS Code..."
 sudo snap install code --classic
fi

# Install Flatpak
if ! command -v flatpak >/dev/null 2>&1; then
 echo "Installing flatpak..."
 sudo apt install flatpak -y
 flatpak remote-add --if-not-exists flathub https://flathub.org/repo/flathub.flatpakrepo
fi

# Install Mission Center
if ! flatpak list 2>/dev/null | grep -q "io.missioncenter.MissionCenter"; then
 echo "Installing MissionCenter..."
 flatpak install flathub io.missioncenter.MissionCenter -y
fi

# Install Sticky Notes
if ! flatpak list 2>/dev/null | grep -q "com.vixalien.sticky"; then
 echo "Installing Sticky Notes..."
 flatpak install flathub com.vixalien.sticky -y
fi

########## LazyDocker #############

if ! command -v lazydocker >/dev/null 2>&1; then
 echo "Installing lazydocker..."
 curl https://raw.githubusercontent.com/jesseduffield/lazydocker/master/scripts/install_update_linux.sh | bash
fi

########## K9s #############

if ! command -v k9s >/dev/null 2>&1; then
 K9S_VERSION="v0.32.5"
 echo "Installing k9s..."
 TMP_DIR=$(mktemp -d)
 curl -L "https://github.com/derailed/k9s/releases/download/${K9S_VERSION}/k9s_Linux_amd64.tar.gz" -o "$TMP_DIR/k9s.tar.gz"
 tar -xzf "$TMP_DIR/k9s.tar.gz" -C "$TMP_DIR"
 sudo install -m 755 "$TMP_DIR/k9s" /usr/local/bin/k9s
 rm -rf "$TMP_DIR"
fi

########## Minikube #############

# Fetch the latest minikube version tag (e.g., v1.32.0)
LATEST_MINIKUBE_VERSION=$(curl -s https://api.github.com/repos/kubernetes/minikube/releases/latest | jq -r .tag_name)

# Helper function to handle the download and install process
install_minikube() {

 echo "Installing minikube ${LATEST_MINIKUBE_VERSION}..."
 curl -LO "https://github.com/kubernetes/minikube/releases/download/${LATEST_MINIKUBE_VERSION}/minikube-linux-amd64"

 sudo install minikube-linux-amd64 /usr/local/bin/minikube
 rm minikube-linux-amd64

 echo "Minikube setup complete!"
}

# Check if minikube is installed
if ! command -v minikube >/dev/null 2>&1; then

 echo "Minikube is not installed."
 install_minikube

else
 # Get the current installed version
 LOCAL_MINIKUBE_VERSION=$(minikube version --short)

 # Compare local version with latest version
 if [ "$LOCAL_MINIKUBE_VERSION" != "$LATEST_MINIKUBE_VERSION" ]; then
  echo "Minikube update available! (Local: $LOCAL_MINIKUBE_VERSION -> Latest: $LATEST_MINIKUBE_VERSION)"
  install_minikube
 else
  echo "Minikube is already up to date ($LOCAL_MINIKUBE_VERSION)."
 fi
fi

########## Kubectl #############

# Fetch the latest kubectl version tag (e.g., v1.30.0)
LATEST_KUBECTL_VERSION=$(curl -L -s https://dl.k8s.io/release/stable.txt)

# Helper function to handle the download and install process
install_kubectl() {
 echo "Installing/Updating kubectl ${LATEST_KUBECTL_VERSION}..."
 curl -LO "https://dl.k8s.io/release/${LATEST_KUBECTL_VERSION}/bin/linux/amd64/kubectl"
 sudo install -o root -g root -m 0755 kubectl /usr/local/bin/kubectl
 rm kubectl
 echo "kubectl setup complete!"
}

# Check if kubectl is installed
if ! command -v kubectl >/dev/null 2>&1; then
 echo "kubectl is not installed."
 install_kubectl
else
 # Get the current installed version
 LOCAL_KUBECTL_VERSION=$(kubectl version --client 2>/dev/null | grep -oE 'v[0-9]+\.[0-9]+\.[0-9]+' | head -n1)

 # Compare local version with latest version
 if [[ "$LOCAL_KUBECTL_VERSION" != "$LATEST_KUBECTL_VERSION" ]]; then
  echo "kubectl update available! (Local: $LOCAL_KUBECTL_VERSION -> Latest: $LATEST_KUBECTL_VERSION)"
  install_kubectl
 else
  echo "kubectl is already up to date ($LOCAL_KUBECTL_VERSION)."
 fi
fi

########## Gnome Settings : Window Centering #############

echo "Configuring GNOME Window settings..."
if command -v gsettings >/dev/null 2>&1; then
 centered=$(gsettings get org.gnome.mutter center-new-windows)
 if [[ "$centered" != "'true'" && "$centered" != "true" ]]; then
  echo "Setting all windows to be centered!"
  gsettings set org.gnome.mutter center-new-windows true
 fi
fi

########## Package Manger : Update packages #############

sudo apt update -y && sudo apt upgrade -y

echo "--- ✨ Setup Complete! ---"
