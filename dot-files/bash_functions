################################################

clean() {
 sudo apt clean
 sudo apt autoclean
 sudo apt remove -y
 sudo apt autoremove -y
 echo -e "${G}Cleanup Complete${NC}\n"
}
export -f clean

update() {
 sudo apt-get update
 sudo apt update && sudo apt upgrade -y
 echo -e "${G}Update Complete!${NC}"
 clean
}
export -f update

# Overrides (Requires 'grc' installed)
# This replaces the redundant 'gdiff' function
if command -v grc >/dev/null; then
 netstat() { grc sudo netstat "$@"; }
 diff() { grc diff "$@"; }
 ping() { grc ping "$@"; }
 head() { grc head "$@"; }
 tail() { grc tail "$@"; }
 mount() { grc mount "$@"; }
 ps() { grc sudo ps "$@"; }
fi

prettyJson() {
 local input="$1"
 if [[ -f "$input" ]]; then
  cat "$input" | jq -C . | less -R
 else
  echo "$input" | jq '.'
 fi
}
export -f prettyJson

spin() {
 local message="$1"
 local delay=0.2
 local spinner="⠋⠙⠹⠸⠼⠴⠦⠧⠇⠏"
 local i=0
 while true; do
  printf "\r%s \033[36m%s\033[0m" "$message" "${spinner:$((i++ % ${#spinner})):1}"
  sleep "$delay"
 done
}
export -f spin

play() {
 if [[ -f "$1" ]]; then
  mpv --no-video "$1"
 elif [[ -d "$1" ]]; then
  local media_files=()
  while IFS= read -r file; do
   media_files+=("$file")
  done < <(find "$1" -type f -iname "*.mp3")

  if [[ "${#media_files[@]}" -ne 0 ]]; then
   echo "Found ${#media_files[@]} MP3s"
   mpv "${media_files[@]}"
  else
   echo "No MP3s found in directory."
  fi
 else
  echo "Usage : play <filePath|dirPath>"
 fi
}
export -f play

# Mirror function
mp3() { play "$@"; }
export -f mp3

search() {
 if [[ -z "$1" ]]; then
  echo "Usage: search <term>"
  return 1
 fi

 local selected_line
 selected_line=$(rg --color=always \
  --line-number \
  --no-heading "$1" |
  fzf --ansi \
   --delimiter=: \
   --nth=1,3.. \
   --preview 'bat --style=numbers --color=always {1} --highlight-line {2} || cat {1}')

 local file_path
 file_path=$(echo "$selected_line" | cut -d: -f1)

 if [[ -n "$file_path" ]]; then
  echo "Selected file : $file_path"
  vim "$file_path"
 fi
}
export -f search

function list-fonts {

 local filter
 local enabled="false"

 # List all avaialable filsters
 local x=$(toilet --filter list)
 local y=$(echo "$x" | awk '{print $1}')
 local z=$(echo "$y" | xargs -I {} bash -c 'f="{}"; echo "${f%?}"')
 local filters=$(echo "$z" | sed '1d')

 # if user entered input
 if [[ ! -z "$1" ]]; then
  filter="$1"
  for filter in "${filters[@]}"; do
   if [[ "$filter" == "$input" ]]; then
    enabled="true"
    break
   fi
  done
 fi

 if [[ "$enabled" != "true" ]]; then
  echo "$filters"
  read -r -p "Choose available filter: " input
  filter="$input"
  enabled="true"
 fi

 counter=0
 for f in /usr/share/figlet/*.[tf]lf; do
  ((counter++))
  font_name=$(basename "${f%.*}")

  if [[ "$enabled" == "true" ]]; then
   toilet -f $font_name --filter "$filter" "Example"
  else
   toilet -f $font_name --gay "Example"
  fi

  echo -e "\e[90mFont :\e[92m$font_name\e[0m"
  modulo=$((counter % 5))
  if [[ "$modulo" -eq 0 ]]; then
   read -r -p "Press any button to continue (or X to exit) " input
   if [[ "$input" =~ ^[xX]$ ]]; then
    return 0
   fi
  fi
 done
}
export -f list-fonts

pki-details() {

 local G='\033[1;92m' R='\033[1;91m' Y='\033[1;93m' B='\033[1;94m' M='\033[3;90m' NC='\033[0m'
 local save_mode=false

 # Helper to get visible width (strips ANSI codes)
 _vwidth() {
  local str=$1
  echo -e "$str" | sed 's/\x1b\[[0-9;]*m//g' | wc -c
 }

 _pki_format() {
  local file="$1"
  [[ ! -s "$file" ]] && return 0

  local type="Unknown" cn="N/A" issued="N/A" expiry="N/A" days_left="N/A" issuer="N/A" sha256="N/A" md5="N/A" color="${B}"
  local protected="${G}No${NC}"
  local abs_path=$(readlink -f "$file" 2>/dev/null || echo "$file")
  local filename=$(basename "$file")

  # 1. Content Detection
  if grep -q "BEGIN PKCS12" "$file" 2>/dev/null || [[ "$file" == *.p12 ]] || [[ "$file" == *.pfx ]]; then
   type="P12 Container"
   color="${Y}"
   if ! openssl pkcs12 -in "$file" -nokeys -passin pass:'' 2>/dev/null >/dev/null; then protected="${R}Yes (Encrypted)${NC}"; fi
   cn=$(openssl pkcs12 -in "$file" -nokeys -passin pass:'' 2>/dev/null | openssl x509 -noout -subject -nameopt RFC2253 2>/dev/null | sed 's/.*CN=\([^,]*\).*/\1/')
   expiry=$(openssl pkcs12 -in "$file" -nokeys -passin pass:'' 2>/dev/null | openssl x509 -noout -dates 2>/dev/null | grep "notAfter" | cut -d= -f2)
   sha256=$(openssl pkcs12 -in "$file" -nokeys -passin pass:'' 2>/dev/null | openssl x509 -noout -fingerprint -sha256 2>/dev/null | cut -d= -f2)
   md5=$(openssl pkcs12 -in "$file" -nokeys -passin pass:'' 2>/dev/null | openssl x509 -noout -fingerprint -md5 2>/dev/null | cut -d= -f2)
  elif grep -q "CERTIFICATE REQUEST" "$file" 2>/dev/null; then
   type="CSR"
   color="${M}"
   cn=$(openssl req -in "$file" -noout -subject -nameopt RFC2253 2>/dev/null | sed 's/.*CN=\([^,]*\).*/\1/')
  elif grep -q "BEGIN CERTIFICATE" "$file" 2>/dev/null; then
   local count=$(grep -c "BEGIN CERTIFICATE" "$file")
   if [[ $count -gt 1 ]]; then
    type="CA Bundle ($count)"
    cn="Multiple Certificates"
    issued="Multiple"
    expiry="Multiple"
    issuer="Multiple"
    days_left="Multiple"
    sha256="Multiple"
    md5="Multiple"
   else
    type="Certificate"
    cn=$(openssl x509 -in "$file" -noout -subject -nameopt RFC2253 2>/dev/null | sed 's/.*CN=\([^,]*\).*/\1/')
    issued=$(openssl x509 -in "$file" -noout -dates 2>/dev/null | grep "notBefore" | cut -d= -f2)
    expiry=$(openssl x509 -in "$file" -noout -dates 2>/dev/null | grep "notAfter" | cut -d= -f2)
    issuer=$(openssl x509 -in "$file" -noout -issuer -nameopt RFC2253 2>/dev/null | sed 's/.*CN=\([^,]*\).*/\1/')
    sha256=$(openssl x509 -in "$file" -noout -fingerprint -sha256 2>/dev/null | cut -d= -f2)
    md5=$(openssl x509 -in "$file" -noout -fingerprint -md5 2>/dev/null | cut -d= -f2)
   fi
  elif grep -q "PRIVATE KEY" "$file" 2>/dev/null; then
   type="Private Key"
   color="${R}"
   cn="[SECRET]"
   if grep -qE "ENCRYPTED|Proc-Type: 4,ENCRYPTED" "$file"; then protected="${R}Yes (Encrypted)${NC}"; fi
  elif grep -q "BEGIN PUBLIC KEY" "$file" 2>/dev/null; then
   type="Public Key"
   color="${G}"
  else return 0; fi

  # 2. Date Logic
  if [[ -n "$expiry" && "$expiry" != "N/A" && "$expiry" != "Multiple" ]]; then
   local exp_s=$(date -d "$expiry" +%s 2>/dev/null)
   if [[ -n "$exp_s" ]]; then
    local now=$(date +%s)
    local diff=$(((exp_s - now) / 86400))
    if [[ $diff -lt 0 ]]; then
     days_left="${R}EXPIRED (${diff#-} days ago)${NC}"
    elif [[ $diff -lt 30 ]]; then
     days_left="${Y}$diff days (URGENT)${NC}"
    else days_left="${G}$diff days${NC}"; fi
   fi
  fi

  # 3. Build Content Rows (Store in Array)
  local rows=()
  rows+=(" Type            : $type")
  rows+=(" Protected       : $protected")
  rows+=(" CN              : ${cn:-N/A}")
  [[ "$issuer" != "N/A" ]] && rows+=(" Issuer          : $issuer")
  [[ "$issued" != "N/A" ]] && rows+=(" Issued          : $issued")
  [[ "$expiry" != "N/A" ]] && rows+=(" Expires         : $expiry")
  [[ "$days_left" != "N/A" ]] && rows+=(" Remaining       : $days_left")
  [[ "$sha256" != "N/A" ]] && rows+=(" SHA256          : $sha256")
  [[ "$md5" != "N/A" ]] && rows+=(" MD5             : $md5")
  rows+=(" File Path       : $abs_path")

  # 3b. Detail individual certs if CA Bundle
  if [[ "$type" == "CA Bundle "* ]]; then
   local c=1
   local cert_buf=""
   local in_cert=false
   while IFS= read -r line; do
    if [[ "$line" == *"BEGIN CERTIFICATE"* ]]; then
     in_cert=true
     cert_buf="$line"$'\n'
    elif [[ "$line" == *"END CERTIFICATE"* ]]; then
     cert_buf+="$line"$'\n'
     local sub=$(printf "%s" "$cert_buf" | openssl x509 -noout -subject -nameopt RFC2253 2>/dev/null | sed -E 's/^subject=//; s/.*CN=([^,]*).*/\1/')
     local iss=$(printf "%s" "$cert_buf" | openssl x509 -noout -issuer -nameopt RFC2253 2>/dev/null | sed -E 's/^issuer=//; s/.*CN=([^,]*).*/\1/')
     local notBefore=$(printf "%s" "$cert_buf" | openssl x509 -noout -dates 2>/dev/null | grep "notBefore" | cut -d= -f2)
     local notAfter=$(printf "%s" "$cert_buf" | openssl x509 -noout -dates 2>/dev/null | grep "notAfter" | cut -d= -f2)
     local sha256_fp=$(printf "%s" "$cert_buf" | openssl x509 -noout -fingerprint -sha256 2>/dev/null | cut -d= -f2)
     local md5_fp=$(printf "%s" "$cert_buf" | openssl x509 -noout -fingerprint -md5 2>/dev/null | cut -d= -f2)
     local d_left="N/A"

     if [[ -n "$notAfter" ]]; then
      local exp_s=$(date -d "$notAfter" +%s 2>/dev/null)
      if [[ -n "$exp_s" ]]; then
       local now=$(date +%s)
       local diff=$(((exp_s - now) / 86400))
       if [[ $diff -lt 0 ]]; then
        d_left="${R}EXPIRED (${diff#-} days ago)${NC}"
       elif [[ $diff -lt 30 ]]; then
        d_left="${Y}$diff days (URGENT)${NC}"
       else d_left="${G}$diff days${NC}"; fi
      fi
     fi

     rows+=(" --------------------------------------------------")
     rows+=(" [Entry $c]")
     rows+=("   Subject       : ${sub:-N/A}")
     rows+=("   Issuer        : ${iss:-N/A}")
     rows+=("   Issued        : ${notBefore:-N/A}")
     rows+=("   Expires       : ${notAfter:-N/A}")
     rows+=("   Remaining     : ${d_left:-N/A}")
     rows+=("   SHA256        : ${sha256_fp:-N/A}")
     rows+=("   MD5           : ${md5_fp:-N/A}")

     ((c++))
     in_cert=false
     cert_buf=""
    elif $in_cert; then
     cert_buf+="$line"$'\n'
    fi
   done <"$file"
  fi

  # 4. Calculate Box Width
  local max_w=50
  for r in "${rows[@]}"; do
   local w=$(_vwidth "$r")
   [[ $w -gt $max_w ]] && max_w=$w
  done
  max_w=$((max_w + 2))

  # 5. Draw
  local dash=$(printf '─%.0s' $(seq 1 $max_w))
  printf "${color}┌%s┐${NC}\n" "$dash"

  # Center Header
  local h_pad=$(((max_w - ${#filename}) / 2))
  printf "${color}│${NC}%*s%s%*s${color}│${NC}\n" "$h_pad" "" "$filename" "$((max_w - h_pad - ${#filename}))" ""

  printf "${color}├%s┤${NC}\n" "$dash"

  # Rows with precise trailing space calculation
  for r in "${rows[@]}"; do
   local cur_w=$(_vwidth "$r")
   local gap=$((max_w - cur_w))
   printf "%b%*s ${color}│${NC}\n" "$r" "$gap" ""
  done

  printf "${color}└%s┘${NC}\n\n" "$dash"
 }

 # --- Argument & Paging Logic ---
 if [[ "$1" == "-s" || "$1" == "--save" ]]; then
  save_mode=true
  shift
 fi

 _pki_run() {
  case "$1" in
  "--verify")
   local f1="$2" f2="$3"
   local m1=$(openssl x509 -noout -modulus -in "$f1" 2>/dev/null || openssl rsa -noout -modulus -in "$f1" 2>/dev/null || openssl req -noout -modulus -in "$f1" 2>/dev/null)
   local m2=$(openssl x509 -noout -modulus -in "$f2" 2>/dev/null || openssl rsa -noout -modulus -in "$f2" 2>/dev/null || openssl req -noout -modulus -in "$f2" 2>/dev/null)
   [[ "$m1" == "$m2" && -n "$m1" ]] && printf "${G}MATCH!${NC}\n" || printf "${R}MISMATCH${NC}\n"
   ;;
  *)
   local tmp=$(mktemp)
   trap 'rm -f "$tmp"' EXIT
   for arg in "$@"; do
    if [[ "$arg" =~ ^([a-z0-9]+(-[a-z0-9]+)*\.)+[a-z]{2,}$ ]]; then
     echo | openssl s_client -connect "${arg}:443" -servername "$arg" 2>/dev/null | openssl x509 >"$tmp"
     [[ -s "$tmp" ]] && _pki_format "$tmp"
    elif [[ -d "$arg" ]]; then
     find "$arg" -type f -not -empty | while read f; do _pki_format "$f"; done
    elif [[ -f "$arg" ]]; then _pki_format "$arg"; fi
   done
   ;;
  esac
 }

 _pki_run "$@" | less -R -F -X
}

pki-analyze() (

 TARGET_DIR="${1:-.}"

 echo "📂 Analyzing directory: $TARGET_DIR"
 cd "$TARGET_DIR" || {
  echo "❌ Directory not found!"
  exit 1
 }

 echo ""
 echo "🔍 Verifying PKI Cryptographic Relationships (Dynamic Matching)..."
 echo "-----------------------------------------------"

 # Enable nullglob so empty matches don't break the loop
 shopt -s nullglob

 # Associative arrays to store modulus hashes
 declare -A cert_mods key_mods csr_mods

 for f in *.crt *.pem; do
  mod=$(openssl x509 -noout -modulus -in "$f" 2>/dev/null | sed 's/Modulus=//')
  [ -n "$mod" ] && cert_mods["$f"]="$mod"
 done
 for f in *.key; do
  mod=$(openssl rsa -noout -modulus -in "$f" 2>/dev/null | sed 's/Modulus=//')
  [ -n "$mod" ] && key_mods["$f"]="$mod"
 done
 for f in *.csr; do
  mod=$(openssl req -noout -modulus -in "$f" 2>/dev/null | sed 's/Modulus=//')
  [ -n "$mod" ] && csr_mods["$f"]="$mod"
 done

 # Match Keys to Certs/CSRs
 for k in "${!key_mods[@]}"; do
  k_mod="${key_mods[$k]}"
  matched=0
  for c in "${!cert_mods[@]}"; do
   if [ "${cert_mods[$c]}" == "$k_mod" ]; then
    echo "✅ Key '$k' matches Certificate '$c'"
    matched=1
   fi
  done
  for r in "${!csr_mods[@]}"; do
   if [ "${csr_mods[$r]}" == "$k_mod" ]; then
    echo "✅ Key '$k' matches CSR '$r'"
    matched=1
   fi
  done
  if [ $matched -eq 0 ]; then
   echo "⚠️  Key '$k' has no matching certificate or CSR in this directory."
  fi
 done

 echo ""
 echo "🔗 Verifying Chains of Trust..."
 echo "-----------------------------------------------"

 # Identify ALL Root CAs vs Issued Certs
 root_cas=()
 other_certs=()

 for f in "${!cert_mods[@]}"; do
  iss=$(openssl x509 -noout -issuer -in "$f" 2>/dev/null | sed -E 's/^issuer=[[:space:]]*//')
  sub=$(openssl x509 -noout -subject -in "$f" 2>/dev/null | sed -E 's/^subject=[[:space:]]*//')

  if [ "$iss" == "$sub" ] && [ -n "$iss" ]; then
   root_cas+=("$f")
  else
   other_certs+=("$f")
  fi
 done

 declare -A displayed_files
 declare -A ca_issued

 for ca in "${root_cas[@]}"; do
  echo "Root CA Identified: $ca"
  for cert in "${other_certs[@]}"; do
   if openssl verify -CAfile "$ca" "$cert" >/dev/null 2>&1; then
    echo "  ✅ Validates: $cert"
    ca_issued["$ca"]+="$cert "
   fi
  done
 done

 echo ""
 echo "🌳 PKI Directory Hierarchy & Connectivity (Multi-Root Dynamic)"
 echo "------------------------------------------------------------"

 if [ ${#root_cas[@]} -eq 0 ]; then
  echo "⚠️  No Root CAs found in directory."
 fi

 for ca in "${root_cas[@]}"; do
  ca_cn=$(openssl x509 -noout -subject -in "$ca" 2>/dev/null | sed -n 's/.*CN\s*=\s*\([^,]*\).*/\1/p')
  [ -z "$ca_cn" ] && ca_cn=$(openssl x509 -noout -subject -in "$ca" 2>/dev/null | sed -E 's/^subject=[[:space:]]*//')
  [ -z "$ca_cn" ] && ca_cn="Unknown CA ($ca)"

  echo "Root CA: $ca_cn"

  # Gathering files for this CA
  ca_files=("$ca")
  ca_mod="${cert_mods[$ca]}"

  for k in "${!key_mods[@]}"; do
   if [ "${key_mods[$k]}" == "$ca_mod" ]; then
    ca_files+=("$k")
   fi
  done

  ca_base="${ca%.*}"
  for srl in *.srl; do
   if [[ "$srl" == "$ca_base"* ]] || [[ "$ca_base" == *"ca"* && "$srl" == *"ca"* ]]; then
    ca_files+=("$srl")
   fi
  done

  for f in "${ca_files[@]}"; do
   displayed_files["$f"]=1
   desc=""
   [[ "$f" == *.crt || "$f" == *.pem ]] && desc="(Public CA Certificate)"
   [[ "$f" == *.key ]] && desc="(Private CA Key)"
   [[ "$f" == *.srl ]] && desc="(Serial Number Tracker)"
   echo "├── $f $desc"
  done

  issued_arr=(${ca_issued["$ca"]})
  num_certs=${#issued_arr[@]}

  if [ "$num_certs" -eq 0 ]; then
   echo "│   └── (No issued certificates found for this CA in directory)"
  else
   echo "│"
   count=0
   for cert in "${issued_arr[@]}"; do
    count=$((count + 1))
    cert_cn=$(openssl x509 -noout -subject -in "$cert" 2>/dev/null | sed -n 's/.*CN\s*=\s*\([^,]*\).*/\1/p')
    [ -z "$cert_cn" ] && cert_cn="Unknown Entity"

    cert_base="${cert%.*}"
    if [ "$count" -eq "$num_certs" ]; then
     node_prefix="└──"
     child_prefix="    "
    else
     node_prefix="├──"
     child_prefix="│   "
    fi

    echo "$node_prefix [Issued Entity]: $cert_cn ($cert_base)"

    entity_files=("$cert")
    cert_mod="${cert_mods[$cert]}"

    for k in "${!key_mods[@]}"; do
     if [ "${key_mods[$k]}" == "$cert_mod" ]; then
      entity_files+=("$k")
      break
     fi
    done
    for r in "${!csr_mods[@]}"; do
     if [ "${csr_mods[$r]}" == "$cert_mod" ]; then
      entity_files+=("$r")
      break
     fi
    done
    for cnf in *.cnf *.ext; do
     if [[ "$cnf" == "$cert_base"* ]] || grep -qF "$cert_cn" "$cnf" 2>/dev/null; then
      if [[ ! " ${entity_files[@]} " =~ " ${cnf} " ]]; then
       entity_files+=("$cnf")
      fi
     fi
    done

    num_files=${#entity_files[@]}
    f_count=0
    for f in "${entity_files[@]}"; do
     displayed_files["$f"]=1
     f_count=$((f_count + 1))
     f_prefix="├──"
     [ "$f_count" -eq "$num_files" ] && f_prefix="└──"

     desc=""
     [[ "$f" == *.crt || "$f" == *.pem ]] && desc="(Public Certificate)"
     [[ "$f" == *.key ]] && desc="(Private Key)"
     [[ "$f" == *.csr ]] && desc="(Certificate Signing Request)"
     [[ "$f" == *.cnf || "$f" == *.ext ]] && desc="(Config/Extensions)"

     echo "$child_prefix$f_prefix $f $desc"
    done
    [ "$count" -lt "$num_certs" ] && echo "│"
   done
  fi
  echo ""
 done

 # Show unlinked/orphaned files
 has_orphans=0
 for f in *.crt *.pem *.key *.csr *.srl *.cnf *.ext; do
  if [ -z "${displayed_files[$f]}" ] && [ -e "$f" ]; then
   if [ "$has_orphans" -eq 0 ]; then
    echo "❓ Unconnected / Orphaned Files"
    echo "------------------------------------------------------------"
    has_orphans=1
   fi

   desc="Unknown"
   if [[ "$f" == *.pem || "$f" == *.crt ]]; then
    iss=$(openssl x509 -noout -issuer -in "$f" 2>/dev/null | sed -n 's/.*CN\s*=\s*\([^,]*\).*/\1/p')
    [ -z "$iss" ] && iss=$(openssl x509 -noout -issuer -in "$f" 2>/dev/null | sed -E 's/^issuer=[[:space:]]*//')
    desc="Certificate (Issuer: $iss)"
   elif [[ "$f" == *.key ]]; then
    desc="Private Key (No matching cert/csr found)"
   elif [[ "$f" == *.csr ]]; then
    desc="CSR (No matching key/cert found)"
   elif [[ "$f" == *.srl || "$f" == *.cnf || "$f" == *.ext ]]; then
    desc="Supporting File"
   fi

   echo "├── $f - $desc"
  fi
 done
 [ "$has_orphans" -eq 1 ] && echo ""

 echo "⏳ Certificate Expiration Status"
 echo "------------------------------------------------------------"
 # 2592000 seconds = 30 days warning window
 for cert in "${!cert_mods[@]}"; do
  end_date=$(openssl x509 -enddate -noout -in "$cert" 2>/dev/null | cut -d= -f2)

  if ! openssl x509 -checkend 0 -noout -in "$cert" >/dev/null 2>&1; then
   echo "❌ EXPIRED: $cert (Expired on: $end_date)"
  elif ! openssl x509 -checkend 2592000 -noout -in "$cert" >/dev/null 2>&1; then
   echo "⚠️  EXPIRING SOON (<30 Days): $cert (Expires on: $end_date)"
  else
   echo "✅ VALID: $cert (Expires on: $end_date)"
  fi
 done
 echo ""

 # Re-disable nullglob
 shopt -u nullglob
)
