#!/bin/bash

if [[ -n "${__BASH_FUNCTIONS__:-}" ]]; then
 return 0
fi

__BASH_FUNCTIONS__=1

# Define global colors for consistency across functions
R='\e[1;91m' # Red
G='\e[1;92m' # Green
Y='\e[1;93m' # Yellow
B='\e[1;94m' # Blue
M='\e[3;90m' # Muted/Grey
NC='\e[0m'   # No Color

############################################
# UTILITY FUNCTIONS
############################################

now() {
 TZ='America/New_York' date +'%I:%M:%S %p'
}

clock() {
 # 1. Dependency check
 if ! command -v toilet >/dev/null || ! command -v watch >/dev/null; then
  echo -e " ${R}(!)${NC} Dependencies [toilet] and [watch] are required."
  echo " Install them with: sudo apt install toilet watch -y"
  return 1
 fi

 echo -e " ${G}(i)${NC} Starting Live Clock (Press ${Y}Ctrl+C${NC} to exit)..."

 # 2. Execute the watch command
 # -t hides the watch header for a cleaner look
 # TZ variable ensures New York time regardless of system settings
 # date format %I:%M:%S %p provides 12-hour time with AM/PM
 watch -t -n 1 "export TZ='America/New_York'; date +'%I:%M:%S %p' | toilet -f future --filter border:gay"
}
export -f clock

clipboard() {
 local G='\033[0;92m'
 local R='\033[0;91m'
 local Y='\033[1;93m'
 local M='\033[0;90m'
 local NC='\033[0m'

 local _temp_buffer
 _temp_buffer=$(mktemp)            # Create a temporary file to hold concatenated content
 trap 'rm -f "$_temp_buffer"' EXIT # Ensure temp file is cleaned up

 # --- Input Logic ---
 if [[ $# -gt 0 ]]; then
  # Multiple Files Path
  local found_any=false
  for file in "$@"; do
   if [[ -f "$file" ]]; then
    cat "$file" >>"$_temp_buffer"
    # Add a newline between files if multiple are passed
    [[ $# -gt 1 ]] && echo "" >>"$_temp_buffer"
    found_any=true
   else
    echo -e " ${R}(!)${NC} File not found: $file"
   fi
  done

  if [[ "$found_any" == "false" ]]; then
   return 1
  fi
 elif [[ -p /dev/stdin ]]; then
  # Pipe/Stdin Path
  cat >"$_temp_buffer"
 else
  echo -e " ${G}(i)${NC} Usage: \e[1;27mclipboard\e[0m ${Y}<file1> <file2> ...${NC} or \e[1;27mcommand\e[0m | \e[1;27mclipboard\e[0m"
  return 1
 fi

 # --- Clipboard Detection & Execution ---
 local success=false

 # Wayland
 if [[ -n "$WAYLAND_DISPLAY" ]] && command -v wl-copy >/dev/null; then
  wl-copy <"$_temp_buffer" && success=true

 # X11 (xclip)
 elif [[ -n "$DISPLAY" ]] && command -v xclip >/dev/null; then
  xclip -selection clipboard -i "$_temp_buffer" && success=true

 # X11 (xsel fallback)
 elif [[ -n "$DISPLAY" ]] && command -v xsel >/dev/null; then
  xsel --clipboard --input <"$_temp_buffer" && success=true
 fi

 if [[ "$success" == "true" ]]; then
  if [[ $# -gt 0 ]]; then
   echo -e "${M} Contents of ${G}$# file(s)${NC}${M} copied to system clipboard.${NC}"
  else
   echo -e "${G} Input copied to system clipboard.${NC}"
  fi
 else
  echo -e " ${R}(!)${NC} Could not detect a valid clipboard utility."
  return 1
 fi
}

fmt() {
 local interactive=false
 local target=""

 # 1. Parse Arguments
 if [[ "$1" == "-i" ]]; then
  interactive=true
  target="$2"
 else
  target="$1"
 fi

 # 2. Validation
 if [[ -z "$target" ]]; then
  echo -e " Usage : ${G}fmt${NC} [-i] <file|directory>"
  return 1
 fi

 if [[ ! -e "$target" ]]; then
  echo -e " ${R}(!)${NC} Path not found: $target"
  return 1
 fi

 if ! command -v shfmt >/dev/null; then
  echo -e " ${R}(!)${NC} 'shfmt' is not installed."
  return 1
 fi

 # 3. Collect Files
 local files=()
 if [[ -f "$target" ]]; then
  files=("$target")
 else
  # Use find to grab all files, then filter by mime-type or extension
  # This avoids the "File not found" error by ensuring we only iterate existing items
  while IFS= read -r line; do
   files+=("$line")
  done < <(find "$target" -type f \( -name "*.sh" -o ! -name "*.*" \))
 fi

 # 4. Process Files
 if [[ ${#files[@]} -eq 0 ]]; then
  echo -e " ${Y}(i)${NC} No shell scripts found in $target"
  return 0
 fi

 for file in "${files[@]}"; do
  # Only process if it's a text file (prevents shfmt from choking on binaries)
  if file "$file" | grep -qE 'shell script|text'; then

   if [[ "$interactive" == true ]]; then
    echo -ne " ${Y}?>${NC} Format ${G}$(basename "$file")${NC}? (y/n): "
    read -r confirm
    [[ "$confirm" != [yY] ]] && continue
   fi

   shfmt -i 1 -w "$file"
   if [[ $? -eq 0 ]]; then
    echo -e " ${M}(i) Formatted:${NC} ${G}$file${NC}"
   else
    echo -e " ${R}(!)${NC} Failure formatting: $file"
   fi
  fi
 done
}

# Depth of terminal sessions
terminal_depth() {

 #pstree -p -A -s $$ | \
 #head -n 1 | \
 #sed "s/($$).*/($$)/; s/([0-9]*)//g; s/---/ ➤ /g; s/ ➤ -/ ➤ /g; s/tmux: server/tmux/"

 # Get the raw tree with PIDs, truncated at the current shell ($$)
 local tree=$(pstree -p -A -s $$ | head -n 1 | sed "s/($$).*/($$)/")

 if [[ "$1" == "--pid" ]]; then
  # Format WITH PIDs: Add space before (, switch arrows, clean artifacts
  echo "$tree" | sed 's/---/ ➤ /g; s/(/ (/g; s/ ➤ -/ ➤ /g; s/tmux: server/tmux/'
 else
  # Format WITHOUT PIDs: Remove numbers, switch arrows, clean artifacts
  echo "$tree" | sed 's/([0-9]*)//g; s/---/ ➤ /g; s/ ➤ -/ ➤ /g; s/tmux: server/tmux/'
 fi

}

export -f terminal_depth

function fz {

 export FZF_DEFAULT_OPTS="--bind 'space:toggle-in'"

 if ! command -v fzf >/dev/null || ! command -v whiptail >/dev/null; then
  echo "Dependencies [fzf] and [whiptail] are required. Installing now..."
  sudo apt update && sudo apt install fzf whiptail -y
  if ! command -v fzf >/dev/null; then return 1; fi
 fi

 local search_path="."
 if [[ -d "$1" ]]; then
  search_path="$1"
  shift # Remove the path from arguments so "$@" only contains fzf flags
 fi

 local selected_items
 selected_items=$(find "$search_path" -maxdepth 3 2>/dev/null | fzf -m "$@")

 [[ -z "$selected_items" ]] && return 0

 mapfile -t selections <<<"$selected_items"
 local first_selection="${selections[0]}"
 local absPath=$(realpath "$first_selection")
 local baseName=$(basename "$first_selection")
 local count=${#selections[@]}

 local directory
 if [[ -d "$absPath" ]]; then
  directory="$absPath"
 else
  directory=$(dirname "$absPath")
 fi

 local extension="${first_selection##*.}"
 local tool_label="System Default"
 [[ "$extension" == "mp3" ]] && tool_label="Play Audio"
 [[ -x /usr/bin/gedit ]] && tool_label="Gedit"

 # 5. Whiptail Menu
 local menu_title="Fuzzy Action ($count items)"
 [[ $count -eq 1 ]] && menu_title="Fuzzy Action: $baseName"

 local option
 option=$(whiptail --title "$menu_title" \
  --menu "Choose action for $count selected item(s):" 18 80 8 \
  "View" "Preview first item with bat" \
  "Edit" "Open all in Vim" \
  "OpenWith" "Open with $tool_label" \
  "OpenDir" "Open parent directory" \
  "GoTo" "CD to parent directory (Single only)" \
  "Delete" "Remove selected items (Careful!)" \
  "Exit" "Cancel" \
  3>&1 1>&2 2>&3)

 case "$option" in
 "View")
  bat "${selections[@]}"
  ;;
 "Edit")
  # Opens all selected files in vim buffers
  if [ -w "$absPath" ]; then
   vim -p "${selections[@]}"
  else
   sudo vim -p "${selections[@]}"
  fi
  ;;
 "OpenWith")
  for item in "${selections[@]}"; do
   local full_path=$(realpath "$item")
   if [[ "$extension" == "mp3" ]]; then
    mpv --no-video "$full_path" >/dev/null 2>&1 &
   elif [[ "$tool_label" == "Gedit" ]]; then
    nohup gedit "$full_path" >/dev/null 2>&1 &
   else
    xdg-open "$full_path" >/dev/null 2>&1 &
   fi
  done
  ;;
 "OpenDir")
  xdg-open "$directory" >/dev/null 2>&1
  ;;
 "GoTo")
  echo -e "${M}Changing directory to: ${G}$directory${NC}"
  cd "$directory" || return
  ls -F --color=auto
  ;;
 "Delete")
  if (whiptail --title "Confirm Delete" --yesno "Are you sure you want to delete $count items?" 10 60); then
   rm -rf "${selections[@]}"
   echo -e "${R}Deleted $count items.${NC}"
  fi
  ;;
 *)
  return 0
  ;;
 esac
}

qr-code() {
 local text="$1"
 if [[ -z "$text" ]]; then
  read -r -p "Text to convert: " text
 fi

 if [[ -z "$text" ]]; then return; fi

 local export_path
 read -e -r -p "Save location (leave empty for terminal only): " export_path

 if [[ -n "$export_path" ]]; then
  local export_dir
  local export_filename

  if [[ -d "$export_path" ]]; then
   export_dir="${export_path%/}"
   export_filename="qr_code"
  else
   export_dir=$(dirname "$export_path")
   export_filename=$(basename "$export_path")
  fi

  # Generate files
  echo "Saving to ${export_dir}..."
  qrencode -m 2 -s 10 -o "${export_dir}/${export_filename}.png" "$text"
  echo -e "${G}Saved:${NC} ${export_dir}/${export_filename}.png"
 fi

 echo "Terminal Preview:"
 qrencode -m 2 -s 1 -t UTF8 -l L "$text"
 echo
}
export -f qr-code

image-to-asci() {
 if [[ -f "$1" ]]; then
  jp2a -i --chars="XxxVO" "$1"
 else
  echo "File not found [$1]"
 fi
}
export -f image-to-asci

convert-image() {
 if [[ -f "$1" ]] && [[ -n "$2" ]]; then
  convert "$1" -quality 100 "$2"
  echo -e "${G}Converted:${NC} $1 -> $2"
 else
  echo "Usage: convert-image <input> <output>"
  return 1
 fi
}
export -f convert-image

function alert {
 local last_exit_status=$?
 local icon_name="terminal"
 local msg

 if [ "$last_exit_status" -ne 0 ]; then
  icon_name="error"
 fi

 msg=$(history | tail -n1 | sed -e 's/^\s*[0-9]\+\s*//;s/[;&|]\s*alert$//')
 notify-send --urgency=low -i "$icon_name" "Command Complete" "$msg"
}

