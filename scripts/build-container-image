#!/bin/bash
# Wrapper script to generate Packer templates, build a Docker image, and push it to Docker Hub

set -e

# Prompt for Docker Hub username to tag the image correctly
read -p "Enter your Docker Hub username (or Quay.io username): " DOCKER_USER
if [[ -z "$DOCKER_USER" ]]; then
  echo "Username is required to push the image. Exiting."
  exit 1
fi

IMAGE_NAME="ubuntu-dev-env"

echo "--- 🛠️ Generating Packer Template (ubuntu-docker.pkr.hcl) ---"
cat << EOF > ubuntu-docker.pkr.hcl
packer {
  required_plugins {
    docker = {
      version = ">= 1.0.8"
      source  = "github.com/hashicorp/docker"
    }
  }
}

source "docker" "ubuntu" {
  image  = "ubuntu:22.04"
  commit = true
  changes = [
    "ENV DEBIAN_FRONTEND=noninteractive",
    "CMD [\"/bin/bash\"]"
  ]
}

build {
  name    = "custom-desktop-container"
  sources = ["source.docker.ubuntu"]

  # Provisioner to run the adapted package installation script
  provisioner "shell" {
    script = "provision.sh"
  }

  # Tag and Push to Docker Hub
  post-processors {
    post-processor "docker-tag" {
      repository = "${DOCKER_USER}/${IMAGE_NAME}"
      tags       = ["latest", "{{timestamp}}"]
    }
    post-processor "docker-push" {
      # This requires you to be logged in via 'docker login' on your host machine
    }
  }
}
EOF

echo "--- 📝 Generating Provisioner Script (provision.sh) ---"
cat << 'EOF' > provision.sh
#!/bin/bash
# Docker Provisioning Script

export DEBIAN_FRONTEND=noninteractive

echo "--- 🔄 Updating Package Lists & Core Utils ---"
# Install sudo and curl first since Docker's Ubuntu base is extremely barebones
apt-get update -y
apt-get install -y sudo curl wget gnupg software-properties-common apt-transport-https dirmngr

packages=(
 "tmux" "vim" "batcat:bat" "curl" "wget" "openssl" "btop" "pluma" "gedit" "colordiff" 
 "tty-clock" "java:default-jdk" "visualvm" "lolcat" "build-essential" "netstat:net-tools" 
 "jq" "notify-send:libnotify-bin" "yq" "figlet" "toilet" "qrencode" "python3-segno" 
 "tree" "whiptail" "mpv" "duf" "fzf" "imagemagick" "zenity" "pipx" "tigervnc-common" 
 "tigervnc-client" "tigervnc-tools" "tigervnc-standalone-server" "pv" "git" "delta:git-delta" 
 "thefuck" "shfmt" "shellcheck" "yamllint" "neofetch:neofetch-desktop" "expect" 
 "xmllint:libxml2-utils" "jc" "gufw" "ranger" "mc" "cmatrix" "sysvbanner" "xclip" "7zip" 
 "p7zip-full" "file-roller" "ffmpeg" "ffmpegthumbnailer" "htop" "kubecolor" "synaptic"
)

echo "--- 📦 Starting APT Package Installation ---"
for item in "${packages[@]}"; do
  if [[ "$item" == *":"* ]]; then
    binary="${item%%:*}"
    package="${item##*:}"
  else
    binary="$item"
    package="$item"
  fi

  if ! command -v "$binary" >/dev/null 2>&1; then
    echo "Installing $package..."
    sudo apt-get install -y "$package"
  else
    echo "Tool [$package] already installed"
  fi
done

echo "--- 🚀 Starting Custom Installations ---"

# Install terraform & packer
if ! command -v terraform >/dev/null 2>&1; then
  echo "Installing terraform & packer"
  curl -fsSL https://apt.releases.hashicorp.com/gpg | sudo gpg --dearmor | sudo tee /usr/share/keyrings/hashicorp-archive-keyring.gpg > /dev/null
  echo "deb [signed-by=/usr/share/keyrings/hashicorp-archive-keyring.gpg] https://apt.releases.hashicorp.com $(lsb_release -cs) main" | sudo tee /etc/apt/sources.list.d/hashicorp.list
  sudo apt-get update && sudo apt-get install -y terraform packer
fi

# Install Helm
if ! command -v helm >/dev/null 2>&1; then
  echo "Installing helm..."
  curl -fsSL -o get_helm.sh https://raw.githubusercontent.com/helm/helm/main/scripts/get-helm-3 | bash
  rm get_helm.sh
fi

# Install Docker CLI (Only the CLI makes sense inside a container, running the daemon requires DinD setup)
if ! command -v docker >/dev/null 2>&1; then
  echo "Installing Docker CLI..."
  sudo apt-get install -y docker.io
fi

# Desktop/GNOME Tools
sudo apt-get install -y indicator-multiload gnome-shell-extension-manager dconf-editor

# Install VS Code via APT (Snap does not work in Docker)
if ! command -v code >/dev/null 2>&1; then
  echo "Installing VS Code via APT..."
  wget -qO- https://packages.microsoft.com/keys/microsoft.asc | gpg --dearmor > packages.microsoft.gpg
  sudo install -D -o root -g root -m 644 packages.microsoft.gpg /etc/apt/keyrings/packages.microsoft.gpg
  echo "deb [arch=amd64,arm64,armhf signed-by=/etc/apt/keyrings/packages.microsoft.gpg] https://packages.microsoft.com/repos/code stable main" | sudo tee /etc/apt/sources.list.d/vscode.list > /dev/null
  rm -f packages.microsoft.gpg
  sudo apt-get update && sudo apt-get install -y code
fi

# Install LazyDocker
if ! command -v lazydocker >/dev/null 2>&1; then
  echo "Installing lazydocker..."
  curl https://raw.githubusercontent.com/jesseduffield/lazydocker/master/scripts/install_update_linux.sh | bash
fi

# Install K9s
if ! command -v k9s >/dev/null 2>&1; then
  K9S_VERSION="v0.32.5"
  echo "Installing k9s..."
  TMP_DIR=$(mktemp -d)
  curl -L "https://github.com/derailed/k9s/releases/download/${K9S_VERSION}/k9s_Linux_amd64.tar.gz" -o "$TMP_DIR/k9s.tar.gz"
  tar -xzf "$TMP_DIR/k9s.tar.gz" -C "$TMP_DIR"
  sudo install -m 755 "$TMP_DIR/k9s" /usr/local/bin/k9s
  rm -rf "$TMP_DIR"
fi

# Install Minikube
if ! command -v minikube >/dev/null 2>&1; then
  LATEST_MINIKUBE_VERSION=$(curl -s https://storage.googleapis.com/minikube/releases/latest/minikube-version)
  echo "Installing minikube ${LATEST_MINIKUBE_VERSION}..."
  curl -LO https://github.com/kubernetes/minikube/releases/latest/download/minikube-linux-amd64
  sudo install minikube-linux-amd64 /usr/local/bin/minikube
  rm minikube-linux-amd64
fi

# NOTE: Flatpak, MissionCenter, Sticky Notes, and gsettings are omitted. 
# Standard Docker containers lack systemd, dbus, and a display server required for these to function.

echo "--- ✨ Provisioning Complete! ---"
EOF

chmod +x provision.sh

echo "--- 🚀 Initializing Packer ---"
packer init ubuntu-docker.pkr.hcl

echo ""
echo "⚠️  CRITICAL STEP: You must be logged into Docker to push the image."
echo "If you haven't logged in yet, press Ctrl+C, run 'docker login', and run this script again."
echo "Sleeping for 5 seconds to give you a chance to cancel..."
sleep 5

echo "--- 🏗️ Building and Pushing Image ---"
packer build ubuntu-docker.pkr.hcl
