#!/usr/bin/env bash
# =============================================================================
#  gen_ssh_keys.sh — Generate ~/.ssh/id_rsa + id_rsa.pub unconditionally
# =============================================================================
set -euo pipefail

GREEN='\033[0;32m'
YELLOW='\033[1;33m'
RED='\033[0;31m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

log() { echo -e "${GREEN}[✔]${RESET} $*"; }
info() { echo -e "${CYAN}[➜]${RESET} $*"; }
warn() { echo -e "${YELLOW}[!]${RESET} $*"; }
die() {
 echo -e "${RED}[✘]${RESET} $*"
 exit 1
}

# ── Config ────────────────────────────────────────────────────────────────────
GIT_EMAIL="xxx@xxx.com"
SSH_DIR="$HOME/.ssh"
KEY="$SSH_DIR/id_rsa"

# ── 1. Sanity checks ──────────────────────────────────────────────────────────
info "Running as       : $(whoami)  (HOME=$HOME)"
info "Target key       : $KEY"
info "openssh version  : $(ssh-keygen -V 2>&1 || ssh -V 2>&1 || echo 'unknown')"

command -v ssh-keygen &>/dev/null || die "ssh-keygen not found — install openssh-client first:
  sudo apt-get install -y openssh-client"

# ── 2. Create ~/.ssh with correct permissions ─────────────────────────────────
info "Ensuring $SSH_DIR exists…"
mkdir -p "$SSH_DIR"
chmod 700 "$SSH_DIR"
log "$SSH_DIR  →  mode 700"

# Verify ownership
OWNER=$(stat -c '%U' "$SSH_DIR" 2>/dev/null || stat -f '%Su' "$SSH_DIR")
[[ "$OWNER" == "$(whoami)" ]] || die "$SSH_DIR is owned by '$OWNER', not $(whoami). Fix with:
  sudo chown -R $(whoami):$(whoami) $SSH_DIR"

# ── 3. Back up any existing (possibly corrupt) keys ───────────────────────────
for f in "$KEY" "${KEY}.pub"; do
 if [[ -e "$f" ]]; then
  BACKUP="${f}.bak.$(date +%s)"
  warn "Found existing $f → backing up to $BACKUP"
  mv "$f" "$BACKUP"
 fi
done

# ── 4. Generate the key pair ──────────────────────────────────────────────────
info "Generating 4096-bit RSA key pair (no passphrase)…"

ssh-keygen \
 -t rsa \
 -b 4096 \
 -C "$GIT_EMAIL" \
 -f "$KEY" \
 -N "" \
 -q # quiet — suppresses the art banner

# ── 5. Verify both files were actually created ────────────────────────────────
[[ -f "$KEY" ]] || die "Private key was NOT created at $KEY"
[[ -f "${KEY}.pub" ]] || die "Public key was NOT created at ${KEY}.pub"
log "Private key : $KEY"
log "Public key  : ${KEY}.pub"

# ── 6. Enforce correct permissions ───────────────────────────────────────────
chmod 600 "$KEY"
chmod 644 "${KEY}.pub"
log "Permissions set  →  id_rsa=600  id_rsa.pub=644"

# ── 7. Validate the key pair is internally consistent ────────────────────────
info "Validating key fingerprint…"
FINGERPRINT=$(ssh-keygen -lf "$KEY" 2>&1)
log "Fingerprint: $FINGERPRINT"

info "Validating public key readability…"
ssh-keygen -y -f "$KEY" >/dev/null && log "Key pair consistency check passed"

# ── 8. Add to ssh-agent ───────────────────────────────────────────────────────
info "Adding key to ssh-agent…"
# Start agent if not already running
if [[ -z "${SSH_AUTH_SOCK:-}" ]]; then
 eval "$(ssh-agent -s)" >/dev/null
 warn "ssh-agent started for this session only. For persistence add to ~/.bashrc:
    eval \"\$(ssh-agent -s)\"
    ssh-add ~/.ssh/id_rsa"
fi

ssh-add "$KEY" 2>/dev/null && log "Key added to ssh-agent" ||
 warn "ssh-add failed (agent may not be available in this shell — key will still work)"

# ── 9. Cache GitHub's host fingerprint ───────────────────────────────────────
info "Caching github.com in known_hosts…"
ssh-keyscan -H github.com >>"$SSH_DIR/known_hosts" 2>/dev/null
sort -u "$SSH_DIR/known_hosts" -o "$SSH_DIR/known_hosts"
chmod 644 "$SSH_DIR/known_hosts"
log "known_hosts updated"

# ── 10. Write ~/.ssh/config if missing ───────────────────────────────────────
SSH_CONF="$SSH_DIR/config"
if ! grep -q "Host github.com" "$SSH_CONF" 2>/dev/null; then
 cat >>"$SSH_CONF" <<EOF

# GitHub
Host github.com
  HostName      github.com
  User          git
  IdentityFile  $KEY
  AddKeysToAgent yes
EOF
 chmod 600 "$SSH_CONF"
 log "~/.ssh/config entry added for github.com"
else
 warn "~/.ssh/config already has a github.com entry — skipped"
fi

# ── 11. Final listing + public key ───────────────────────────────────────────
echo ""
echo -e "${BOLD}${CYAN}══ File listing ══════════════════════════════════════${RESET}"
ls -la "$SSH_DIR"

echo ""
echo -e "${BOLD}${CYAN}══ Public Key (paste into GitHub → Settings → SSH Keys) ══${RESET}"
cat "${KEY}.pub"

echo ""
echo -e "${BOLD}${CYAN}══ Test SSH to GitHub ════════════════════════════════════${RESET}"
info "Running: ssh -T git@github.com"
SSH_TEST=$(ssh -T git@github.com -o StrictHostKeyChecking=no -o BatchMode=yes 2>&1 || true)
echo "$SSH_TEST"
echo "$SSH_TEST" | grep -q "successfully authenticated" &&
 log "GitHub SSH auth: ${GREEN}SUCCESS ✔${RESET}" ||
 warn "Not authenticated yet — add the public key above to:
  https://github.com/settings/keys  →  New SSH key"

echo -e "\n${GREEN}${BOLD}Done!${RESET}  Keys are at:"
echo -e "  Private : ${BOLD}$KEY${RESET}"
echo -e "  Public  : ${BOLD}${KEY}.pub${RESET}"
