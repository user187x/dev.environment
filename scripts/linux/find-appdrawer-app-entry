#!/usr/bin/env bash

# find-appdrawer-app-entry
# Search for .desktop files across all standard app drawer locations (case-insensitive)
# Usage: find-appdrawer-app-entry <search-term>

SEARCH_TERM="$1"

# Colours
RED='\033[0;31m'
GREEN='\033[0;32m'
YELLOW='\033[1;33m'
CYAN='\033[0;36m'
BOLD='\033[1m'
RESET='\033[0m'

# --- Usage check ---
if [[ -z "$SEARCH_TERM" ]]; then
    echo -e "${RED}Error:${RESET} No search term provided."
    echo -e "Usage: ${BOLD}find-appdrawer-app-entry <search-term>${RESET}"
    echo -e "Example: find-appdrawer-app-entry lm-studio"
    exit 1
fi

# --- Locations to search ---
LOCATIONS=(
    "/usr/share/applications"
    "$HOME/.local/share/applications"
    "/var/lib/snapd/desktop/applications"
    "/var/lib/flatpak/exports/share/applications"
    "/usr/local/share/applications"
)

echo -e "\n${BOLD}Searching for:${RESET} ${CYAN}${SEARCH_TERM}${RESET}"
echo -e "${BOLD}─────────────────────────────────────────────────────${RESET}\n"

FOUND=0

for LOCATION in "${LOCATIONS[@]}"; do
    # Skip locations that don't exist
    if [[ ! -d "$LOCATION" ]]; then
        continue
    fi

    # Find matching .desktop files (case-insensitive)
    while IFS= read -r -d '' FILE; do
        FOUND=$((FOUND + 1))
        FILENAME=$(basename "$FILE")

        # Extract useful fields from the desktop file
        APP_NAME=$(grep -m1 "^Name=" "$FILE" 2>/dev/null | cut -d'=' -f2-)
        EXEC=$(grep -m1 "^Exec=" "$FILE" 2>/dev/null | cut -d'=' -f2-)
        COMMENT=$(grep -m1 "^Comment=" "$FILE" 2>/dev/null | cut -d'=' -f2-)
        NO_DISPLAY=$(grep -m1 "^NoDisplay=" "$FILE" 2>/dev/null | cut -d'=' -f2-)

        # Visibility indicator
        if [[ "${NO_DISPLAY,,}" == "true" ]]; then
            VISIBILITY="${YELLOW}[hidden from drawer]${RESET}"
        else
            VISIBILITY="${GREEN}[visible in drawer]${RESET}"
        fi

        echo -e "${BOLD}File:${RESET}     $FILE"
        echo -e "${BOLD}Name:${RESET}     ${APP_NAME:-N/A}"
        echo -e "${BOLD}Exec:${RESET}     ${EXEC:-N/A}"
        echo -e "${BOLD}Comment:${RESET}  ${COMMENT:-N/A}"
        echo -e "${BOLD}Status:${RESET}   $VISIBILITY"
        echo -e "${BOLD}─────────────────────────────────────────────────────${RESET}\n"

    done < <(find "$LOCATION" -maxdepth 1 -iname "*${SEARCH_TERM}*.desktop" -print0 2>/dev/null)
done

# --- Summary ---
if [[ $FOUND -eq 0 ]]; then
    echo -e "${RED}No .desktop entries found for:${RESET} ${CYAN}${SEARCH_TERM}${RESET}\n"
    exit 1
else
    echo -e "${GREEN}${FOUND} entry/entries found for:${RESET} ${CYAN}${SEARCH_TERM}${RESET}\n"
fi
