#!/bin/bash

# 1. Ensure the script is NOT run as root initially
if [ "$EUID" -eq 0 ]; then
 echo "Error: Please run this script as your standard user, NOT with sudo."
 echo "The script will prompt you for your password when it needs root privileges."
 exit 1
fi

echo "=========================================="
echo " Ubuntu 24 Debloat & Cleanup Script"
echo "=========================================="

echo -e "\n[1/5] Applying User-Specific Preferences..."

# Disable pesky shell message
touch ~/.hushlogin

# Disable ~/.lesshist file safely
if ! grep -q "LESSHISTFILE" ~/.bashrc; then
 echo "export LESSHISTFILE=/dev/null" >>~/.bashrc
fi

# Remove recent files from nautilus file browser
gsettings set org.gnome.desktop.privacy remember-recent-files false

# Add right-click "New Document > New File" to context menu
mkdir -p ~/Templates
touch ~/Templates/Text\ File.txt

echo -e "\n[2/5] Requesting administrative privileges for system changes..."
# This caches your sudo credentials for the rest of the script
sudo -v

# Disable pesky 'sudo_successful' file at home directory
echo "Defaults !admin_flag" | sudo tee /etc/sudoers.d/disable_admin_file_in_home >/dev/null
sudo chmod 440 /etc/sudoers.d/disable_admin_file_in_home

echo -e "\n[3/5] Purging unwanted applications via APT..."
# Remove LibreOffice
sudo apt-get remove --purge -y libreoffice* uno-libs-private ure

# Remove Help (Yelp) and Totem (Fixing the broken syntax from the original script)
sudo apt-get remove --purge -y yelp libreoffice-help-* totem
sudo rm -f /usr/share/applications/yelp.desktop

# Remove Thunderbird (APT version)
sudo apt-get remove --purge -y thunderbird*

echo -e "\n[4/5] Checking for and removing Snap packages..."
# Check for snap before trying to remove Thunderbird snap
if command -v snap >/dev/null 2>&1; then
 echo "Snap installed. Removing Thunderbird snap..."
 sudo snap remove thunderbird || true
else
 echo "Snap not installed, skipping..."
fi

echo -e "\n[5/5] Erasing system-wide and user configuration directories..."

# Erase system-wide configuration directories
sudo rm -rf /etc/thunderbird
sudo rm -rf /usr/lib/thunderbird
sudo rm -rf /usr/share/thunderbird
sudo rm -f /usr/share/applications/thunderbird.desktop

# Hunt down user-specific mail profiles and caches across all home directories
for user_home in /home/*; do
 if [ -d "$user_home/.thunderbird" ]; then
  sudo rm -rf "$user_home/.thunderbird"
 fi
 if [ -d "$user_home/.cache/thunderbird" ]; then
  sudo rm -rf "$user_home/.cache/thunderbird"
 fi
done

# Check root user directories
if [ -d "/root/.thunderbird" ]; then
 sudo rm -rf "/root/.thunderbird"
fi

echo -e "\n[Cleaning Up] Removing orphaned dependencies and APT cache..."
sudo apt-get autoremove --purge -y
sudo apt-get autoclean -y

# Refresh the GNOME application menu cache
if command -v update-desktop-database >/dev/null 2>&1; then
 sudo update-desktop-database /usr/share/applications
fi

echo "----------------------------------------"
echo "Success: Unnecessary apps removed and Ubuntu 24 debloated."
